[2026-04-10 01:40:21] [DEBUG] [PPT PostToolUse Hook] stdin 数据: {"session_id":"2040121509614309376","transcript_path":"/root/.codebuddy/projects/workspace/2040121509614309376.jsonl","cwd":"/workspace","hook_event_name":"PostToolUse","tool_name":"Write","tool_input":{"content":"import { useState } from 'react';\nimport { useStrategies } from '@/hooks/use-strategies';\nimport { Card, CardContent, CardHeader } from '@/components/ui/card';\nimport { Button } from '@/components/ui/button';\nimport { Input } from '@/components/ui/input';\nimport { Badge } from '@/components/ui/badge';\nimport { Progress } from '@/components/ui/progress';\nimport { Skeleton } from '@/components/ui/skeleton';\nimport {\n  Table,\n  TableBody,\n  TableCell,\n  TableHead,\n  TableHeader,\n  TableRow,\n} from '@/components/ui/table';\nimport {\n  Dialog,\n  DialogContent,\n  DialogHeader,\n  DialogTitle,\n  DialogFooter,\n} from '@/components/ui/dialog';\nimport { Label } from '@/components/ui/label';\nimport { Textarea } from '@/components/ui/textarea';\nimport {\n  Select,\n  SelectContent,\n  SelectItem,\n  SelectTrigger,\n  SelectValue,\n} from '@/components/ui/select';\nimport { FadeIn } from '@/components/MotionPrimitives';\nimport { Plus, Search, Edit, Trash2, Target, AlertCircle, Link, ChevronRight } from 'lucide-react';\nimport type { Strategy } from '@/types';\n\nexport default function StrategyList() {\n  const [search, setSearch] = useState('');\n  const [statusFilter, setStatusFilter] = useState<string>('all');\n  const [dialogOpen, setDialogOpen] = useState(false);\n  const [editingStrategy, setEditingStrategy] = useState<Strategy | null>(null);\n  const [submitting, setSubmitting] = useState(false);\n  const [formData, setFormData] = useState({\n    title: '',\n    description: '',\n    year: new Date().getFullYear(),\n    startDate: '',\n    endDate: '',\n  });\n\n  const { strategies, loading, error, createStrategy, updateStrategy, deleteStrategy } = useStrategies({\n    search,\n    status: statusFilter !== 'all' ? statusFilter : undefined,\n  });\n\n  const handleSubmit = async (e: React.FormEvent) => {\n    e.preventDefault();\n    try {\n      setSubmitting(true);\n      if (editingStrategy) {\n        await updateStrategy(editingStrategy.id, formData);\n      } else {\n        await createStrategy(formData);\n      }\n      setDialogOpen(false);\n      resetForm();\n    } catch (err: any) {\n      alert(err.message);\n    } finally {\n      setSubmitting(false);\n    }\n  };\n\n  const handleEdit = (strategy: Strategy) => {\n    setEditingStrategy(strategy);\n    setFormData({\n      title: strategy.title,\n      description: strategy.description || '',\n      year: strategy.year,\n      startDate: strategy.startDate.split('T')[0],\n      endDate: strategy.endDate.split('T')[0],\n    });\n    setDialogOpen(true);\n  };\n\n  const handleDelete = async (id: string) => {\n    if (confirm('确定要删除这个战略目标吗？')) {\n      try {\n        await deleteStrategy(id);\n      } catch (err: any) {\n        alert(err.message);\n      }\n    }\n  };\n\n  const resetForm = () => {\n    setFormData({\n      title: '',\n      description: '',\n      year: new Date().getFullYear(),\n      startDate: '',\n      endDate: '',\n    });\n    setEditingStrategy(null);\n  };\n\n  const statusStyles: Record<string, string> = {\n    draft: 'bg-gray-100 text-gray-700',\n    active: '',\n    completed: 'bg-green-100 text-green-700',\n    archived: 'bg-gray-100 text-gray-500',\n  };\n\n  const statusLabels: Record<string, string> = {\n    draft: '草稿',\n    active: '进行中',\n    completed: '已完成',\n    archived: '已归档',\n  };\n\n  if (error) {\n    return (\n      <div className=\"flex items-center justify-center h-64\">\n        <div className=\"text-center\">\n          <AlertCircle className=\"w-12 h-12 mx-auto text-destructive mb-4\" />\n          <p className=\"text-destructive\">{error}</p>\n        </div>\n      </div>\n    );\n  }\n\n  return (\n    <div className=\"space-y-6\">\n      <FadeIn>\n        <div className=\"flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4\">\n          <div>\n            <h1 className=\"font-bold\" style={{ fontSize: 'var(--font-size-headline)' }}>\n              战略管理\n            </h1>\n            <p className=\"text-muted-foreground\" style={{ fontSize: 'var(--font-size-label)' }}>\n              管理公司战略目标，追踪落地执行\n            </p>\n          </div>\n          <Button onClick={() => { resetForm(); setDialogOpen(true); }}>\n            <Plus className=\"w-4 h-4 mr-2\" />\n            新建战略\n          </Button>\n        </div>\n      </FadeIn>\n\n      <FadeIn>\n        <Card>\n          <CardHeader>\n            <div className=\"flex flex-col sm:flex-row gap-4\">\n              <div className=\"relative flex-1\">\n                <Search className=\"absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-muted-foreground\" />\n                <Input\n                  placeholder=\"搜索战略...\"\n                  value={search}\n                  onChange={(e) => setSearch(e.target.value)}\n                  className=\"pl-10\"\n                />\n              </div>\n              <Select value={statusFilter} onValueChange={setStatusFilter}>\n                <SelectTrigger className=\"w-[150px]\">\n                  <SelectValue placeholder=\"状态筛选\" />\n                </SelectTrigger>\n                <SelectContent>\n                  <SelectItem value=\"all\">全部状态</SelectItem>\n                  <SelectItem value=\"active\">进行中</SelectItem>\n                  <SelectItem value=\"completed\">已完成</SelectItem>\n                  <SelectItem value=\"draft\">草稿</SelectItem>\n                </SelectContent>\n              </Select>\n            </div>\n          </CardHeader>\n          <CardContent>\n            {loading ? (\n              <div className=\"space-y-4\">\n                {[1, 2, 3].map((i) => (\n                  <Skeleton key={i} className=\"h-16\" />\n                ))}\n              </div>\n            ) : (\n              <div className=\"overflow-x-auto\">\n                <Table>\n                  <TableHeader>\n                    <TableRow>\n                      <TableHead>战略名称</TableHead>\n                      <TableHead>年度</TableHead>\n                      <TableHead>状态</TableHead>\n                      <TableHead>进度</TableHead>\n                      <TableHead>关联计划</TableHead>\n                      <TableHead>落地链路</TableHead>\n                      <TableHead className=\"text-right\">操作</TableHead>\n                    </TableRow>\n                  </TableHeader>\n                  <TableBody>\n                    {strategies.map((strategy) => (\n                      <TableRow key={strategy.id}>\n                        <TableCell>\n                          <div className=\"flex items-center gap-3\">\n                            <div \n                              className=\"p-2 rounded-lg\"\n                              style={{ background: 'var(--muted)' }}\n                            >\n                              <Target className=\"w-4 h-4\" style={{ color: 'oklch(0.42 0.19 250)' }} />\n                            </div>\n                            <div>\n                              <div className=\"font-medium\">{strategy.title}</div>\n                              {strategy.description && (\n                                <div className=\"text-xs text-muted-foreground truncate max-w-xs\">\n                                  {strategy.description}\n                                </div>\n                              )}\n                            </div>\n                          </div>\n                        </TableCell>\n                        <TableCell>{strategy.year}</TableCell>\n                        <TableCell>\n                          <Badge className={statusStyles[strategy.status]}>\n                            {statusLabels[strategy.status]}\n                          </Badge>\n                        </TableCell>\n                        <TableCell>\n                          <div className=\"flex items-center gap-2\">\n                            <Progress value={strategy.progress} className=\"w-20 h-2\" />\n                            <span className=\"text-sm\">{strategy.progress}%</span>\n                          </div>\n                        </TableCell>\n                        <TableCell>\n                          <div className=\"flex items-center gap-1\">\n                            <Link className=\"w-3 h-3 text-blue-600\" />\n                            <span className=\"font-medium text-blue-600\">{strategy.planCount || 0}</span>\n                            <span className=\"text-muted-foreground text-sm\">个计划</span>\n                          </div>\n                        </TableCell>\n                        <TableCell>\n                          <div className=\"flex items-center gap-1 text-xs text-muted-foreground\">\n                            <span className=\"text-purple-600 font-medium\">战略</span>\n                            <ChevronRight className=\"w-3 h-3\" />\n                            <span className=\"text-blue-600\">计划</span>\n                            <ChevronRight className=\"w-3 h-3\" />\n                            <span className=\"text-green-600\">任务</span>\n                          </div>\n                        </TableCell>\n                        <TableCell className=\"text-right\">\n                          <Button variant=\"ghost\" size=\"sm\" onClick={() => handleEdit(strategy)}>\n                            <Edit className=\"w-4 h-4\" />\n                          </Button>\n                          <Button variant=\"ghost\" size=\"sm\" onClick={() => handleDelete(strategy.id)}>\n                            <Trash2 className=\"w-4 h-4 text-destructive\" />\n                          </Button>\n                        </TableCell>\n                      </TableRow>\n                    ))}\n                    {strategies.length === 0 && (\n                      <TableRow>\n                        <TableCell colSpan={7} className=\"text-center py-8 text-muted-foreground\">\n                          暂无数据\n                        </TableCell>\n                      </TableRow>\n                    )}\n                  </TableBody>\n                </Table>\n              </div>\n            )}\n          </CardContent>\n        </Card>\n      </FadeIn>\n\n      {/* 新建/编辑对话框 */}\n      <Dialog open={dialogOpen} onOpenChange={setDialogOpen}>\n        <DialogContent>\n          <DialogHeader>\n            <DialogTitle>\n              {editingStrategy ? '编辑战略' : '新建战略'}\n            </DialogTitle>\n          </DialogHeader>\n          <form onSubmit={handleSubmit} className=\"space-y-4\">\n            <div className=\"space-y-2\">\n              <Label htmlFor=\"title\">战略名称 *</Label>\n              <Input\n                id=\"title\"\n                value={formData.title}\n                onChange={(e) => setFormData({ ...formData, title: e.target.value })}\n                required\n              />\n            </div>\n            <div className=\"space-y-2\">\n              <Label htmlFor=\"description\">战略描述</Label>\n              <Textarea\n                id=\"description\"\n                value={formData.description}\n                onChange={(e) => setFormData({ ...formData, description: e.target.value })}\n                rows={3}\n              />\n            </div>\n            <div className=\"grid grid-cols-2 gap-4\">\n              <div className=\"space-y-2\">\n                <Label htmlFor=\"year\">年度</Label>\n                <Input\n                  id=\"year\"\n                  type=\"number\"\n                  value={formData.year}\n                  onChange={(e) => setFormData({ ...formData, year: parseInt(e.target.value) })}\n                  required\n                />\n              </div>\n              <div></div>\n              <div className=\"space-y-2\">\n                <Label htmlFor=\"startDate\">开始日期</Label>\n                <Input\n                  id=\"startDate\"\n                  type=\"date\"\n                  value={formData.startDate}\n                  onChange={(e) => setFormData({ ...formData, startDate: e.target.value })}\n                  required\n                />\n              </div>\n              <div className=\"space-y-2\">\n                <Label htmlFor=\"endDate\">结束日期</Label>\n                <Input\n                  id=\"endDate\"\n                  type=\"date\"\n                  value={formData.endDate}\n                  onChange={(e) => setFormData({ ...formData, endDate: e.target.value })}\n                  required\n                />\n              </div>\n            </div>\n            <DialogFooter>\n              <Button type=\"button\" variant=\"outline\" onClick={() => setDialogOpen(false)}>\n                取消\n              </Button>\n              <Button type=\"submit\" disabled={submitting}>\n                {submitting ? '提交中...' : (editingStrategy ? '保存' : '创建')}\n              </Button>\n            </DialogFooter>\n          </form>\n        </DialogContent>\n      </Dialog>\n    </div>\n  );\n}\n","file_path":"/workspace/frontend/src/pages/StrategyList.tsx"},"tool_response":"Successfully overwrote file: /workspace/frontend/src/pages/StrategyList.tsx","client":"CLI","version":"2.71.1","generation_id":"f309304b85e046b082d28d265054930d","model":"glm-5.0","call_id":"019d750b522168aff4cb3e6496f44b21"}
