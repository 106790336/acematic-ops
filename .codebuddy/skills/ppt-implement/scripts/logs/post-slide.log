og(true); };\n  const onDialogChange = (open: boolean) => { setShowDialog(open); if (!open) resetForm(); };"},{"new_string":"          <Button onClick={openCreate} disabled={!hasPermission('report:create')}><Plus className=\"w-4 h-4 mr-2\" />提交周报</Button>","old_string":"          <Button onClick={openCreate}><Plus className=\"w-4 h-4 mr-2\" />提交周报</Button>"},{"new_string":"                      <TableCell>\n                        {canEditContent((item as any).submitterId || '') && <Button variant=\"ghost\" size=\"sm\" onClick={() => onEdit(item)}><Edit className=\"w-4 h-4\" /></Button>}\n                        {canDeleteContent((item as any).submitterId || '') && <Button variant=\"ghost\" size=\"sm\" onClick={() => onDelete(item.id)}><Trash2 className=\"w-4 h-4 text-destructive\" /></Button>}\n                      </TableCell>","old_string":"                      <TableCell>\n                        <Button variant=\"ghost\" size=\"sm\" onClick={() => onEdit(item)}><Edit className=\"w-4 h-4\" /></Button>\n                        <Button variant=\"ghost\" size=\"sm\" onClick={() => onDelete(item.id)}><Trash2 className=\"w-4 h-4 text-destructive\" /></Button>\n                      </TableCell>"},{"new_string":"            <div className=\"space-y-2\">\n              <div className=\"flex items-center justify-between\">\n                <Label>完成事项 *</Label>\n                <Button type=\"button\" variant=\"outline\" size=\"sm\" onClick={pullTaskSummary} disabled={!form.weekDate || !form.departmentId}>\n                  <ListTodo className=\"w-3 h-3 mr-1\" />拉取任务汇总\n                </Button>\n              </div>\n              <Textarea value={form.completedTasks} onChange={e => setForm({...form, completedTasks: e.target.value})} rows={4} placeholder=\"本周完成的主要工作，点击“拉取任务汇总”自动填充\" required />\n              {taskSummary.length > 0 && <div className=\"text-xs text-muted-foreground\">已拉取 {taskSummary.length} 条任务</div>}\n            </div>","old_string":"            