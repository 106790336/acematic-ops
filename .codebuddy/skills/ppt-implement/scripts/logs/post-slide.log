      borderRadius: '8px',\n                      }}\n                    />\n                    <Bar dataKey=\"completionRate\" fill=\"oklch(0.42 0.19 250)\" radius={[4, 4, 0, 0]} />\n                  </BarChart>\n                </ResponsiveContainer>\n              </div>\n            </CardContent>\n          </Card>\n        </FadeIn>\n\n        {/* 考核趋势 */}\n        <FadeIn>\n          <Card>\n            <CardHeader>\n              <CardTitle className=\"flex items-center gap-2\">\n                <TrendingUp className=\"w-5 h-5\" style={{ color: 'oklch(0.58 0.20 250)' }} />\n                考核趋势\n              </CardTitle>\n            </CardHeader>\n            <CardContent>\n              <div className=\"h-64\">\n                <ResponsiveContainer width=\"100%\" height=\"100%\">\n                  <LineChart data={assessmentTrends}>\n                    <CartesianGrid strokeDasharray=\"3 3\" stroke=\"oklch(0.90 0 0)\" />\n                    <XAxis dataKey=\"period\" tick={{ fontSize: 12 }} />\n                    <YAxis domain={[0, 100]} tick={{ fontSize: 12 }} />\n                    <Tooltip \n                      contentStyle={{ \n                        background: 'white',\n                        border: '1px solid oklch(0.90 0 0)',\n                        borderRadius: '8px',\n                      }}\n                    />\n                    <Line \n                      type=\"monotone\" \n                      dataKey=\"avgScore\" \n                      stroke=\"oklch(0.42 0.19 250)\" \n                      strokeWidth={2}\n                      dot={{ fill: 'oklch(0.42 0.19 250)', strokeWidth: 2 }}\n                    />\n                  </LineChart>\n                </ResponsiveContainer>\n              </div>\n            </CardContent>\n          </Card>\n        </FadeIn>\n      </div>\n\n      {/* 最近计划 */}\n      <FadeIn>\n        <Card>\n          <CardHeader>\n            <CardTitle className=\"flex items-center gap-2\">\n