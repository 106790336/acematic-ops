ation(\"UserAchievements\", fields: [userId], references: [id])\n}\n\n// 战略对齐统计\nmodel AlignmentStats {\n  id              String   @id @default(cuid())\n  userId          String?\n  departmentId    String?\n  period          String   // 2026-04\n  totalTasks      Int      @default(0)\n  alignedTasks    Int      @default(0)\n  alignmentRate   Float    @default(0)\n  unalignedReason String?\n  createdAt       DateTime @default(now())\n  updatedAt       DateTime @updatedAt\n}\n","file_path":"/workspace/backend/prisma/schema.prisma"},"tool_response":"Successfully overwrote file: /workspace/backend/prisma/schema.prisma","client":"CLI","version":"2.71.1","generation_id":"4a21942503834f83b9b2bef5507d5219","model":"glm-5.0","call_id":"019d715b0f47a88e1130081ac42a0233"}
