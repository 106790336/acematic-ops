[2026-04-09 04:40:25] [DEBUG] [PPT PostToolUse Hook] stdin 数据: {"session_id":"2040121509614309376","transcript_path":"/root/.codebuddy/projects/workspace/2040121509614309376.jsonl","cwd":"/workspace","hook_event_name":"PostToolUse","tool_name":"Write","tool_input":{"content":"import { useState, useEffect } from 'react';\nimport { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';\nimport { Button } from '@/components/ui/button';\nimport { Input } from '@/components/ui/input';\nimport { Badge } from '@/components/ui/badge';\nimport { Skeleton } from '@/components/ui/skeleton';\nimport { Textarea } from '@/components/ui/textarea';\nimport { Label } from '@/components/ui/label';\nimport { Progress } from '@/components/ui/progress';\nimport {\n  Dialog,\n  DialogContent,\n  DialogHeader,\n  DialogTitle,\n  DialogFooter,\n} from '@/components/ui/dialog';\nimport {\n  Select,\n  SelectContent,\n  SelectItem,\n  SelectTrigger,\n  SelectValue,\n} from '@/components/ui/select';\nimport { FadeIn } from '@/components/MotionPrimitives';\nimport { Plus, AlertTriangle, CheckCircle, Clock, Search } from 'lucide-react';\nimport { apiClient, getErrorMessage } from '@/lib/api-client';\nimport type { Issue, Department, User, ApiResponse, PaginatedResponse } from '@/types';\n\nexport default function IssueList() {\n  const [issues, setIssues] = useState<Issue[]>([]);\n  const [departments, setDepartments] = useState<Department[]>([]);\n  const [users, setUsers] = useState<User[]>([]);\n  const [loading, setLoading] = useState(true);\n  const [dialogOpen, setDialogOpen] = useState(false);\n  const [search, setSearch] = useState('');\n  const [statusFilter, setStatusFilter] = useState('all');\n  const [formData, setFormData] = useState({\n    source: '周报',\n    discoveryDate: '',\n    departmentId: '',\n    description: '',\n    issueType: '质量问题',\n    severity: '中',\n    responsibleId: '',\n    planCompleteDate: '',\n  });\n\n  useEffect(() => {\n    fetchIssues();\n    fetchDepartments();\n    fetchUsers();\n  }, [search, statusFilter]);\n\n  const fetchIssues = async () => {\n    setLoading(true);\n    try {\n      const params = new URLSearchParams();\n      if (search) params.append('search', search);\n      if (statusFilter !== 'all') params.append('status', statusFilter);\n      \n      const response = await apiClient.get<ApiResponse<PaginatedResponse<Issue>>>(`/issues?${params.toString()}`);\n      if (response.data.success && response.data.data) {\n        setIssues(response.data.data.items);\n      }\n    } catch (err) {\n      console.error('Fetch issues error:', err);\n    } finally {\n      setLoading(false);\n    }\n  };\n\n  const fetchDepartments = async () => {\n    try {\n      const response = await apiClient.get<ApiResponse<Department[]>>('/departments/list');\n      if (response.data.success && response.data.data) {\n        setDepartments(response.data.data);\n      }\n    } catch (err) {\n      console.error('Fetch departments error:', err);\n    }\n  };\n\n  const fetchUsers = async () => {\n    try {\n      const response = await apiClient.get<ApiResponse<PaginatedResponse<User>>>('/users?limit=100');\n      if (response.data.success && response.data.data) {\n        setUsers(response.data.data.items);\n      }\n    } catch (err) {\n      console.error('Fetch users error:', err);\n    }\n  };\n\n  const handleSubmit = async (e: React.FormEvent) => {\n    e.preventDefault();\n    try {\n      await apiClient.post('/issues', formData);\n      setDialogOpen(false);\n      resetForm();\n      fetchIssues();\n    } catch (err: any) {\n      alert(err.response?.data?.error || getErrorMessage(err));\n    }\n  };\n\n  const handleUpdateStatus = async (id: string, status: string) => {\n    try {\n      await apiClient.put(`/issues/${id}`, { status });\n      fetchIssues();\n    } catch (err: any) {\n      alert(err.response?.data?.error || getErrorMessage(err));\n    }\n  };\n\n  const resetForm = () => {\n    setFormData({\n      source: '周报',\n      discoveryDate: '',\n      departmentId: '',\n      description: '',\n      issueType: '质量问题',\n      severity: '中',\n      responsibleId: '',\n      planCompleteDate: '',\n    });\n  };\n\n  const statusColors: Record<string, string> = {\n    '待处理': 'destructive',\n    '处理中': 'default',\n    '已解决': 'success',\n    '挂起': 'secondary',\n  };\n\n  const severityColors: Record<string, string> = {\n    '高': 'destructive',\n    '中': 'warning',\n    '低': 'secondary',\n  };\n\n  const severityIcons: Record<string, any> = {\n    '高': AlertTriangle,\n    '中': Clock,\n    '低': CheckCircle,\n  };\n\n  return (\n    <div className=\"space-y-6\">\n      <FadeIn>\n        <div className=\"flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4\">\n          <div>\n            <h1 className=\"font-bold\" style={{ fontSize: 'var(--font-size-headline)' }}>\n              问题清单\n            </h1>\n            <p className=\"text-muted-foreground\" style={{ fontSize: 'var(--font-size-label)' }}>\n              统一管理所有问题，跟踪解决进度\n            </p>\n          </div>\n          <Button onClick={() => setDialogOpen(true)}>\n            <Plus className=\"w-4 h-4 mr-2\" />\n            新建问题\n          </Button>\n        </div>\n      </FadeIn>\n\n      <FadeIn>\n        <Card>\n          <CardHeader>\n            <div className=\"flex flex-col sm:flex-row gap-4\">\n              <div className=\"relative flex-1\">\n                <Search className=\"absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-muted-foreground\" />\n                <Input\n                  placeholder=\"搜索问题编号或描述...\"\n                  value={search}\n                  onChange={(e) => setSearch(e.target.value)}\n                  className=\"pl-10\"\n                />\n              </div>\n              <Select value={statusFilter} onValueChange={setStatusFilter}>\n                <SelectTrigger className=\"w-[120px]\">\n                  <SelectValue placeholder=\"状态筛选\" />\n                </SelectTrigger>\n                <SelectContent>\n                  <SelectItem value=\"all\">全部状态</SelectItem>\n                  <SelectItem value=\"待处理\">待处理</SelectItem>\n                  <SelectItem value=\"处理中\">处理中</SelectItem>\n                  <SelectItem value=\"已解决\">已解决</SelectItem>\n                  <SelectItem value=\"挂起\">挂起</SelectItem>\n                </SelectContent>\n              </Select>\n            </div>\n          </CardHeader>\n          <CardContent>\n            {loading ? (\n              <div className=\"space-y-4\">\n                {[1, 2, 3].map((i) => (\n                  <Skeleton key={i} className=\"h-24\" />\n                ))}\n              </div>\n            ) : issues.length === 0 ? (\n              <div className=\"text-center py-12\">\n                <CheckCircle className=\"w-16 h-16 mx-auto text-muted-foreground mb-4\" />\n                <p className=\"text-muted-foreground\">暂无问题记录</p>\n              </div>\n            ) : (\n              <div className=\"space-y-4\">\n                {issues.map((issue) => {\n                  const SeverityIcon = severityIcons[issue.severity] || Clock;\n                  return (\n                    <div\n                      key={issue.id}\n                      className=\"p-4 rounded-lg border\"\n                      style={{ borderColor: 'var(--border)' }}\n                    >\n                      <div className=\"flex items-start justify-between mb-3\">\n                        <div className=\"flex items-start gap-3\">\n                          <div \n                            className=\"p-2 rounded-lg\"\n                            style={{ \n                              background: issue.severity === '高' \n                                ? 'oklch(0.95 0.03 25)' \n                                : 'var(--muted)' \n                            }}\n                          >\n                            <SeverityIcon \n                              className=\"w-5 h-5\" \n                              style={{ \n                                color: issue.severity === '高' \n                                  ? 'oklch(0.55 0.22 25)' \n                                  : 'oklch(0.42 0.19 250)' \n                              }} \n                            />\n                          </div>\n                          <div className=\"flex-1\">\n                            <div className=\"flex items-center gap-2 mb-1\">\n                              <span className=\"font-mono text-sm text-muted-foreground\">\n                                {issue.issueNumber}\n                              </span>\n                              <Badge variant={severityColors[issue.severity] as any}>\n                                {issue.severity}优先\n                              </Badge>\n                              <Badge variant={statusColors[issue.status] as any}>\n                                {issue.status}\n                              </Badge>\n                            </div>\n                            <div className=\"font-medium\">{issue.description}</div>\n                            <div className=\"flex items-center gap-4 mt-2 text-sm text-muted-foreground\">\n                              <span>{issue.department?.name}</span>\n                              <span>{issue.issueType}</span>\n                              <span>来源: {issue.source}</span>\n                            </div>\n                          </div>\n                        </div>\n                        <div className=\"flex items-center gap-2\">\n                          {issue.status === '待处理' && (\n                            <Button size=\"sm\" variant=\"outline\" onClick={() => handleUpdateStatus(issue.id, '处理中')}>\n                              开始处理\n                            </Button>\n                          )}\n                          {issue.status === '处理中' && (\n                            <Button size=\"sm\" variant=\"outline\" onClick={() => handleUpdateStatus(issue.id, '已解决')}>\n                              标记解决\n                            </Button>\n                          )}\n                        </div>\n                      </div>\n\n                      {issue.responsible && (\n                        <div className=\"flex items-center gap-2 text-sm text-muted-foreground\">\n                          <span>责任人: {issue.responsible.name}</span>\n                          {issue.planCompleteDate && (\n                            <span>· 计划完成: {new Date(issue.planCompleteDate).toLocaleDateString('zh-CN')}</span>\n                          )}\n                        </div>\n                      )}\n\n                      <div className=\"mt-2 text-sm text-muted-foreground\">\n                        发现时间: {new Date(issue.discoveryDate).toLocaleDateString('zh-CN')}\n                      </div>\n                    </div>\n                  );\n                })}\n              </div>\n            )}\n          </CardContent>\n        </Card>\n      </FadeIn>\n\n      {/* 新建问题对话框 */}\n      <Dialog open={dialogOpen} onOpenChange={setDialogOpen}>\n        <DialogContent className=\"max-w-2xl\">\n          <DialogHeader>\n            <DialogTitle>新建问题</DialogTitle>\n          </DialogHeader>\n          <form onSubmit={handleSubmit} className=\"space-y-4\">\n            <div className=\"grid grid-cols-2 gap-4\">\n              <div className=\"space-y-2\">\n                <Label htmlFor=\"source\">问题来源</Label>\n                <Select value={formData.source} onValueChange={(v) => setFormData({ ...formData, source: v })}>\n                  <SelectTrigger>\n                    <SelectValue />\n                  </SelectTrigger>\n                  <SelectContent>\n                    <SelectItem value=\"周报\">周报</SelectItem>\n                    <SelectItem value=\"会议\">会议</SelectItem>\n                    <SelectItem value=\"其他\">其他</SelectItem>\n                  </SelectContent>\n                </Select>\n              </div>\n              <div className=\"space-y-2\">\n                <Label htmlFor=\"discoveryDate\">发现时间</Label>\n                <Input\n                  id=\"discoveryDate\"\n                  type=\"date\"\n                  value={formData.discoveryDate}\n                  onChange={(e) => setFormData({ ...formData, discoveryDate: e.target.value })}\n                  required\n                />\n              </div>\n            </div>\n\n            <div className=\"grid grid-cols-2 gap-4\">\n              <div className=\"space-y-2\">\n                <Label htmlFor=\"department\">所属部门</Label>\n                <Select value={formData.departmentId} onValueChange={(v) => setFormData({ ...formData, departmentId: v })}>\n                  <SelectTrigger>\n                    <SelectValue placeholder=\"选择部门\" />\n                  </SelectTrigger>\n                  <SelectContent>\n                    {departments.map((dept) => (\n                      <SelectItem key={dept.id} value={dept.id}>\n                        {dept.name}\n                      </SelectItem>\n                    ))}\n                  </SelectContent>\n                </Select>\n              </div>\n              <div className=\"space-y-2\">\n                <Label htmlFor=\"issueType\">问题类型</Label>\n                <Select value={formData.issueType} onValueChange={(v) => setFormData({ ...formData, issueType: v })}>\n                  <SelectTrigger>\n                    <SelectValue />\n                  </SelectTrigger>\n                  <SelectContent>\n                    <SelectItem value=\"质量问题\">质量问题</SelectItem>\n                    <SelectItem value=\"交付问题\">交付问题</SelectItem>\n                    <SelectItem value=\"协作问题\">协作问题</SelectItem>\n                    <SelectItem value=\"其他\">其他</SelectItem>\n                  </SelectContent>\n                </Select>\n              </div>\n            </div>\n\n            <div className=\"space-y-2\">\n              <Label htmlFor=\"description\">问题描述</Label>\n              <Textarea\n                id=\"description\"\n                value={formData.description}\n                onChange={(e) => setFormData({ ...formData, description: e.target.value })}\n                placeholder=\"详细描述问题\"\n                rows={3}\n                required\n              />\n            </div>\n\n            <div className=\"grid grid-cols-3 gap-4\">\n              <div className=\"space-y-2\">\n                <Label>严重程度</Label>\n                <Select value={formData.severity} onValueChange={(v) => setFormData({ ...formData, severity: v })}>\n                  <SelectTrigger>\n                    <SelectValue />\n                  </SelectTrigger>\n                  <SelectContent>\n                    <SelectItem value=\"高\">高</SelectItem>\n                    <SelectItem value=\"中\">中</SelectItem>\n                    <SelectItem value=\"低\">低</SelectItem>\n                  </SelectContent>\n                </Select>\n              </div>\n              <div className=\"space-y-2\">\n                <Label htmlFor=\"responsible\">责任人</Label>\n                <Select value={formData.responsibleId} onValueChange={(v) => setFormData({ ...formData, responsibleId: v })}>\n                  <SelectTrigger>\n                    <SelectValue placeholder=\"选择责任人\" />\n                  </SelectTrigger>\n                  <SelectContent>\n                    {users.map((user) => (\n                      <SelectItem key={user.id} value={user.id}>\n                        {user.name}\n                      </SelectItem>\n                    ))}\n                  </SelectContent>\n                </Select>\n              </div>\n              <div className=\"space-y-2\">\n                <Label htmlFor=\"planCompleteDate\">计划完成时间</Label>\n                <Input\n                  id=\"planCompleteDate\"\n                  type=\"date\"\n                  value={formData.planCompleteDate}\n                  onChange={(e) => setFormData({ ...formData, planCompleteDate: e.target.value })}\n                />\n              </div>\n            </div>\n\n            <DialogFooter>\n              <Button type=\"button\" variant=\"outline\" onClick={() => setDialogOpen(false)}>\n                取消\n              </Button>\n              <Button type=\"submit\">创建</Button>\n            </DialogFooter>\n          </form>\n        </DialogContent>\n      </Dialog>\n    </div>\n  );\n}\n","file_path":"/workspace/frontend/src/pages/IssueList.tsx"},"tool_response":"Successfully created and wrote to new file: /workspace/frontend/src/pages/IssueList.tsx","client":"CLI","version":"2.71.1","generation_id":"9786ddd4976b4dc68ff557515b7a138b","model":"glm-5.0","call_id":"019d7089a9ce0676c35f92752fe184b6"}
