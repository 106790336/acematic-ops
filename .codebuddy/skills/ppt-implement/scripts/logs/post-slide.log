loadData = async () => {\n    try {\n      setLoading(true);\n      // 加载战略\n      const sRes = await apiClient.get('/strategies?limit=100');\n      const strategyList = sRes.data.data?.items || [];\n\n      // 加载计划\n      const pRes = await apiClient.get('/plans?limit=100');\n      const planList = pRes.data.data?.items || [];\n\n      // 加载任务\n      const tRes = await apiClient.get('/tasks-v2?limit=200');\n      const taskList = tRes.data.data?.items || [];\n\n      // 构建树形结构\n      const taskMap = new Map(taskList.map((t: any) => [t.id, { ...t, subTasks: [] }]));\n      const planMap = new Map(planList.map((p: any) => [p.id, { ...p, tasks: [] }]));\n\n      // 组织任务的子任务关系\n      taskList.forEach((t: any) => {\n        if (t.parentTaskId && taskMap.has(t.parentTaskId)) {\n          taskMap.get(t.parentTaskId)!.subTasks!.push(taskMap.get(t.id)!);\n        }\n      });\n\n      // 组织计划的任务关系\n      taskList.forEach((t: any) => {\n        if (t.planId && planMap.has(t.planId) && !t.parentTaskId) {\n          planMap.get(t.planId)!.tasks!.push(taskMap.get(t.id)!);\n        }\n      });\n\n      // 组织战略的计划关系\n      const result = strategyList.map((s: any) => ({\n        ...s,\n        plans: planList.filter((p: any) => p.strategyId === s.id).map((p: any) => planMap.get(p.id)!),\n      }));\n\n      setStrategies(result);\n      // 默认展开所有战略\n      setExpandedStrategies(new Set(strategyList.map((s: any) => s.id)));\n    } catch (e) {\n      console.error(e);\n    } finally {\n      setLoading(false);\n    }\n  };\n\n  const toggleStrategy = (id: string) => {\n    const newSet = new Set(expandedStrategies);\n    if (newSet.has(id)) newSet.delete(id);\n    else newSet.add(id);\n    setExpandedStrategies(newSet);\n  };\n\n  const togglePlan = (id: string) => {\n    const newSet = new Set(expandedPlans);\n    if (newSet.has(id)) newSet.delete(id);\n    else newSet.add(id);\n    setExpandedPlans(newSet);\n  };\n\n  const getStatusColor = (status: string) => {\n    const map: Record<string, string> = {\n      active: 'bg-blue-100 text-blue-700',\n      in_progress: 'bg-cyan-100 text-cyan-700',\n      completed: 'bg-green-100 text-green-700',\n      pending: 'bg-yellow-100 text-yellow-700',\n    };\n    return map[status] || 'bg-gray-100 text-gray-700';\n  };\n\n  const getPriorityColor = (priority: string) => {\n    const map: Record<string, string> = {\n      high: 'bg-red-100 text-red-700',\n      medium: 'bg-yellow-100 text-yellow-700',\n      low: 'bg-green-100 text-green-700',\n    };\n    return map[priority] || 'bg-gray-100 text-gray-700';\n  };\n\n  // 提取编号\n  const getCode = (title: string) => {\n    const match = title.match(/^([A-Z]\\d+(?:\\.\\d+)*)/);\n    return match ? match[1] : null;\n  };\n\n  // 渲染任务\n  const renderTask = (task: TaskItem, level: number = 2) => {\n    const hasSubtasks = task.subTasks && task.subTasks.length > 0;\n    const code = getCode(task.title) || task.taskNumber;\n\n    return (\n      <div key={task.id} className=\"mb-1\">\n        <div\n          className=\"flex items-center gap-2 p-2 rounded hover:bg-muted/50 cursor-pointer group\"\n          style={{ marginLeft: level * 20 }}\n          onClick={() => hasSubtasks && togglePlan(task.id)}\n        >\n          {hasSubtasks ? (\n            <button className=\"p-0.5\">\n              {expandedPlans.has(task.id) ? (\n                <ChevronDown className=\"w-4 h-4 text-muted-foreground\" />\n              ) : (\n                <ChevronRight className=\"w-4 h-4 text-muted-foreground\" />\n              )}\n            </button>\n          ) : (\n            <div className=\"w-5\" />\n          )}\n          <Badge variant=\"outline\" className=\"text-xs font-mono\">{code}</Badge>\n          <span className=\"flex-1 text-sm truncate\">{task.title.replace(/^[A-Z]\\d+(?:\\.\\d+)*\\s*/, '')}</span>\n          <span className=\"text-xs text-muted-foreground\">{task.assignee?.name || '-'}</span>\n          <Progress value={task.progress || 0} className=\"w-12 h-1.5\" />\n          <span className=\"text-xs w-8 text-right\">{task.progress || 0}%</span>\n          <Button variant=\"ghost\" size=\"sm\" className=\"opacity-0 group-hover:opacity-100\" onClick={(e) => { e.stopPropagation(); setDetailItem({ type: 'task', data: task }); }}>\n            <Eye className=\"w-3 h-3\" />\n          </Button>\n        </div>\n        {hasSubtasks && expandedPlans.has(task.id) && (\n          <div>\n            {task.subTasks!.map(st => renderTask(st, level + 1))}\n          </div>\n        )}\n      </div>\n    );\n  };\n\n  // 渲染计划\n  const renderPlan = (plan: PlanItem) => {\n    const hasTasks = plan.tasks && plan.tasks.length > 0;\n    const code = getCode(plan.title);\n\n    return (\n      <div key={plan.id} className=\"mb-2 border-l-2 border-blue-200 pl-3\">\n        <div\n          className=\"flex items-center gap-2 p-2 rounded hover:bg-blue-50/50 cursor-pointer group\"\n          onClick={() => hasTasks && togglePlan(plan.id)}\n        >\n          {hasTasks ? (\n            <button className=\"p-0.5\">\n              {expandedPlans.has(plan.id) ? (\n                <ChevronDown className=\"w-4 h-4 text-blue-500\" />\n              ) : (\n                <ChevronRight className=\"w-4 h-4 text-blue-500\" />\n              )}\n            </button>\n          ) : (\n            <div className=\"w-5\" />\n          )}\n          {code && <Badge className=\"bg-blue-100 text-blue-700 text-xs font-mono\">{code}</Badge>}\n          <span className=\"flex-1 font-medium text-sm\">{plan.title.replace(/^[A-Z]\\d+(?:\\.\\d+)*\\s*/, '')}</span>\n          <span className=\"text-xs text-muted-foreground\">{plan.department?.name || '-'}</span>\n          <Badge className={getStatusColor(plan.status)}>{plan.status === 'in_progress' ? '进行中' : plan.status}</Badge>\n          <Progress value={plan.progress || 0} className=\"w-12 h-1.5\" />\n          <span className=\"text-xs w-8 text-right\">{plan.progress || 0}%</span>\n          <Button variant=\"ghost\" size=\"sm\" className=\"opacity-0 group-hover:opacity-100\" onClick={(e) => { e.stopPropagation(); setDetailItem({ type: 'plan', data: plan }); }}>\n            <Eye className=\"w-3 h-3\" />\n          </Button>\n        </div>\n        {hasTasks && expandedPlans.has(plan.id) && (\n          <div className=\"mt-1 ml-4\">\n            {plan.tasks!.map(t => renderTask(t))}\n          </div>\n        )}\n      </div>\n    );\n  };\n\n  // 渲染战略\n  const renderStrategy = (strategy: StrategyItem, index: number) => {\n    const hasPlans = strategy.plans && strategy.plans.length > 0;\n    const isExpanded = expandedStrategies.has(strategy.id);\n\n    return (\n      <div key={strategy.id} className=\"mb-4 border rounded-lg overflow-hidden\">\n        <div\n          className=\"flex items-center gap-3 p-4 bg-gradient-to-r from-purple-50 to-blue-50 cursor-pointer\"\n          onClick={() => toggleStrategy(strategy.id)}\n        >\n          <Badge className=\"bg-purple-600 text-white text-sm font-mono px-3 py-1\">\n            O{index + 1}\n          </Badge>\n          <div className=\"flex-1\">\n            <div className=\"font-medium\">{strategy.title}</div>\n            <div className=\"flex items-center gap-4 mt-1\">\n              <span className=\"text-xs text-muted-foreground\">\n                {hasPlans ? `${strategy.plans!.length} 个计划` : '无计划'}\n              </span>\n              <Badge className={getStatusColor(strategy.status)}>\n                {strategy.status === 'active' ? '进行中' : strategy.status}\n              </Badge>\n            </div>\n          </div>\n          <div className=\"flex items-center gap-3\">\n            <Progress value={strategy.progress || 0} className=\"w-24 h-2\" />\n            <span className=\"text-sm font-medium\">{strategy.progress || 0}%</span>\n            {isExpanded ? (\n              <ChevronDown className=\"w-5 h-5 text-muted-foreground\" />\n            ) : (\n              <ChevronRight className=\"w-5 h-5 text-muted-foreground\" />\n            )}\n          </div>\n        </div>\n        {isExpanded && hasPlans && (\n          <div className=\"p-4 bg-white\">\n            {strategy.plans!.map(p => renderPlan(p))}\n          </div>\n        )}\n      </div>\n    );\n  };\n\n  if (loading) {\n    return (\n      <div className=\"space-y-6 p-6\">\n        {[1, 2, 3].map(i => <Skeleton key={i} className=\"h-32\" />)}\n      </div>\n    );\n  }\n\n  return (\n    <div className=\"space-y-6\">\n      <FadeIn>\n        <div className=\"flex items-center justify-between\">\n          <div>\n            <h1 className=\"font-bold text-2xl\">战略对齐视图</h1>\n            <p className=\"text-muted-foreground text-sm\">OKR层级结构：战略(O) → 计划(K) → 任务(T)</p>\n          </div>\n          <div className=\"flex items-center gap-2 text-sm\">\n            <Badge className=\"bg-purple-600 text-white\">O = 战略目标</Badge>\n            <Badge className=\"bg-blue-100 text-blue-700\">K = 关键结果</Badge>\n            <Badge variant=\"outline\">T = 任务</Badge>\n          </div>\n        </div>\n      </FadeIn>\n\n      {/* 统计卡片 */}\n      <FadeIn>\n        <div className=\"grid grid-cols-4 gap-4\">\n          <Card>\n            <CardContent className=\"pt-4\">\n              <div className=\"text-2xl font-bold text-purple-600\">{strategies.length}</div>\n              <div className=\"text-sm text-muted-foreground\">战略目标 (O)</div>\n            </CardContent>\n          </Card>\n          <Card>\n            <CardContent className=\"pt-4\">\n              <div className=\"text-2xl font-bold text-blue-600\">\n                {strategies.reduce((sum, s) => sum + (s.plans?.length || 0), 0)}\n              </div>\n              <div className=\"text-sm text-muted-foreground\">工作计划 (K)</div>\n            </CardContent>\n          </Card>\n          <Card>\n            <CardContent className=\"pt-4\">\n              <div className=\"text-2xl font-bold text-cyan-600\">\n                {strategies.reduce((sum, s) => sum + (s.plans?.reduce((s2, p) => s2 + (p.tasks?.length || 0), 0) || 0), 0)}\n              </div>\n              <div className=\"text-sm text-muted-foreground\">任务总数 (T)</div>\n            </CardContent>\n          </Card>\n          <Card>\n            <CardContent className=\"pt-4\">\n              <div className=\"text-2xl font-bold text-green-600\">\n                {Math.round(strategies.reduce((sum, s) => sum + (s.progress || 0), 0) / Math.max(strategies.length, 1))}%\n              </div>\n              <div className=\"text-sm text-muted-foreground\">平均进度</div>\n            </CardContent>\n          </Card>\n        </div>\n      </FadeIn>\n\n      {/* 层级视图 */}\n      <FadeIn>\n        <Card>\n          <CardHeader className=\"pb-2\">\n            <CardTitle className=\"text-base\">OKR 层级结构</CardTitle>\n          </CardHeader>\n          <CardContent>\n            {strategies.length === 0 ? (\n              <div className=\"text-center py-12 text-muted-foreground\">\n                暂无数据\n              </div>\n            ) : (\n              <div>\n                {strategies.map((s, i) => renderStrategy(s, i))}\n              </div>\n            )}\n          </CardContent>\n        </Card>\n      </FadeIn>\n\n      {/* 详情弹窗 */}\n      <Dialog open={!!detailItem} onOpenChange={() => setDetailItem(null)}>\n        <DialogContent>\n          <DialogHeader>\n            <DialogTitle>\n              {detailItem?.type === 'plan' ? '计划详情' : '任务详情'}\n            </DialogTitle>\n          </DialogHeader>\n          {detailItem && (\n            <div className=\"space-y-3 text-sm\">\n              <div><span className=\"text-muted-foreground\">编号：</span>{getCode(detailItem.data.title) || detailItem.data.taskNumber}</div>\n              <div><span className=\"text-muted-foreground\">名称：</span>{detailItem.data.title}</div>\n              <div><span className=\"text-muted-foreground\">状态：</span>\n                <Badge className={getStatusColor(detailItem.data.status)}>{detailItem.data.status}</Badge>\n              </div>\n              <div><span className=\"text-muted-foreground\">进度：</span>{detailItem.data.progress}%</div>\n              {detailItem.data.assignee && <div><span className=\"text-muted-foreground\">执行人：</span>{detailItem.data.assignee.name}</div>}\n              {detailItem.data.department && <div><span className=\"text-muted-foreground\">部门：</span>{detailItem.data.department.name}</div>}\n              {detailItem.data.dueDate && <div><span className=\"text-muted-foreground\">截止日期：</span>{detailItem.data.dueDate?.split('T')[0]}</div>}\n            </div>\n          )}\n        </DialogContent>\n      </Dialog>\n    </div>\n  );\n}\n","file_path":"/workspace/frontend/src/pages/AlignmentView.tsx"},"tool_response":"Successfully created and wrote to new file: /workspace/frontend/src/pages/AlignmentView.tsx","client":"CLI","version":"2.71.1","generation_id":"025d7289a8b641c5891f466e64998234","model":"glm-5.0","call_id":"019d80be74e38e9c33cf3969e89c6d6a"}
