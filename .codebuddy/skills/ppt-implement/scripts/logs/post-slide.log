[2026-04-03 17:40:21] [DEBUG] [PPT PostToolUse Hook] stdin 数据: {"session_id":"2040121509614309376","transcript_path":"/root/.codebuddy/projects/workspace/2040121509614309376.jsonl","cwd":"/workspace","hook_event_name":"PostToolUse","tool_name":"Write","tool_input":{"content":"// Prisma Schema for CEO Management System\n// PostgreSQL database with TypeScript ORM\n\ngenerator client {\n  provider = \"prisma-client-js\"\n}\n\ndatasource db {\n  provider = \"postgresql\"\n  url      = env(\"DATABASE_URL\")\n}\n\n// 用户表\nmodel User {\n  id          String   @id @default(cuid())\n  username    String   @unique\n  password    String\n  name        String\n  role        String   @default(\"employee\") // ceo, executive, manager, employee\n  departmentId String?\n  position    String?\n  avatar      String?\n  email       String?  @unique\n  phone       String?\n  isActive    Boolean  @default(true)\n  lastLoginAt DateTime?\n  createdAt   DateTime @default(now())\n  updatedAt   DateTime @updatedAt\n\n  department Department?  @relation(fields: [departmentId], references: [id])\n  plans      Plan[]       @relation(\"PlanOwner\")\n  tasks      Task[]       @relation(\"TaskAssignee\")\n  assessments      Assessment[] @relation(\"AssessmentUser\")\n  assessedBy       Assessment[] @relation(\"AssessmentAssessor\")\n  createdStrategies Strategy[]  @relation(\"StrategyCreator\")\n}\n\n// 部门表\nmodel Department {\n  id          String   @id @default(cuid())\n  name        String\n  parentId    String?\n  managerId   String?\n  description String?\n  memberCount Int      @default(0)\n  createdAt   DateTime @default(now())\n  updatedAt   DateTime @updatedAt\n\n  parent   Department?  @relation(\"DepartmentTree\", fields: [parentId], references: [id])\n  children Department[] @relation(\"DepartmentTree\")\n  members  User[]\n  plans    Plan[]\n}\n\n// 战略目标表\nmodel Strategy {\n  id          String   @id @default(cuid())\n  title       String\n  description String?\n  year        Int\n  status      String   @default(\"draft\") // draft, active, completed, archived\n  progress    Int      @default(0)\n  startDate   DateTime\n  endDate     DateTime\n  createdById String\n  createdAt   DateTime @default(now())\n  updatedAt   DateTime @updatedAt\n\n  createdBy User?  @relation(\"StrategyCreator\", fields: [createdById], references: [id])\n  plans     Plan[]\n}\n\n// 工作计划表\nmodel Plan {\n  id           String   @id @default(cuid())\n  title        String\n  description  String?\n  type         String   @default(\"department\") // company, department, personal\n  strategyId   String?\n  departmentId String?\n  ownerId      String\n  status       String   @default(\"pending\") // pending, in_progress, completed, cancelled\n  progress     Int      @default(0)\n  priority     String   @default(\"medium\") // high, medium, low\n  startDate    DateTime\n  endDate      DateTime\n  createdAt    DateTime @default(now())\n  updatedAt    DateTime @updatedAt\n\n  strategy   Strategy?    @relation(fields: [strategyId], references: [id])\n  department Department?  @relation(fields: [departmentId], references: [id])\n  owner      User         @relation(\"PlanOwner\", fields: [ownerId], references: [id])\n  tasks      Task[]\n  assessments Assessment[]\n}\n\n// 任务表\nmodel Task {\n  id          String   @id @default(cuid())\n  planId      String\n  title       String\n  description String?\n  assigneeId  String?\n  status      String   @default(\"pending\") // pending, in_progress, completed, cancelled\n  progress    Int      @default(0)\n  priority    String   @default(\"medium\")\n  dueDate     DateTime\n  createdAt   DateTime @default(now())\n  updatedAt   DateTime @updatedAt\n\n  plan     Plan    @relation(fields: [planId], references: [id])\n  assignee User?   @relation(\"TaskAssignee\", fields: [assigneeId], references: [id])\n}\n\n// 考核记录表\nmodel Assessment {\n  id         String   @id @default(cuid())\n  planId     String?\n  userId     String\n  assessorId String\n  score      Int\n  comment    String?\n  type       String   @default(\"monthly\") // monthly, quarterly, annual\n  period     String\n  createdAt  DateTime @default(now())\n  updatedAt  DateTime @updatedAt\n\n  plan     Plan?  @relation(fields: [planId], references: [id])\n  user     User   @relation(\"AssessmentUser\", fields: [userId], references: [id])\n  assessor User   @relation(\"AssessmentAssessor\", fields: [assessorId], references: [id])\n}\n","file_path":"/workspace/backend/prisma/schema.prisma"},"tool_response":"Successfully overwrote file: /workspace/backend/prisma/schema.prisma","client":"CLI","version":"2.71.1","generation_id":"a720bb6a32444f819ac9d5e79afb78fe","model":"glm-5.0","call_id":"019d546e3c19e1ba73c5699068fcafa9"}
