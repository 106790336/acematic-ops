st response = await apiClient.get<ApiResponse<PaginatedResponse<Assessment>>>('/assessments?limit=50');\n      if (response.data.success && response.data.data) {\n        setAssessments(response.data.data.items);\n      }\n    } catch (err) {\n      setError(getErrorMessage(err));\n    } finally {\n      setLoading(false);\n    }\n  };\n\n  const fetchUsers = async () => {\n    try {\n      const response = await apiClient.get<ApiResponse<{ items: User[] }>>('/users?limit=100');\n      if (response.data.success) {\n        setUsers(response.data.data.items || []);\n      }\n    } catch (err) {\n      console.error('Failed to fetch users:', err);\n    }\n  };\n\n  useEffect(() => {\n    fetchAssessments();\n    fetchUsers();\n  }, []);\n\n  const handleSubmit = async (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!formData.userId) {\n      alert('请选择考核对象');\n      return;\n    }\n    if (!formData.period) {\n      alert('请输入考核周期');\n      return;\n    }\n\n    try {\n      setSubmitting(true);\n      const response = await apiClient.post<ApiResponse<Assessment>>('/assessments', {\n        userId: formData.userId,\n        assessorId: 'user-ceo', // CEO作为考核人\n        type: formData.type,\n        period: formData.period,\n        score: formData.score,\n        comment: formData.comment,\n      });\n\n      if (response.data.success) {\n        setDialogOpen(false);\n        resetForm();\n        fetchAssessments();\n      } else {\n        alert(response.data.error || '创建失败');\n      }\n    } catch (err: any) {\n      alert(getErrorMessage(err));\n    } finally {\n      setSubmitting(false);\n    }\n  };\n\n  const resetForm = () => {\n    setFormData({\n      userId: '',\n      type: 'monthly',\n      period: '',\n      score: 80,\n      comment: '',\n    });\n  };\n\n  const typeLabels: Record<string, string> = {\n    monthly: '月度考核',\n    quarterly: '季度考核',\n    annual: '年度考核',\n  };\n\n  const getScoreColor = (score: number) => {\n    if (score >= 90) return 'text-green-600';\n    if (score >= 80) return 'text-blue-600';\n    if (score >= 70) return 'text-yellow-600';\n    return 'text-red-600';\n  };\n\n  const getScoreBadge = (score: number) => {\n    if (score >= 90) return { label: '优秀', className: 'bg-green-100 text-green-700' };\n    if (score >= 80) return { label: '良好', className: 'bg-blue-100 text-blue-700' };\n    if (score >= 70) return { label: '合格', className: 'bg-yellow-100 text-yellow-700' };\n    return { label: '待改进', className: 'bg-red-100 text-red-700' };\n  };\n\n  // 准备图表数据\n  const chartData = assessments.slice(0, 10).map(a => ({\n    name: a.user?.name || '未知',\n    score: a.score,\n  }));\n\n  if (error) {\n    return (\n      <div className=\"flex items-center justify-center h-64\">\n        <div className=\"text-center\">\n          <AlertCircle className=\"w-12 h-12 mx-auto text-destructive mb-4\" />\n          <p className=\"text-destructive\">{error}</p>\n        </div>\n      </div>\n    );\n  }\n\n  return (\n    <div className=\"space-y-6\">\n      <FadeIn>\n        <div className=\"flex items-center justify-between\">\n          <div>\n            <h1 className=\"font-bold\" style={{ fontSize: 'var(--font-size-headline)' }}>\n              考核管理\n            </h1>\n            <p className=\"text-muted-foreground\" style={{ fontSize: 'var(--font-size-label)' }}>\n              查看和管理员工绩效考核记录\n            </p>\n          </div>\n          <Button onClick={() => { resetForm(); setDialogOpen(true); }}>\n            <Plus className=\"w-4 h-4 mr-2\" />\n            新建考核\n          </Button>\n        </div>\n      </FadeIn>\n\n      <div className=\"grid gap-6 lg:grid-cols-3\">\n        {/* 统计卡片 */}\n        <Stagger className=\"lg:col-span-3 grid gap-4 md:grid-cols-3\">\n          <Card>\n            <CardContent className=\"p-6\">\n              <div className=\"flex items-center justify-between\">\n                <div>\n                  <p className=\"text-sm text-muted-foreground\">考核记录</p>\n                  <p className=\"text-2xl font-bold mt-1\">{assessments.length}</p>\n                </div>\n                <div className=\"p-3 rounded-lg\" style={{ background: 'oklch(0.94 0.01 250)' }}>\n                  <Trophy className=\"w-6 h-6\" style={{ color: 'oklch(0.42 0.19 250)' }} />\n                </div>\n              </div>\n            </CardContent>\n          </Card>\n\n          <Card>\n            <CardContent className=\"p-6\">\n              <div className=\"flex items-center justify-between\">\n                <div>\n                  <p className=\"text-sm text-muted-foreground\">平均得分</p>\n                  <p className=\"text-2xl font-bold mt-1\">\n                    {assessments.length > 0\n                      ? Math.round(assessments.reduce((sum, a) => sum + a.score, 0) / assessments.length)\n                      : 0}\n                  </p>\n                </div>\n                <div className=\"p-3 rounded-lg\" style={{ background: 'oklch(0.95 0.04 75)' }}>\n                  <Star className=\"w-6 h-6\" style={{ color: 'oklch(0.75 0.18 75)' }} />\n                </div>\n              </div>\n            </CardContent>\n          </Card>\n\n          <Card>\n            <CardContent className=\"p-6\">\n              <div className=\"flex items-center justify-between\">\n                <div>\n                  <p className=\"text-sm text-muted-foreground\">优秀率</p>\n                  <p className=\"text-2xl font-bold mt-1\">\n                    {assessments.length > 0\n                      ? Math.round((assessments.filter(a => a.score >= 90).length / assessments.length) * 100)\n                      : 0}%\n                  </p>\n                </div>\n                <div className=\"p-3 rounded-lg\" style={{ background: 'oklch(0.95 0.02 163)' }}>\n                  <TrendingUp className=\"w-6 h-6\" style={{ color: 'oklch(0.60 0.15 163)' }} />\n                </div>\n              </div>\n            </CardContent>\n          </Card>\n        </Stagger>\n\n        {/* 考核得分图表 */}\n        <FadeIn className=\"lg:col-span-2\">\n          <Card>\n            <CardHeader>\n              <CardTitle className=\"flex items-center gap-2\">\n                <TrendingUp className=\"w-5 h-5\" style={{ color: 'oklch(0.58 0.20 250)' }} />\n                近期考核得分\n              </CardTitle>\n            </CardHeader>\n            <CardContent>\n              <div className=\"h-64\">\n                <ResponsiveContainer width=\"100%\" height=\"100%\">\n                  <BarChart data={chartData}>\n                    <CartesianGrid strokeDasharray=\"3 3\" stroke=\"oklch(0.90 0 0)\" />\n                    <XAxis dataKey=\"name\" tick={{ fontSize: 12 }} />\n                    <YAxis domain={[0, 100]} tick={{ fontSize: 12 }} />\n                    <Tooltip \n                      contentStyle={{ \n                        background: 'white',\n                        border: '1px solid oklch(0.90 0 0)',\n                        borderRadius: '8px',\n                      }}\n                    />\n                    <Bar dataKey=\"score\" fill=\"oklch(0.42 0.19 250)\" radius={[4, 4, 0, 0]} />\n                  </BarChart>\n                </ResponsiveContainer>\n              </div>\n            </CardContent>\n          </Card>\n        </FadeIn>\n\n        {/* 考核列表 */}\n        <FadeIn>\n          <Card>\n            <CardHeader>\n              <CardTitle>考核记录</CardTitle>\n            </CardHeader>\n            <CardContent>\n              {loading ? (\n                <div className=\"space-y-4\">\n                  {[1, 2, 3].map((i) => (\n                    <Skeleton key={i} className=\"h-16\" />\n                  ))}\n                </div>\n              ) : (\n                <div className=\"space-y-4 max-h-80 overflow-y-auto\">\n                  {assessments.map((assessment) => {\n                    const badge = getScoreBadge(assessment.score);\n                    return (\n                      <div\n                        key={assessment.id}\n                        className=\"flex items-center justify-between p-3 rounded-lg\"\n                        style={{ background: 'var(--muted)' }}\n                      >\n                        <div className=\"flex items-center gap-3\">\n                          <div\n                            className=\"w-10 h-10 rounded-full flex items-center justify-center text-white font-medium\"\n                            style={{ background: 'oklch(0.42 0.19 250)' }}\n                          >\n                            {assessment.user?.name?.[0] || 'U'}\n                          </div>\n                          <div>\n                            <div className=\"font-medium\">{assessment.user?.name}</div>\n                            <div className=\"text-xs text-muted-foreground\">\n                              {assessment.user?.department?.name} · {typeLabels[assessment.type]}\n                            </div>\n                          </div>\n                        </div>\n                        <div className=\"text-right\">\n                          <div className={`text-lg font-bold ${getScoreColor(assessment.score)}`}>\n                            {assessment.score}\n                          </div>\n                          <Badge className={badge.className}>\n                            {badge.label}\n                          </Badge>\n                        </div>\n                      </div>\n                    );\n                  })}\n                  {assessments.length === 0 && (\n                    <div className=\"text-center py-8 text-muted-foreground\">\n                      暂无考核记录\n                    </div>\n                  )}\n                </div>\n              )}\n            </CardContent>\n          </Card>\n        </FadeIn>\n      </div>\n\n      {/* 新建考核对话框 */}\n      <Dialog open={dialogOpen} onOpenChange={setDialogOpen}>\n        <DialogContent>\n          <DialogHeader>\n            <DialogTitle>新建考核</DialogTitle>\n          </DialogHeader>\n          <form onSubmit={handleSubmit} className=\"space-y-4\">\n            <div className=\"grid grid-cols-2 gap-4\">\n              <div className=\"space-y-2\">\n                <Label>考核对象 *</Label>\n                <Select value={formData.userId} onValueChange={(v) => setFormData({ ...formData, userId: v })}>\n                  <SelectTrigger>\n                    <SelectValue placeholder=\"选择员工\" />\n                  </SelectTrigger>\n                  <SelectContent>\n                    {users.map((u) => (\n                      <SelectItem key={u.id} value={u.id}>{u.name}</SelectItem>\n                    ))}\n                  </SelectContent>\n                </Select>\n              </div>\n              <div className=\"space-y-2\">\n                <Label>考核类型</Label>\n                <Select value={formData.type} onValueChange={(v) => setFormData({ ...formData, type: v as any })}>\n                  <SelectTrigger>\n                    <SelectValue />\n                  </SelectTrigger>\n                  <SelectContent>\n                    <SelectItem value=\"monthly\">月度考核</SelectItem>\n                    <SelectItem value=\"quarterly\">季度考核</SelectItem>\n                    <SelectItem value=\"annual\">年度考核</SelectItem>\n                  </SelectContent>\n                </Select>\n              </div>\n            </div>\n            <div className=\"grid grid-cols-2 gap-4\">\n              <div className=\"space-y-2\">\n                <Label>考核周期 *</Label>\n                <Input\n                  placeholder=\"如: 2026年4月\"\n                  value={formData.period}\n                  onChange={(e) => setFormData({ ...formData, period: e.target.value })}\n                  required\n                />\n              </div>\n              <div className=\"space-y-2\">\n                <Label>考核分数 (0-100)</Label>\n                <Input\n                  type=\"number\"\n                  min=\"0\"\n                  max=\"100\"\n                  value={formData.score}\n                  onChange={(e) => setFormData({ ...formData, score: parseInt(e.target.value) || 0 })}\n                />\n              </div>\n            </div>\n            <div className=\"space-y-2\">\n              <Label>考核评语</Label>\n              <Textarea\n                placeholder=\"输入考核评语\"\n                value={formData.comment}\n                onChange={(e) => setFormData({ ...formData, comment: e.target.value })}\n                rows={3}\n              />\n            </div>\n            <DialogFooter>\n              <Button type=\"button\" variant=\"outline\" onClick={() => setDialogOpen(false)}>取消</Button>\n              <Button type=\"submit\" disabled={submitting}>{submitting ? '提交中...' : '创建'}</Button>\n            </DialogFooter>\n          </form>\n        </DialogContent>\n      </Dialog>\n    </div>\n  );\n}\n","file_path":"/workspace/frontend/src/pages/AssessmentList.tsx"},"tool_response":"Successfully overwrote file: /workspace/frontend/src/pages/AssessmentList.tsx","client":"CLI","version":"2.71.1","generation_id":"d4004153357645eaa1a879a56dc453e9","model":"minimax-m2.5","call_id":"call_function_adt473r0xqk3_1"}
