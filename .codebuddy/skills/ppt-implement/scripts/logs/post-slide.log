[2026-04-10 03:30:53] [DEBUG] [PPT PostToolUse Hook] stdin 数据: {"session_id":"2040121509614309376","transcript_path":"/root/.codebuddy/projects/workspace/2040121509614309376.jsonl","cwd":"/workspace","hook_event_name":"PostToolUse","tool_name":"Write","tool_input":{"content":"import { useState, useEffect } from 'react';\nimport { api } from '@/lib/api';\nimport { Button } from '@/components/ui/button';\nimport { Input } from '@/components/ui/input';\nimport { Card, CardContent } from '@/components/ui/card';\nimport {\n  Table, TableBody, TableCell, TableHead, TableHeader, TableRow,\n} from '@/components/ui/table';\nimport {\n  Dialog, DialogContent, DialogHeader, DialogTitle, DialogFooter,\n} from '@/components/ui/dialog';\nimport {\n  Select, SelectContent, SelectItem, SelectTrigger, SelectValue,\n} from '@/components/ui/select';\nimport { Tabs, TabsContent, TabsList, TabsTrigger } from '@/components/ui/tabs';\nimport { Textarea } from '@/components/ui/textarea';\nimport { Label } from '@/components/ui/label';\nimport { Badge } from '@/components/ui/badge';\nimport { Skeleton } from '@/components/ui/skeleton';\nimport { \n  Plus, Search, CheckCircle, Clock, AlertTriangle, Target, Play,\n  User, Link, ChevronRight, Edit, Trash2, FileCheck\n} from 'lucide-react';\n\ninterface Task {\n  id: string;\n  taskNumber: string;\n  title: string;\n  description?: string;\n  sourceType: 'assigned' | 'self_initiated' | 'plan_decomposition';\n  sourceRef?: string;\n  assignee?: { id: string; name: string; position?: string };\n  assigner?: { id: string; name: string };\n  assignerId?: string;\n  dueDate: string;\n  priority: 'low' | 'medium' | 'high' | 'urgent';\n  status: 'pending' | 'confirmed' | 'in_progress' | 'completed' | 'verified' | 'rejected';\n  progress: number;\n  strategicAlignment: boolean;\n  alignmentTarget?: string;\n  planId?: string;\n  plan?: { id: string; title: string; strategyId?: string; strategy?: { id: string; title: string } };\n  createdAt: string;\n}\n\ninterface Plan {\n  id: string;\n  title: string;\n  strategy?: { id: string; title: string };\n}\n\n// 当前登录用户信息（简单存储）\nconst AUTH_KEY = 'auth_user';\n\nfunction getCurrentUser(): { id: string; role: string } | null {\n  try {\n    const raw = localStorage.getItem(AUTH_KEY);\n    if (!raw) return null;\n    const parsed = JSON.parse(raw);\n    return { id: parsed.id, role: parsed.role };\n  } catch { return null; }\n}\n\nexport default function TaskManagement() {\n  const [tasks, setTasks] = useState<Task[]>([]);\n  const [loading, setLoading] = useState(true);\n  const [error, setError] = useState<string | null>(null);\n  const [activeTab, setActiveTab] = useState('all');\n  const [search, setSearch] = useState('');\n  const [sourceTypeFilter, setSourceTypeFilter] = useState('all');\n  const [statusFilter, setStatusFilter] = useState('all');\n  const [users, setUsers] = useState<{ id: string; name: string }[]>([]);\n  const [plans, setPlans] = useState<Plan[]>([]);\n  const [submitting, setSubmitting] = useState(false);\n\n  // 对话框状态\n  const [showDialog, setShowDialog] = useState(false);\n  const [dialogMode, setDialogMode] = useState<'create' | 'edit' | 'result'>('create');\n  const [editingTask, setEditingTask] = useState<Task | null>(null);\n\n  const [formData, setFormData] = useState({\n    title: '',\n    description: '',\n    sourceType: 'assigned' as 'assigned' | 'self_initiated' | 'plan_decomposition',\n    assigneeId: '',\n    planId: '',\n    dueDate: '',\n    priority: 'medium' as 'low' | 'medium' | 'high' | 'urgent',\n    strategicAlignment: false,\n    alignmentTarget: '',\n  });\n\n  // 成果编辑表单\n  const [resultData, setResultData] = useState({\n    progress: 0,\n    result: '',\n  });\n\n  const currentUser = getCurrentUser();\n\n  const loadTasks = async () => {\n    try {\n      setLoading(true);\n      setError(null);\n      const params = new URLSearchParams();\n      if (sourceTypeFilter !== 'all') params.append('sourceType', sourceTypeFilter);\n      if (statusFilter !== 'all') params.append('status', statusFilter);\n      const endpoint = activeTab === 'my' ? '/tasks-v2/my' : '/tasks-v2';\n      const response = await api.get(endpoint, { params });\n      if (response.data.success) {\n        let items = response.data.data.items || response.data.data || [];\n        if (search) {\n          items = items.filter((t: Task) => t.title.toLowerCase().includes(search.toLowerCase()));\n        }\n        setTasks(items);\n      } else {\n        setError(response.data.error || '加载失败');\n      }\n    } catch (err: any) {\n      setError(err.response?.data?.error || err.message || '加载任务失败');\n    } finally {\n      setLoading(false);\n    }\n  };\n\n  const loadUsers = async () => {\n    try {\n      const response = await api.get('/users');\n      if (response.data.success) setUsers(response.data.data.items || []);\n    } catch (err) { console.error(err); }\n  };\n\n  const loadPlans = async () => {\n    try {\n      const response = await api.get('/plans?limit=100');\n      if (response.data.success) setPlans(response.data.data.items || []);\n    } catch (err) { console.error(err); }\n  };\n\n  useEffect(() => { loadTasks(); loadUsers(); loadPlans(); }, [activeTab, sourceTypeFilter, statusFilter]);\n\n  // ---- 新建/编辑 ----\n  const openCreateDialog = () => {\n    setDialogMode('create');\n    setEditingTask(null);\n    resetFormData();\n    setShowDialog(true);\n  };\n\n  const openEditDialog = (task: Task) => {\n    setDialogMode('edit');\n    setEditingTask(task);\n    setFormData({\n      title: task.title,\n      description: task.description || '',\n      sourceType: task.sourceType,\n      assigneeId: task.assignee?.id || '',\n      planId: task.planId || '',\n      dueDate: task.dueDate.split('T')[0],\n      priority: task.priority,\n      strategicAlignment: task.strategicAlignment,\n      alignmentTarget: task.alignmentTarget || '',\n    });\n    setShowDialog(true);\n  };\n\n  const openResultDialog = (task: Task) => {\n    setDialogMode('result');\n    setEditingTask(task);\n    setResultData({ progress: task.progress, result: '' });\n    setShowDialog(true);\n  };\n\n  const resetFormData = () => {\n    setFormData({\n      title: '', description: '', sourceType: 'assigned', assigneeId: '',\n      planId: '', dueDate: '', priority: 'medium', strategicAlignment: false, alignmentTarget: '',\n    });\n  };\n\n  const handleSave = async () => {\n    if (dialogMode === 'create' || dialogMode === 'edit') {\n      if (!formData.title.trim()) { alert('请输入任务标题'); return; }\n      if (!formData.dueDate) { alert('请选择截止日期'); return; }\n    }\n\n    try {\n      setSubmitting(true);\n      if (dialogMode === 'create') {\n        const res = await api.post('/tasks-v2', {\n          title: formData.title, description: formData.description,\n          sourceType: formData.planId ? 'plan_decomposition' : formData.sourceType,\n          assigneeId: formData.assigneeId || undefined,\n          planId: formData.planId || undefined, dueDate: formData.dueDate,\n          priority: formData.priority, strategicAlignment: formData.strategicAlignment,\n          alignmentTarget: formData.strategicAlignment ? formData.alignmentTarget : undefined,\n        });\n        if (!res.data.success) { alert(res.data.error || '创建失败'); return; }\n      } else if (dialogMode === 'edit') {\n        const res = await api.put(`/tasks-v2/${editingTask!.id}`, {\n          title: formData.title, description: formData.description,\n          assigneeId: formData.assigneeId || null,\n          planId: formData.planId || null, dueDate: formData.dueDate,\n          priority: formData.priority, strategicAlignment: formData.strategicAlignment,\n          alignmentTarget: formData.strategicAlignment ? formData.alignmentTarget : null,\n        });\n        if (!res.data.success) { alert(res.data.error || '保存失败'); return; }\n      } else if (dialogMode === 'result') {\n        const res = await api.put(`/tasks-v2/${editingTask!.id}/progress`, {\n          progress: resultData.progress, result: resultData.result,\n        });\n        if (!res.data.success) { alert(res.data.error || '更新失败'); return; }\n      }\n      setShowDialog(false);\n      loadTasks();\n    } catch (err: any) {\n      alert(err.response?.data?.error || '操作失败');\n    } finally {\n      setSubmitting(false);\n    }\n  };\n\n  const handleDelete = async (task: Task) => {\n    if (!confirm(`确定要删除任务\"${task.title}\"吗？`)) return;\n    try {\n      const res = await api.delete(`/tasks-v2/${task.id}`);\n      if (res.data.success) loadTasks();\n      else alert(res.data.error || '删除失败');\n    } catch (err: any) {\n      alert(err.response?.data?.error || '删除失败');\n    }\n  };\n\n  // ---- 状态操作 ----\n  const handleConfirm = async (id: string) => {\n    try { await api.post(`/tasks-v2/${id}/confirm`); loadTasks(); } catch (e: any) { alert(e.response?.data?.error || '失败'); }\n  };\n  const handleStart = async (id: string) => {\n    try { await api.post(`/tasks-v2/${id}/start`); loadTasks(); } catch (e: any) { alert(e.response?.data?.error || '失败'); }\n  };\n  const handleApprove = async (id: string, approved: boolean) => {\n    try { await api.post(`/tasks-v2/${id}/approve`, { approved }); loadTasks(); } catch (e: any) { alert(e.response?.data?.error || '失败'); }\n  };\n\n  // ---- 权限判断 ----\n  const canEdit = (task: Task) => {\n    return currentUser && (task.assignerId === currentUser.id || currentUser.role === 'ceo');\n  };\n  const canDelete = (task: Task) => {\n    return currentUser && (task.assignerId === currentUser.id || currentUser.role === 'ceo');\n  };\n  const canEditResult = (task: Task) => {\n    return currentUser && task.assignee?.id === currentUser.id && ['confirmed', 'in_progress'].includes(task.status);\n  };\n\n  const formatDate = (dateStr: string) => {\n    try { return new Date(dateStr).toLocaleDateString('zh-CN'); } catch { return dateStr; }\n  };\n  const selectedPlan = plans.find(p => p.id === formData.planId);\n\n  const sourceTypeLabels: Record<string, string> = { assigned: '上级分配', self_initiated: '主动提交', plan_decomposition: '计划分解' };\n  const priorityConfig: Record<string, { label: string; className: string }> = {\n    low: { label: '低', className: 'bg-gray-100 text-gray-700' },\n    medium: { label: '中', className: 'bg-blue-100 text-blue-700' },\n    high: { label: '高', className: 'bg-orange-100 text-orange-700' },\n    urgent: { label: '紧急', className: 'bg-red-100 text-red-700' },\n  };\n  const statusConfig: Record<string, { label: string; className: string }> = {\n    pending: { label: '待确认', className: 'bg-yellow-100 text-yellow-700' },\n    confirmed: { label: '已确认', className: 'bg-blue-100 text-blue-700' },\n    in_progress: { label: '进行中', className: 'bg-cyan-100 text-cyan-700' },\n    completed: { label: '已完成', className: 'bg-green-100 text-green-700' },\n    verified: { label: '已验收', className: 'bg-emerald-100 text-emerald-700' },\n    rejected: { label: '已驳回', className: 'bg-red-100 text-red-700' },\n  };\n\n  const dialogTitle = dialogMode === 'create' ? '新建任务' : dialogMode === 'edit' ? '编辑任务' : '填写执行成果';\n\n  return (\n    <div className=\"space-y-6\">\n      <div className=\"flex items-center justify-between\">\n        <div>\n          <h1 className=\"text-2xl font-semibold\">任务管理</h1>\n          <p className=\"text-sm text-muted-foreground mt-1\">任务来源追溯 · 战略对齐管理</p>\n        </div>\n        <Button onClick={openCreateDialog}>\n          <Plus className=\"w-4 h-4 mr-2\" />\n          新建任务\n        </Button>\n      </div>\n\n      <Card>\n        <CardContent className=\"pt-4\">\n          <div className=\"flex flex-wrap gap-4\">\n            <div className=\"flex-1 min-w-[200px]\">\n              <div className=\"relative\">\n                <Search className=\"absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-muted-foreground\" />\n                <Input placeholder=\"搜索任务...\" value={search} onChange={(e) => setSearch(e.target.value)} onBlur={loadTasks} className=\"pl-10\" />\n              </div>\n            </div>\n            <Select value={sourceTypeFilter} onValueChange={setSourceTypeFilter}>\n              <SelectTrigger className=\"w-[140px]\"><SelectValue placeholder=\"来源类型\" /></SelectTrigger>\n              <SelectContent>\n                <SelectItem value=\"all\">全部来源</SelectItem>\n                <SelectItem value=\"assigned\">上级分配</SelectItem>\n                <SelectItem value=\"self_initiated\">主动提交</SelectItem>\n                <SelectItem value=\"plan_decomposition\">计划分解</SelectItem>\n              </SelectContent>\n            </Select>\n            <Select value={statusFilter} onValueChange={setStatusFilter}>\n              <SelectTrigger className=\"w-[140px]\"><SelectValue placeholder=\"状态\" /></SelectTrigger>\n              <SelectContent>\n                <SelectItem value=\"all\">全部状态</SelectItem>\n                <SelectItem value=\"pending\">待确认</SelectItem>\n                <SelectItem value=\"confirmed\">已确认</SelectItem>\n                <SelectItem value=\"in_progress\">进行中</SelectItem>\n                <SelectItem value=\"completed\">已完成</SelectItem>\n                <SelectItem value=\"verified\">已验收</SelectItem>\n              </SelectContent>\n            </Select>\n          </div>\n        </CardContent>\n      </Card>\n\n      <Tabs value={activeTab} onValueChange={setActiveTab}>\n        <TabsList>\n          <TabsTrigger value=\"all\">全部任务</TabsTrigger>\n          <TabsTrigger value=\"my\">我的任务</TabsTrigger>\n        </TabsList>\n        <TabsContent value={activeTab} className=\"mt-4\">\n          <Card>\n            <CardContent className=\"p-0\">\n              {error && (\n                <div className=\"p-4 text-red-500 bg-red-50 text-center\">\n                  {error}\n                  <Button variant=\"link\" onClick={loadTasks} className=\"ml-2\">重试</Button>\n                </div>\n              )}\n              {loading ? (\n                <div className=\"p-8 space-y-4\">{[1, 2, 3].map((i) => <Skeleton key={i} className=\"h-12\" />)}</div>\n              ) : tasks.length === 0 ? (\n                <div className=\"p-8 text-center text-muted-foreground\">暂无任务数据</div>\n              ) : (\n                <div className=\"overflow-x-auto\">\n                  <Table>\n                    <TableHeader>\n                      <TableRow>\n                        <TableHead>任务编号</TableHead>\n                        <TableHead>任务名称</TableHead>\n                        <TableHead>关联链路</TableHead>\n                        <TableHead>来源</TableHead>\n                        <TableHead>负责人</TableHead>\n                        <TableHead>截止日期</TableHead>\n                        <TableHead>优先级</TableHead>\n                        <TableHead>战略对齐</TableHead>\n                        <TableHead>状态</TableHead>\n                        <TableHead>进度</TableHead>\n                        <TableHead>操作</TableHead>\n                      </TableRow>\n                    </TableHeader>\n                    <TableBody>\n                      {tasks.map((task) => (\n                        <TableRow key={task.id}>\n                          <TableCell className=\"font-mono text-sm\">{task.taskNumber}</TableCell>\n                          <TableCell>\n                            <div>\n                              <div className=\"font-medium\">{task.title}</div>\n                              {task.sourceRef && <div className=\"text-xs text-muted-foreground\">{task.sourceRef}</div>}\n                            </div>\n                          </TableCell>\n                          <TableCell>\n                            {task.plan ? (\n                              <div className=\"flex items-center gap-1 text-xs flex-wrap\">\n                                {task.plan.strategy && (\n                                  <>\n                                    <span className=\"text-purple-600 font-medium fl