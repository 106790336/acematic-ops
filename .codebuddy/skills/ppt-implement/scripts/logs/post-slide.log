tring\n  planCompleteDate DateTime\n  progress        Int      @default(0)\n  effectVerify    String?\n  isEffective     String   @default(\"待验证\") // 有效/部分有效/无效/待验证\n  createdAt       DateTime @default(now())\n  updatedAt       DateTime @updatedAt\n\n  issue       Issue? @relation(fields: [issueId], references: [id])\n  responsible User   @relation(\"MeasureResponsible\", fields: [responsibleId], references: [id])\n}\n\n// ===== 执行管理体系 =====\n\n// 年度经营目标\nmodel AnnualGoal {\n  id             String   @id @default(cuid())\n  year           Int\n  title          String\n  description    String?\n  strategyId     String?\n  departmentId   String?\n  ownerId        String?\n  targetValue    Float    @default(0)\n  currentValue   Float    @default(0)\n  unit           String?\n  startDate      DateTime\n  endDate        DateTime\n  status         String   @default(\"进行中\") // 进行中/已完成/已延期/已取消\n  createdAt      DateTime @default(now())\n  updatedAt      DateTime @updatedAt\n\n  department     Department?      @relation(fields: [departmentId], references: [id])\n  owner          User?            @relation(\"AnnualGoalOwner\", fields: [ownerId], references: [id])\n  quarterlyPlans QuarterlyPlan[]\n  monthlyPlans   NewMonthlyPlan[]\n  monthlyPlansOld MonthlyPlan[]\n}\n\n// 季度计划\nmodel QuarterlyPlan {\n  id             String   @id @default(cuid())\n  annualGoalId   String?\n  title          String\n  description    String?\n  quarter        Int      // 1-4\n  year           Int\n  departmentId   String?\n  ownerId        String?\n  targetValue    Float    @default(0)\n  currentValue   Float    @default(0)\n  keyResults     String?  // JSON格式的关键结果\n  startDate      DateTime\n  endDate        DateTime\n  status         String   @default(\"进行中\")\n  createdAt      DateTime @default(now())\n  updatedAt      DateTime @updatedAt\n\n  annualGoal  AnnualGoal?     @relation(fields: [annualGoalId], references: [id])\n  department  Department?     @relation(fields: [departmentId], references: [id])\n  owner       User?           @relation(\"QuarterlyPlanOwner\", fields: [ownerId], references: [id])\n  monthlyPlans NewMonthlyPlan[]\n}\n\n// 月度经营计划（新版）\nmodel NewMonthlyPlan {\n  id                String   @id @default(cuid())\n  annualGoalId      String?\n  quarterlyPlanId   String?\n  title             String\n  description       String?\n  month             Int      // 1-12\n  year              Int\n  departmentId      String?\n  ownerId           String?\n  targetValue       Float    @default(0)\n  currentValue      Float    @default(0)\n  keyResults        String?  // JSON格式的关键结果\n  status            String   @default(\"进行中\")\n  reviewStatus      String   @default(\"待提交\") // 待提交/待审核/已通过/需修改\n  reviewComment     String?\n  reviewedBy        String?\n  reviewedAt        DateTime?\n  createdAt         DateTime @default(now())\n  updatedAt         DateTime @updatedAt\n\n  annualGoal     AnnualGoal?      @relation(fields: [annualGoalId], references: [id])\n  quarterlyPlan  QuarterlyPlan?  @relation(fields: [quarterlyPlanId], references: [id])\n  department     Department?     @relation(fields: [departmentId], references: [id])\n  owner          User?           @relation(\"NewMonthlyPlanOwner\", fields: [ownerId], references: [id])\n  weeklyPlans    NewWeeklyPlan[]\n}\n\n// 周计划（新版）\nmodel NewWeeklyPlan {\n  id                String   @id @default(cuid())\n  monthlyPlanId     String?\n  title             String\n  description       String?\n  weekNumber        Int      // 第几周\n  startDate         DateTime\n  endDate           DateTime\n  departmentId      String?\n  ownerId           String?\n  targetValue       Float    @default(0)\n  currentValue      Float    @default(0)\n  keyTasks          String?  // JSON格式的关键任务\n  status            String   @default(\"进行中\")\n  createdAt         DateTime @default(now())\n  updatedAt         DateTime @updatedAt\n\n  monthlyPlan   NewMonthlyPlan? @relation(fields: [monthlyPlanId], references: [id])\n  department    Department?     @relation(fields: [departmentId], references: [id])\n  owner         User?           @relation(\"NewWeeklyPlanOwner\", fields: [ownerId], references: [id])\n  dailyLogs     DailyLog[]\n}\n\n// 旧版月度经营计划（保持兼容）\nmodel MonthlyPlan {\n  id             String   @id @default(cuid())\n  yearMonth      String   // 2026-04\n  departmentId   String\n  submitterId    String\n  annualGoalId   String?\n  planItems      String   // JSON格式的计划项列表\n  totalBudget    Float?\n  reviewStatus   String   @default(\"待提交\") // 待提交/待审核/已通过/需修改\n  reviewComment  String?\n  reviewedBy     String?\n  reviewedAt     DateTime?\n  submitTime     DateTime @default(now())\n  createdAt      DateTime @default(now())\n  updatedAt      DateTime @updatedAt\n\n  department   Department   @relation(fields: [departmentId], references: [id])\n  submitter    User         @relation(\"PlanSubmitter\", fields: [submitterId], references: [id])\n  annualGoal   AnnualGoal?  @relation(fields: [annualGoalId], references: [id])\n  weeklyPlans  WeeklyPlan[]\n}\n\n// 旧版周计划（保持兼容）\nmodel WeeklyPlan {\n  id             String   @id @default(cuid())\n  weekDate       DateTime // 周一日期\n  monthlyPlanId  String\n  departmentId   String\n  submitterId    String\n  planItems      String   // JSON格式的周计划项\n  completedItems String?  // JSON格式的完成情况\n  progress       Int      @default(0)\n  submitTime     DateTime @default(now())\n  createdAt      DateTime @default(now())\n  updatedAt      DateTime @updatedAt\n\n  monthlyPlan MonthlyPlan @relation(fields: [monthlyPlanId], references: [id])\n  department  Department  @relation(fields: [departmentId], references: [id])\n  submitter   User        @relation(\"WeeklyPlanSubmitter\", fields: [submitterId], references: [id])\n  dailyLogs   DailyLog[]\n}\n\n// 每日日志\nmodel DailyLog {\n  id             String   @id @default(cuid())\n  logDate        DateTime\n  weeklyPlanId   String?\n  newWeeklyPlanId String?\n  userId         String\n  departmentId   String\n  workContent