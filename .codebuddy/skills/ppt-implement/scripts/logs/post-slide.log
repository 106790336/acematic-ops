-y-2\">\n                <Label>责任人</Label>\n                <Select value={formData.responsibleId} onValueChange={(v) => setFormData({ ...formData, responsibleId: v })}>\n                  <SelectTrigger><SelectValue placeholder=\"选择责任人\" /></SelectTrigger>\n                  <SelectContent>\n                    {users.map((user) => (\n                      <SelectItem key={user.id} value={user.id}>{user.name}</SelectItem>\n                    ))}\n                  </SelectContent>\n                </Select>\n              </div>\n              <div className=\"space-y-2\">\n                <Label>计划完成时间</Label>\n                <Input\n                  type=\"date\"\n                  value={formData.planCompleteDate}\n                  onChange={(e) => setFormData({ ...formData, planCompleteDate: e.target.value })}\n                />\n              </div>\n            </div>\n            <DialogFooter>\n              <Button type=\"button\" variant=\"outline\" onClick={() => setDialogOpen(false)}>取消</Button>\n              <Button type=\"submit\" disabled={submitting}>{submitting ? '提交中...' : (editingIssue ? '保存' : '创建')}</Button>\n            </DialogFooter>\n          </form>\n        </DialogContent>\n      </Dialog>\n    </div>\n  );\n}\n","file_path":"/workspace/frontend/src/pages/IssueList.tsx"},"tool_response":"Successfully overwrote file: /workspace/frontend/src/pages/IssueList.tsx","client":"CLI","version":"2.71.1","generation_id":"6b12202c44b046f886bc6f9c42cd9286","model":"glm-5.0-turbo","call_id":"call_1dfb69633fed449ebbe33b28"}
