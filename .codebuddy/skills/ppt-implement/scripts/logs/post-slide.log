[2026-04-11 03:22:06] [DEBUG] [PPT PostToolUse Hook] stdin 数据: {"session_id":"2040121509614309376","transcript_path":"/root/.codebuddy/projects/workspace/2040121509614309376.jsonl","cwd":"/workspace","hook_event_name":"PostToolUse","tool_name":"Write","tool_input":{"content":"import { useState } from 'react';\nimport { Card, CardContent, CardHeader } from '@/components/ui/card';\nimport { Button } from '@/components/ui/button';\nimport { Input } from '@/components/ui/input';\nimport { Badge } from '@/components/ui/badge';\nimport { Progress } from '@/components/ui/progress';\nimport { Skeleton } from '@/components/ui/skeleton';\nimport {\n  Table, TableBody, TableCell, TableHead, TableHeader, TableRow,\n} from '@/components/ui/table';\nimport {\n  Dialog, DialogContent, DialogHeader, DialogTitle, DialogFooter,\n} from '@/components/ui/dialog';\nimport { Label } from '@/components/ui/label';\nimport { Textarea } from '@/components/ui/textarea';\nimport { FadeIn } from '@/components/MotionPrimitives';\nimport { Plus, Edit, Trash2, Target, AlertCircle } from 'lucide-react';\nimport { apiClient, getErrorMessage } from '@/lib/api-client';\nimport type { Strategy, ApiResponse, PaginatedResponse } from '@/types';\n\nexport default function StrategyList() {\n  const [strategies, setStrategies] = useState<Strategy[]>([]);\n  const [loading, setLoading] = useState(true);\n  const [error, setError] = useState<string | null>(null);\n  const [dialogOpen, setDialogOpen] = useState(false);\n  const [editingItem, setEditingItem] = useState<Strategy | null>(null);\n  const [submitting, setSubmitting] = useState(false);\n  const [search, setSearch] = useState('');\n  const [formData, setFormData] = useState({\n    title: '',\n    description: '',\n    year: new Date().getFullYear(),\n    startDate: '',\n    endDate: '',\n  });\n\n  const fetchData = async () => {\n    try {\n      setLoading(true);\n      const params = new URLSearchParams();\n      if (search) params.append('search', search);\n      const response = await apiClient.get<ApiResponse<PaginatedResponse<Strategy>>>(`/strategies?${params.toString()}`);\n      if (response.data.success && response.data.data) {\n        setStrategies(response.data.data.items);\n      }\n    } catch (err: any) {\n      setError(getErrorMessage(err));\n    } finally {\n      setLoading(false);\n    }\n  };\n\n  // 加载数据\n  const loadData = async () => {\n    try {\n      setLoading(true);\n      const response = await apiClient.get<ApiResponse<PaginatedResponse<Strategy>>>('/strategies?limit=100');\n      if (response.data.success && response.data.data) {\n        setStrategies(response.data.data.items);\n      }\n    } catch (err: any) {\n      setError(getErrorMessage(err));\n    } finally {\n      setLoading(false);\n    }\n  };\n\n  loadData();\n\n  const handleSubmit = async (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!formData.title.trim()) {\n      alert('请输入战略名称');\n      return;\n    }\n    if (!formData.startDate || !formData.endDate) {\n      alert('请选择日期');\n      return;\n    }\n    try {\n      setSubmitting(true);\n      if (editingItem) {\n        await apiClient.put(`/strategies/${editingItem.id}`, formData);\n      } else {\n        await apiClient.post('/strategies', formData);\n      }\n      setDialogOpen(false);\n      resetForm();\n      fetchData();\n    } catch (err: any) {\n      alert(getErrorMessage(err));\n    } finally {\n      setSubmitting(false);\n    }\n  };\n\n  const handleEdit = (item: Strategy) => {\n    setEditingItem(item);\n    setFormData({\n      title: item.title,\n      description: item.description || '',\n      year: item.year,\n      startDate: item.startDate.split('T')[0],\n      endDate: item.endDate.split('T')[0],\n    });\n    setDialogOpen(true);\n  };\n\n  const handleDelete = async (id: string) => {\n    if (confirm('确定要删除这个战略目标吗？')) {\n      try {\n        await apiClient.delete(`/strategies/${id}`);\n        fetchData();\n      } catch (err: any) {\n        alert(getErrorMessage(err));\n      }\n    }\n  };\n\n  const resetForm = () => {\n    setEditingItem(null);\n    setFormData({\n      title: '',\n      description: '',\n      year: new Date().getFullYear(),\n      startDate: '',\n      endDate: '',\n    });\n  };\n\n  const handleDialogChange = (open: boolean) => {\n    setDialogOpen(open);\n    if (!open) {\n      resetForm();\n    }\n  };\n\n  const statusLabels: Record<string, string> = {\n    draft: '草稿', active: '进行中', completed: '已完成', archived: '已归档',\n  };\n  const statusBadge: Record<string, string> = {\n    draft: 'bg-gray-100 text-gray-700',\n    active: 'bg-blue-100 text-blue-700',\n    completed: 'bg-green-100 text-green-700',\n    archived: 'bg-gray-100 text-gray-500',\n  };\n\n  return (\n    <div className=\"space-y-6\">\n      <FadeIn>\n        <div className=\"flex items-center justify-between\">\n          <div>\n            <h1 className=\"font-bold text-2xl\">战略管理</h1>\n            <p className=\"text-muted-foreground text-sm mt-1\">管理公司战略目标，追踪落地执行</p>\n          </div>\n          <Button onClick={() => { resetForm(); setDialogOpen(true); }}>\n            <Plus className=\"w-4 h-4 mr-2\" />\n            新建战略\n          </Button>\n        </div>\n      </FadeIn>\n\n      <FadeIn>\n        <Card>\n          <CardHeader>\n            <div className=\"relative\">\n              <AlertCircle className=\"absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-muted-foreground\" />\n              <Input\n                placeholder=\"搜索战略...\"\n                value={search}\n                onChange={(e) => setSearch(e.target.value)}\n                onBlur={fetchData}\n                className=\"pl-10\"\n              />\n            </div>\n          </CardHeader>\n          <CardContent>\n            {loading ? (\n              <div className=\"space-y-4\">{[1, 2, 3].map((i) => <Skeleton key={i} className=\"h-16\" />)}</div>\n            ) : strategies.length === 0 ? (\n              <div className=\"text-center py-12 text-muted-foreground\">暂无数据</div>\n            ) : (\n              <Table>\n                <TableHeader>\n                  <TableRow>\n                    <TableHead>战略名称</TableHead>\n                    <TableHead>年度</TableHead>\n                    <TableHead>状态</TableHead>\n                    <TableHead>进度</TableHead>\n                    <TableHead>操作</TableHead>\n                  </TableRow>\n                </TableHeader>\n                <TableBody>\n                  {strategies.map((item) => (\n                    <TableRow key={item.id}>\n                      <TableCell>\n                        <div className=\"flex items-center gap-3\">\n                          <div className=\"p-2 rounded-lg bg-muted\">\n                            <Target className=\"w-4 h-4 text-blue-500\" />\n                          </div>\n                          <div>\n                            <div className=\"font-medium\">{item.title}</div>\n                            {item.description && <div className=\"text-xs text-muted-foreground truncate max-w-xs\">{item.description}</div>}\n                          </div>\n                        </div>\n                      </TableCell>\n                      <TableCell>{item.year}</TableCell>\n                      <TableCell>\n                        <Badge className={statusBadge[item.status] || ''}>{statusLabels[item.status] || item.status}</Badge>\n                      </TableCell>\n                      <TableCell>\n                        <div className=\"flex items-center gap-2\">\n                          <Progress value={item.progress} className=\"w-20 h-2\" />\n                          <span className=\"text-sm\">{item.progress}%</span>\n                        </div>\n                      </TableCell>\n                      <TableCell>\n                        <Button variant=\"ghost\" size=\"sm\" onClick={() => handleEdit(item)}>\n                          <Edit className=\"w-4 h-4\" />\n                        </Button>\n                        <Button variant=\"ghost\" size=\"sm\" onClick={() => handleDelete(item.id)}>\n                          <Trash2 className=\"w-4 h-4 text-destructive\" />\n                        </Button>\n                      </TableCell>\n                    </TableRow>\n                  ))}\n                </TableBody>\n              </Table>\n            )}\n          </CardContent>\n        </Card>\n      </FadeIn>\n\n      {/* 新建/编辑对话框 */}\n      <Dialog open={dialogOpen} onOpenChange={handleDialogChange}>\n        <DialogContent>\n          <DialogHeader>\n            <DialogTitle>{editingItem ? '编辑战略' : '新建战略'}</DialogTitle>\n          </DialogHeader>\n          <form onSubmit={handleSubmit} className=\"space-y-4\">\n            <div className=\"space-y-2\">\n              <Label>战略名称 *</Label>\n              <Input\n                value={formData.title}\n                onChange={(e) => setFormData({ ...formData, title: e.target.value })}\n                placeholder=\"输入战略名称\"\n                required\n              />\n            </div>\n            <div className=\"space-y-2\">\n              <Label>战略描述</Label>\n              <Textarea\n                value={formData.description}\n                onChange={(e) => setFormData({ ...formData, description: e.target.value })}\n                placeholder=\"输入战略描述\"\n                rows={3}\n              />\n            </div>\n            <div className=\"grid grid-cols-2 gap-4\">\n              <div className=\"space-y-2\">\n                <Label>年度</Label>\n                <Input\n                  type=\"number\"\n                  value={formData.year}\n                  onChange={(e) => setFormData({ ...formData, year: parseInt(e.target.value) })}\n                />\n              </div>\n              <div className=\"space-y-2\">\n                <Label>开始日期 *</Label>\n                <Input\n                  type=\"date\"\n                  value={formData.startDate}\n                  onChange={(e) => setFormData({ ...formData, startDate: e.target.value })}\n                  required\n                />\n              </div>\n              <div className=\"space-y-2\">\n                <Label>结束日期 *</Label>\n                <Input\n                  type=\"date\"\n                  value={formData.endDate}\n                  onChange={(e) => setFormData({ ...formData, endDate: e.target.value })}\n                  required\n                />\n              </div>\n            </div>\n            <DialogFooter>\n              <Button type=\"button\" variant=\"outline\" onClick={() => setDialogOpen(false)}>取消</Button>\n              <Button type=\"submit\" disabled={submitting}>\n                {submitting ? '提交中...' : (editingItem ? '保存' : '创建')}\n              </Button>\n            </DialogFooter>\n          </form>\n        </DialogContent>\n      </Dialog>\n    </div>\n  );\n}\n","file_path":"/workspace/frontend/src/pages/StrategyList.tsx"},"tool_response":"Successfully overwrote file: /workspace/frontend/src/pages/StrategyList.tsx","client":"CLI","version":"2.71.1","generation_id":"646b82a4f7dc4bd8b89b1b9870f47a4e","model":"minimax-m2.7","call_id":"call_function_dmrbpkzk2qco_1"}
