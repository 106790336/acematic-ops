\n                borderRadius: 'var(--radius-lg)',\n              }}\n            >\n              <Building2 className=\"w-8 h-8 text-white\" />\n            </div>\n            <CardTitle style={{ fontSize: 'var(--font-size-headline)', fontWeight: 'var(--font-weight-bold)' }}>\n              CEO一把手管理系统\n            </CardTitle>\n            <CardDescription style={{ fontSize: 'var(--font-size-label)' }}>\n              企业战略执行管理平台\n            </CardDescription>\n          </CardHeader>\n          \n          <CardContent style={{ padding: 'var(--spacing-xl)', paddingTop: 0 }}>\n            <form onSubmit={handleSubmit} className=\"space-y-4\">\n              {error && (\n                <div \n                  className=\"flex items-center gap-2 p-3 rounded-lg text-sm\"\n                  style={{ \n                    background: 'oklch(0.95 0.03 25)',\n                    color: 'oklch(0.55 0.22 25)',\n                  }}\n                >\n                  <AlertCircle className=\"w-4 h-4\" />\n                  {error}\n                </div>\n              )}\n\n              <div className=\"space-y-2\">\n                <Label htmlFor=\"username\">用户名</Label>\n                <div className=\"relative\">\n                  <User className=\"absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-muted-foreground\" />\n                  <Input\n                    id=\"username\"\n                    type=\"text\"\n                    placeholder=\"请输入用户名\"\n                    value={username}\n                    onChange={(e) => setUsername(e.target.value)}\n                    className=\"pl-10\"\n                    required\n                  />\n                </div>\n              </div>\n\n              <div className=\"space-y-2\">\n                <Label htmlFor=\"password\">密码</Label>\n                <div className=\"relative\">\n                  <Lock className=\"absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-muted-foreground\" />\n                  <Input\n                    id=\"password\"\n                    type=\"password\"\n                    placeholder=\"请输入密码\"\n                    value={password}\n                    onChange={(e) => setPassword(e.target.value)}\n                    className=\"pl-10\"\n                    required\n                  />\n                </div>\n              </div>\n\n              <div className=\"flex items-center space-x-2\">\n                <Checkbox \n                  id=\"remember\" \n                  checked={rememberMe}\n                  onCheckedChange={(checked) => setRememberMe(checked as boolean)}\n                />\n                <Label htmlFor=\"remember\" className=\"text-sm font-normal cursor-pointer\">\n                  记住密码\n                </Label>\n              </div>\n\n              <Button \n                type=\"submit\" \n                className=\"w-full\" \n                disabled={loading}\n                style={{ \n                  background: 'oklch(0.42 0.19 250)',\n                  height: '44px',\n                }}\n              >\n                {loading ? '登录中...' : '登录'}\n              </Button>\n            </form>\n\n            <div \n              className=\"mt-6 p-4 rounded-lg\"\n              style={{ background: 'var(--muted)' }}\n            >\n              <p className=\"text-sm text-muted-foreground mb-2\">测试账号：</p>\n              <div className=\"text-xs space-y-1 text-muted-foreground\">\n                <p>CEO账号: ceo / 123456</p>\n                <p>高管账号: vp1 / 123456</p>\n                <p>经理账号: manager1 / 123456</p>\n                <p>员工账号: employee1 / 123456</p>\n              </div>\n            </div>\n          </CardContent>\n        </Card>\n      </FadeIn>\n    </div>\n  );\n}\n","file_path":"/workspace/frontend/src/pages/Login.tsx"},"tool_response":"Successfully created and wrote to new file: /workspace/frontend/src/pages/Login.tsx","client":"CLI","version":"2.71.1",