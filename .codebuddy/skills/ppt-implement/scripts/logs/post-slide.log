[2026-04-09 08:34:17] [DEBUG] [PPT PostToolUse Hook] stdin 数据: {"session_id":"2040121509614309376","transcript_path":"/root/.codebuddy/projects/workspace/2040121509614309376.jsonl","cwd":"/workspace","hook_event_name":"PostToolUse","tool_name":"Write","tool_input":{"content":"import { useState, useEffect } from 'react';\nimport { useAuth } from '@/hooks/use-auth';\nimport { api } from '@/lib/api';\nimport { Button } from '@/components/ui/button';\nimport { Input } from '@/components/ui/input';\nimport { Badge } from '@/components/ui/badge';\nimport { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';\nimport {\n  Table,\n  TableBody,\n  TableCell,\n  TableHead,\n  TableHeader,\n  TableRow,\n} from '@/components/ui/table';\nimport {\n  Dialog,\n  DialogContent,\n  DialogHeader,\n  DialogTitle,\n  DialogFooter,\n} from '@/components/ui/dialog';\nimport {\n  Select,\n  SelectContent,\n  SelectItem,\n  SelectTrigger,\n  SelectValue,\n} from '@/components/ui/select';\nimport { Tabs, TabsContent, TabsList, TabsTrigger } from '@/components/ui/tabs';\nimport { Textarea } from '@/components/ui/textarea';\nimport { Label } from '@/components/ui/label';\nimport { \n  Plus, \n  Search, \n  Filter, \n  CheckCircle, \n  XCircle, \n  Clock, \n  AlertTriangle,\n  Target,\n  Play,\n  FileCheck,\n  ArrowRight\n} from 'lucide-react';\n\ninterface Task {\n  id: string;\n  taskNumber: string;\n  title: string;\n  description?: string;\n  sourceType: string;\n  sourceRef?: string;\n  assignee?: { id: string; name: string; position?: string };\n  assigner?: { id: string; name: string };\n  dueDate: string;\n  priority: string;\n  status: string;\n  progress: number;\n  strategicAlignment: boolean;\n  alignmentTarget?: string;\n  parentTask?: { id: string; title: string };\n  createdAt: string;\n}\n\nconst sourceTypeLabels: Record<string, string> = {\n  assigned: '上级分配',\n  self_initiated: '主动提交',\n  plan_decomposition: '计划分解',\n};\n\nconst priorityLabels: Record<string, { label: string; color: string }> = {\n  low: { label: '低', color: 'bg-gray-100 text-gray-700' },\n  medium: { label: '中', color: 'bg-blue-100 text-blue-700' },\n  high: { label: '高', color: 'bg-orange-100 text-orange-700' },\n  urgent: { label: '紧急', color: 'bg-red-100 text-red-700' },\n};\n\nconst statusLabels: Record<string, { label: string; color: string }> = {\n  pending: { label: '待确认', color: 'bg-yellow-100 text-yellow-700' },\n  confirmed: { label: '已确认', color: 'bg-blue-100 text-blue-700' },\n  in_progress: { label: '进行中', color: 'bg-cyan-100 text-cyan-700' },\n  completed: { label: '已完成', color: 'bg-green-100 text-green-700' },\n  verified: { label: '已验收', color: 'bg-emerald-100 text-emerald-700' },\n  rejected: { label: '已驳回', color: 'bg-red-100 text-red-700' },\n};\n\nexport default function TaskManagement() {\n  const { user } = useAuth();\n  const [tasks, setTasks] = useState<Task[]>([]);\n  const [loading, setLoading] = useState(true);\n  const [activeTab, setActiveTab] = useState('all');\n  const [filters, setFilters] = useState({\n    sourceType: '',\n    status: '',\n    priority: '',\n    search: '',\n  });\n  const [showCreateDialog, setShowCreateDialog] = useState(false);\n  const [showDetailDialog, setShowDetailDialog] = useState(false);\n  const [selectedTask, setSelectedTask] = useState<Task | null>(null);\n  const [newTask, setNewTask] = useState({\n    title: '',\n    description: '',\n    sourceType: 'assigned' as const,\n    assigneeId: '',\n    dueDate: '',\n    priority: 'medium' as const,\n    strategicAlignment: false,\n    alignmentTarget: '',\n  });\n  const [users, setUsers] = useState<any[]>([]);\n\n  useEffect(() => {\n    fetchTasks();\n    fetchUsers();\n  }, [activeTab, filters]);\n\n  const fetchTasks = async () => {\n    try {\n      setLoading(true);\n      const params = new URLSearchParams();\n      if (filters.sourceType) params.append('sourceType', filters.sourceType);\n      if (filters.status) params.append('status', filters.status);\n      if (filters.priority) params.append('priority', filters.priority);\n      \n      const endpoint = activeTab === 'my' ? '/tasks-v2/my' : '/tasks-v2';\n      const response = await api.get(endpoint, { params: Object.fromEntries(params) });\n      \n      if (response.data.success) {\n        setTasks(response.data.data.items || response.data.data);\n      }\n    } catch (error) {\n      console.error('Failed to fetch tasks:', error);\n    } finally {\n      setLoading(false);\n    }\n  };\n\n  const fetchUsers = async () => {\n    try {\n      const response = await api.get('/users');\n      if (response.data.success) {\n        setUsers(response.data.data.items || response.data.data);\n      }\n    } catch (error) {\n      console.error('Failed to fetch users:', error);\n    }\n  };\n\n  const handleCreateTask = async () => {\n    try {\n      const response = await api.post('/tasks-v2', {\n        ...newTask,\n        sourceType: newTask.sourceType,\n        priority: newTask.priority,\n      });\n      \n      if (response.data.success) {\n        setShowCreateDialog(false);\n        fetchTasks();\n        resetNewTask();\n      }\n    } catch (error) {\n      console.error('Failed to create task:', error);\n    }\n  };\n\n  const handleConfirmTask = async (taskId: string) => {\n    try {\n      const response = await api.post(`/tasks-v2/${taskId}/confirm`);\n      if (response.data.success) {\n        fetchTasks();\n      }\n    } catch (error) {\n      console.error('Failed to confirm task:', error);\n    }\n  };\n\n  const handleStartTask = async (taskId: string) => {\n    try {\n      const response = await api.post(`/tasks-v2/${taskId}/start`);\n      if (response.data.success) {\n        fetchTasks();\n      }\n    } catch (error) {\n      console.error('Failed to start task:', error);\n    }\n  };\n\n  const handleApproveTask = async (taskId: string, approved: boolean, comment?: string) => {\n    try {\n      const response = await api.post(`/tasks-v2/${taskId}/approve`, {\n        approved,\n        comment,\n      });\n      if (response.data.success) {\n        fetchTasks();\n      }\n    } catch (error) {\n      console.error('Failed to approve task:', error);\n    }\n  };\n\n  const resetNewTask = () => {\n    setNewTask({\n      title: '',\n      description: '',\n      sourceType: 'assigned',\n      assigneeId: '',\n      dueDate: '',\n      priority: 'medium',\n      strategicAlignment: false,\n      alignmentTarget: '',\n    });\n  };\n\n  const getFilteredTasks = () => {\n    return tasks.filter(task => {\n      if (filters.search && !task.title.toLowerCase().includes(filters.search.toLowerCase())) {\n        return false;\n      }\n      return true;\n    });\n  };\n\n  return (\n    <div className=\"space-y-6\">\n      {/* 页面标题和操作 */}\n      <div className=\"flex items-center justify-between\">\n        <div>\n          <h1 className=\"text-2xl font-semibold\" style={{ color: 'var(--foreground)' }}>\n            任务管理\n          </h1>\n          <p className=\"text-sm mt-1\" style={{ color: 'var(--muted-foreground)' }}>\n            任务来源追溯 · 战略对齐管理\n          </p>\n        </div>\n        <div className=\"flex gap-3\">\n          <Button \n            onClick={() => setShowCreateDialog(true)}\n            style={{ \n              background: 'oklch(0.75 0.18 75)',\n              color: 'oklch(0.18 0.02 250)',\n            }}\n          >\n            <Plus className=\"w-4 h-4 mr-2\" />\n            新建任务\n          </Button>\n        </div>\n      </div>\n\n      {/* 筛选器 */}\n      <Card>\n        <CardContent className=\"pt-4\">\n          <div className=\"flex flex-wrap gap-4\">\n            <div className=\"flex-1 min-w-[200px]\">\n              <div className=\"relative\">\n                <Search className=\"absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-muted-foreground\" />\n                <Input\n                  placeholder=\"搜索任务...\"\n                  value={filters.search}\n                  onChange={(e) => setFilters({ ...filters, search: e.target.value })}\n                  className=\"pl-10\"\n                />\n              </div>\n            </div>\n            <Select\n              value={filters.sourceType}\n              onValueChange={(value) => setFilters({ ...filters, sourceType: value })}\n            >\n              <SelectTrigger className=\"w-[140px]\">\n                <SelectValue placeholder=\"来源类型\" />\n              </SelectTrigger>\n              <SelectContent>\n                <SelectItem value=\"\">全部来源</SelectItem>\n                <SelectItem value=\"assigned\">上级分配</SelectItem>\n                <SelectItem value=\"self_initiated\">主动提交</SelectItem>\n                <SelectItem value=\"plan_decomposition\">计划分解</SelectItem>\n              </SelectContent>\n            </Select>\n            <Select\n              value={filters.status}\n              onValueChange={(value) => setFilters({ ...filters, status: value })}\n            >\n              <SelectTrigger className=\"w-[140px]\">\n                <SelectValue placeholder=\"状态\" />\n              </SelectTrigger>\n              <SelectContent>\n                <SelectItem value=\"\">全部状态</SelectItem>\n                <SelectItem value=\"pending\">待确认</SelectItem>\n                <SelectItem value=\"confirmed\">已确认</SelectItem>\n                <SelectItem value=\"in_progress\">进行中</SelectItem>\n                <SelectItem value=\"completed\">已完成</SelectItem>\n                <SelectItem value=\"verified\">已验收</SelectItem>\n              </SelectContent>\n            </Select>\n            <Select\n              value={filters.priority}\n              onValueChange={(value) => setFilters({ ...filters, priority: value })}\n            >\n              <SelectTrigger className=\"w-[120px]\">\n                <SelectValue placeholder=\"优先级\" />\n              </SelectTrigger>\n              <SelectContent>\n                <SelectItem value=\"\">全部</SelectItem>\n                <SelectItem value=\"urgent\">紧急</SelectItem>\n                <SelectItem value=\"high\">高</SelectItem>\n                <SelectItem value=\"medium\">中</SelectItem>\n                <SelectItem value=\"low\">低</SelectItem>\n              </SelectContent>\n            </Select>\n          </div>\n        </CardContent>\n      </Card>\n\n      {/* 任务列表 */}\n      <Tabs value={activeTab} onValueChange={setActiveTab}>\n        <TabsList>\n          <TabsTrigger value=\"all\">全部任务</TabsTrigger>\n          <TabsTrigger value=\"my\">我的任务</TabsTrigger>\n        </TabsList>\n\n        <TabsContent value={activeTab} className=\"mt-4\">\n          <Card>\n            <CardContent className=\"p-0\">\n              <Table>\n                <TableHeader>\n                  <TableRow>\n                    <TableHead>任务编号</TableHead>\n                    <TableHead>任务名称</TableHead>\n                    <TableHead>来源</TableHead>\n                    <TableHead>负责人</TableHead>\n                    <TableHead>截止日期</TableHead>\n                    <TableHead>优先级</TableHead>\n                    <TableHead>战略对齐</TableHead>\n                    <TableHead>状态</TableHead>\n                    <TableHead>操作</TableHead>\n                  </TableRow>\n                </TableHeader>\n                <TableBody>\n                  {loading ? (\n                    <TableRow>\n                      <TableCell colSpan={9} className=\"text-center py-8 text-muted-foreground\">\n                        加载中...\n                      </TableCell>\n                    </TableRow>\n                  ) : getFilteredTasks().length === 0 ? (\n                    <TableRow>\n                      <TableCell colSpan={9} className=\"text-center py-8 text-muted-foreground\">\n                        暂无任务\n                      </TableCell>\n                    </TableRow>\n                  ) : (\n                    getFilteredTasks().map((task) => (\n                      <TableRow key={task.id} className=\"cursor-pointer hover:bg-muted/50\"\n                        onClick={() => { setSelectedTask(task); setShowDetailDialog(true); }}>\n                        <TableCell className=\"font-mono text-sm\">{task.taskNumber}</TableCell>\n                        <TableCell>\n                          <div>\n                            <div className=\"font-medium\">{task.title}</div>\n                            {task.sourceRef && (\n                              <div className=\"text-xs text-muted-foreground\">{task.sourceRef}</div>\n                            )}\n                          </div>\n                        </TableCell>\n                        <TableCell>\n                          <Badge variant=\"outline\">{sourceTypeLabels[task.sourceType]}</Badge>\n                        </TableCell>\n                        <TableCell>{task.assignee?.name || '未分配'}</TableCell>\n                        <TableCell>\n                          <div className=\"flex items-center gap-1\">\n                            <Clock className=\"w-3 h-3 text-muted-foreground\" />\n                            {new Date(task.dueDate).toLocaleDateString()}\n                          </div>\n                        </TableCell>\n                        <TableCell>\n                          <Badge className={priorityLabels[task.priority]?.color}>\n                            {priorityLabels[task.priority]?.label}\n                          </Badge>\n                        </TableCell>\n                        <TableCell>\n                          {task.strategicAlignment ? (\n                            <div className=\"flex items-center gap-1 text-green-600\">\n                              <Target className=\"w-4 h-4\" />\n                              <span className=\"text-xs\">已对齐</span>\n                            </div>\n                          ) : (\n                            <div className=\"flex items-center gap-1 text-orange-500\">\n                              <AlertTriangle className=\"w-4 h-4\" />\n                              <span className=\"text-xs\">未对齐</span>\n                            </div>\n                          )}\n                        </TableCell>\n                        <TableCell>\n                          <Badge className={statusLabels[task.status]?.color}>\n                            {statusLabels[task.status]?.label}\n                          </Badge>\n                        </TableCell>\n                        <TableCell>\n                          <div className=\"flex items-center gap-2\" onClick={(e) => e.stopPropagation()}>\n                            {task.status === 'pending' && task.sourceType === 'assigned' && (\n                              <Button size=\"sm\" variant=\"outline\" onClick={() => handleConfirmTask(task.id)}>\n                                <CheckCircle className=\"w-4 h-4 mr-1\" />\n                                确认\n                              </Button>\n                            )}\n                            {task.status === 'confirmed' && (\n                              <Button size=\"sm\" variant=\"outline\" onClick={() => handleStartTask(task.id)}>\n                                <Play className=\"w-4 h-4 mr-1\" />\n                                开始\n                              </Button>\n                            )}\n                            {task.status === 'pending' && task.sourceType === 'self_initiated' && (\n                              <>\n                                <Button size=\"sm\" onClick={() => handleApproveTask(task.id, true)}>\n                                  通过\n                                </Button>\n                                <Button size=\"sm\" variant=\"destructive\" onClick={() => handleApproveTask(task.id, false)}>\n                                  驳回\n                                </Button>\n                              </>\n                            )}\n    