[2026-04-11 05:17:46] [DEBUG] [PPT PostToolUse Hook] stdin 数据: {"session_id":"2040121509614309376","transcript_path":"/root/.codebuddy/projects/workspace/2040121509614309376.jsonl","cwd":"/workspace","hook_event_name":"PostToolUse","tool_name":"Write","tool_input":{"content":"import urllib.request\nimport json\n\nBASE = \"http://localhost:5173/api\"\n\ndef login():\n    r = urllib.request.urlopen(urllib.request.Request(\n        BASE + '/auth/login',\n        data=json.dumps({\"username\": \"admin\", \"password\": \"123456\"}).encode(),\n        headers={\"Content-Type\": \"application/json\"},\n        method=\"POST\"\n    ))\n    return json.loads(r.read())[\"data\"][\"token\"]\n\ntoken = login()\nhdrs = {\"Content-Type\": \"application/json\", \"Authorization\": f\"Bearer {token}\"}\n\ndef get(path):\n    r = urllib.request.Request(f\"{BASE}{path}\", headers=hdrs)\n    return json.loads(urllib.request.urlopen(r).read())\n\ndef post(path, body):\n    r = urllib.request.Request(f\"{BASE}{path}\", data=json.dumps(body).encode(), headers=hdrs, method=\"POST\")\n    return json.loads(urllib.request.urlopen(r).read())\n\ndef put(path, body):\n    r = urllib.request.Request(f\"{BASE}{path}\", data=json.dumps(body).encode(), headers=hdrs, method=\"PUT\")\n    return json.loads(urllib.request.urlopen(r).read())\n\nprint(\"=== 测试各模块CRUD ===\")\n\n# 战略\nprint(\"\\n1. 战略管理\")\nr = post(\"/strategies\", {\"title\": \"测试战略\", \"year\": 2026, \"startDate\": \"2026-01-01\", \"endDate\": \"2026-12-31\"})\nif r.get(\"success\"):\n    sid = r[\"data\"][\"id\"]\n    print(f\"   新建: OK (id={sid[:8]}...)\")\n    r2 = put(f\"/strategies/{sid}\", {\"title\": \"已修改战略\"})\n    print(f\"   编辑: {'OK' if r2.get('success') else 'FAIL'}\")\nelse:\n    print(f\"   新建: FAIL - {r.get('error')}\")\n\n# 计划\nprint(\"\\n2. 计划管理\")\nr = post(\"/plans\", {\"title\": \"测试计划\", \"type\": \"department\", \"startDate\": \"2026-01-01\", \"endDate\": \"2026-06-30\"})\nif r.get(\"success\"):\n    pid = r[\"data\"][\"id\"]\n    print(f\"   新建: OK\")\n    r2 = put(f\"/plans/{pid}\", {\"title\": \"已修改计划\"})\n    print(f\"   编辑: {'OK' if r2.get('success') else 'FAIL'}\")\nelse:\n    print(f\"   新建: FAIL - {r.get('error')}\")\n\n# 任务\nprint(\"\\n3. 任务管理\")\nr = post(\"/tasks-v2\", {\"title\": \"测试任务\", \"dueDate\": \"2026-04-30\"})\nif r.get(\"success\"):\n    tid = r[\"data\"][\"id\"]\n    print(f\"   新建: OK\")\n    r2 = put(f\"/tasks-v2/{tid}\", {\"title\": \"已修改任务\"})\n    print(f\"   编辑: {'OK' if r2.get('success') else 'FAIL'}\")\nelse:\n    print(f\"   新建: FAIL - {r.get('error')}\")\n\n# 考核\nprint(\"\\n4. 考核管理\")\nr = post(\"/assessments\", {\"userId\": \"user-emp1\", \"assessorId\": \"user-ceo\", \"type\": \"monthly\", \"period\": \"测试\", \"score\": 85})\nif r.get(\"success\"):\n    aid = r[\"data\"][\"id\"]\n    print(f\"   新建: OK\")\n    r2 = put(f\"/assessments/{aid}\", {\"score\": 95})\n    print(f\"   编辑: {'OK' if r2.get('success') else 'FAIL'}\")\nelse:\n    print(f\"   新建: FAIL - {r.get('error')}\")\n\n# 问题\nprint(\"\\n5. 问题清单\")\nr = post(\"/issues\", {\"source\": \"测试\", \"discoveryDate\": \"2026-04-10\", \"departmentId\": \"dept-ops\", \"description\": \"测试问题\", \"issueType\": \"其他\", \"severity\": \"中\"})\nif r.get(\"success\"):\n    iid = r[\"data\"][\"id\"]\n    print(f\"   新建: OK\")\n    r2 = put(f\"/issues/{iid}\", {\"description\": \"已修改问题\"})\n    print(f\"   编辑: {'OK' if r2.get('success') else 'FAIL'}\")\nelse:\n    print(f\"   新建: FAIL - {r.get('error')}\")\n\n# 周报\nprint(\"\\n6. 周报管理\")\nr = post(\"/weekly-reports\", {\"weekDate\": \"2026-04-07\", \"departmentId\": \"dept-ops\", \"completedTasks\": \"测试\", \"keyData\": \"100\", \"nextWeekPlan\": \"继续\", \"selfEvaluation\": \"达成\"})\nif r.get(\"success\"):\n    rid = r[\"data\"][\"id\"]\n    print(f\"   新建: OK\")\n    r2 = put(f\"/weekly-reports/{rid}\", {\"completedTasks\": \"已修改\"})\n    print(f\"   编辑: {'OK' if r2.get('success') else 'FAIL'}\")\nelse:\n    print(f\"   新建: FAIL - {r.get('error')}\")\n\n# 部门\nprint(\"\\n7. 部门管理\")\nr = post(\"/departments\", {\"name\": \"测试部门\", \"description\": \"测试\"})\nif r.get(\"success\"):\n    did = r[\"data\"][\"id\"]\n    print(f\"   新建: OK\")\n    r2 = put(f\"/departments/{did}\", {\"name\": \"已修改部门\"})\n    print(f\"   编辑: {'OK' if r2.get('success') else 'FAIL'}\")\nelse:\n    print(f\"   新建: FAIL - {r.get('error')}\")\n\nprint(\"\\n=== 全部测试完成 ===\")\n","file_path":"/workspace/test_all.py"},"tool_response":"Successfully created and wrote to new file: /workspace/test_all.py","client":"CLI","version":"2.71.1","generation_id":"cbb2077c49d24a45b6a850f11a299c54","model":"glm-5.0","call_id":"019d7af92201f89be3f36d40d409ce4d"}
