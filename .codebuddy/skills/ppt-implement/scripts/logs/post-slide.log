[2026-04-12 01:54:42] [DEBUG] [PPT PostToolUse Hook] stdin 数据: {"session_id":"05e50e2b-b627-47dc-9949-3dd811d4ee9d","transcript_path":"/root/.codebuddy/projects/workspace/05e50e2b-b627-47dc-9949-3dd811d4ee9d.jsonl","cwd":"/workspace","hook_event_name":"PostToolUse","tool_name":"Write","tool_input":{"content":"import { useState, useEffect, useCallback } from 'react';\nimport { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';\nimport { Button } from '@/components/ui/button';\nimport { Input } from '@/components/ui/input';\nimport { Badge } from '@/components/ui/badge';\nimport { Skeleton } from '@/components/ui/skeleton';\nimport { Textarea } from '@/components/ui/textarea';\nimport { Label } from '@/components/ui/label';\nimport {\n  Dialog,\n  DialogContent,\n  DialogHeader,\n  DialogTitle,\n  DialogFooter,\n} from '@/components/ui/dialog';\nimport { FadeIn } from '@/components/MotionPrimitives';\nimport { Plus, Calendar, Clock, CheckCircle, AlertCircle, Edit, Trash2, ChevronLeft, ChevronRight } from 'lucide-react';\nimport { apiClient, getErrorMessage } from '@/lib/api-client';\nimport type { DailyLog as DailyLogType, ApiResponse, PaginatedResponse } from '@/types';\n\nconst emptyForm = {\n  logDate: new Date().toISOString().split('T')[0],\n  weeklyPlanId: '',\n  workContent: '',\n  achievements: '',\n  workHours: 8,\n  progress: 0,\n  problems: '',\n  nextDayPlan: '',\n  tasks: [] as any[],\n};\n\nexport default function DailyLog() {\n  const [logs, setLogs] = useState<DailyLogType[]>([]);\n  const [loading, setLoading] = useState(true);\n  const [dialogOpen, setDialogOpen] = useState(false);\n  const [submitting, setSubmitting] = useState(false);\n  const [todayLog, setTodayLog] = useState<DailyLogType | null>(null);\n  const [currentDate, setCurrentDate] = useState(new Date().toISOString().split('T')[0]);\n  const [editItem, setEditItem] = useState<DailyLogType | null>(null);\n  const [form, setForm] = useState({ ...emptyForm });\n\n  const fetchLogs = useCallback(async () => {\n    setLoading(true);\n    try {\n      const startDate = new Date(currentDate);\n      startDate.setDate(startDate.getDate() - 7);\n      const endDate = new Date(currentDate);\n      endDate.setDate(endDate.getDate() + 7);\n\n      const response = await apiClient.get<ApiResponse<PaginatedResponse<DailyLogType>>>(\n        `/execution?startDate=${startDate.toISOString()}&endDate=${endDate.toISOString()}`\n      );\n      if (response.data.success && response.data.data) {\n        setLogs(response.data.data.items);\n      }\n    } catch (err) {\n      console.error('Fetch logs error:', err);\n    } finally {\n      setLoading(false);\n    }\n  }, [currentDate]);\n\n  const checkTodayLog = useCallback(async () => {\n    try {\n      const response = await apiClient.get<ApiResponse<DailyLogType>>('/execution/today');\n      if (response.data.success && response.data.data) {\n        setTodayLog(response.data.data);\n      } else {\n        setTodayLog(null);\n      }\n    } catch (err) {\n      console.error('Check today log error:', err);\n      setTodayLog(null);\n    }\n  }, []);\n\n  useEffect(() => {\n    fetchLogs();\n    checkTodayLog();\n  }, [fetchLogs, checkTodayLog]);\n\n  const populateForm = (log: DailyLogType) => {\n    setEditItem(log);\n    setForm({\n      logDate: log.logDate.split('T')[0],\n      weeklyPlanId: log.weeklyPlanId || '',\n      workContent: log.workContent,\n      achievements: log.achievements || '',\n      workHours: log.workHours,\n      progress: log.progress,\n      problems: log.problems || '',\n      nextDayPlan: log.nextDayPlan || '',\n      tasks: (log as any).tasks || [],\n    });\n  };\n\n  const resetForm = () => {\n    setEditItem(null);\n    setForm({ ...emptyForm });\n  };\n\n  const openCreate = () => {\n    resetForm();\n    if (todayLog) {\n      populateForm(todayLog);\n    }\n    setDialogOpen(true);\n  };\n\n  const onEdit = (log: DailyLogType) => {\n    populateForm(log);\n    setDialogOpen(true);\n  };\n\n  const onDialogChange = (open: boolean) => {\n    setDialogOpen(open);\n    if (!open) resetForm();\n  };\n\n  const handleSubmit = async (e: React.FormEvent) => {\n    e.preventDefault();\n    try {\n      setSubmitting(true);\n      if (editItem) {\n        await apiClient.put(`/execution/${editItem.id}`, form);\n      } else {\n        await apiClient.post('/execution', form);\n      }\n      setDialogOpen(false);\n      resetForm();\n      fetchLogs();\n      checkTodayLog();\n    } catch (err: any) {\n      alert(err.response?.data?.error || getErrorMessage(err));\n    } finally {\n      setSubmitting(false);\n    }\n  };\n\n  const onDelete = async (id: string) => {\n    if (!confirm('确定删除该日志？')) return;\n    try {\n      await apiClient.delete(`/execution/${id}`);\n      fetchLogs();\n      checkTodayLog();\n    } catch (err: any) {\n      alert(err.response?.data?.error || getErrorMessage(err));\n    }\n  };\n\n  const addTask = () => {\n    setForm({\n      ...form,\n      tasks: [\n        ...form.tasks,\n        { taskName: '', description: '', planHours: 0, actualHours: 0, status: '进行中', completion: 0 },\n      ],\n    });\n  };\n\n  const updateTask = (index: number, field: string, value: any) => {\n    const newTasks = [...form.tasks];\n    newTasks[index] = { ...newTasks[index], [field]: value };\n    setForm({ ...form, tasks: newTasks });\n  };\n\n  const removeTask = (index: number) => {\n    const newTasks = form.tasks.filter((_, i) => i !== index);\n    setForm({ ...form, tasks: newTasks });\n  };\n\n  const getProgressColor = (progress: number) => {\n    if (progress >= 80) return 'oklch(0.60 0.15 163)';\n    if (progress >= 50) return 'oklch(0.75 0.18 75)';\n    return 'oklch(0.55 0.22 25)';\n  };\n\n  return (\n    <div className=\"space-y-6\">\n      <FadeIn>\n        <div className=\"flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4\">\n          <div>\n            <h1 className=\"font-bold\" style={{ fontSize: 'var(--font-size-headline)' }}>\n              每日执行日志\n            </h1>\n            <p className=\"text-muted-foreground\" style={{ fontSize: 'var(--font-size-label)' }}>\n              记录每日工作内容和成果，跟踪执行进度\n            </p>\n          </div>\n          <Button onClick={openCreate}>\n            <Plus className=\"w-4 h-4 mr-2\" />\n            {todayLog ? '更新日志' : '填写今日日志'}\n          </Button>\n        </div>\n      </FadeIn>\n\n      {/* 今日概览 */}\n      {todayLog && (\n        <FadeIn>\n          <Card>\n            <CardHeader>\n              <CardTitle className=\"flex items-center justify-between\">\n                <div className=\"flex items-center gap-2\">\n                  <Calendar className=\"w-5 h-5\" style={{ color: 'oklch(0.42 0.19 250)' }} />\n                  今日工作概览\n                </div>\n                <Button size=\"sm\" variant=\"outline\" onClick={() => onEdit(todayLog)}>\n                  <Edit className=\"w-4 h-4 mr-2\" />\n                  编辑\n                </Button>\n              </CardTitle>\n            </CardHeader>\n            <CardContent>\n              <div className=\"space-y-4\">\n                <div className=\"grid grid-cols-3 gap-4\">\n                  <div className=\"text-center p-4 rounded-lg\" style={{ background: 'var(--muted)' }}>\n                    <Clock className=\"w-6 h-6 mx-auto mb-2\" style={{ color: 'oklch(0.42 0.19 250)' }} />\n                    <div className=\"text-2xl font-bold\">{todayLog.workHours}h</div>\n                    <div className=\"text-sm text-muted-foreground\">工作时长</div>\n                  </div>\n                  <div className=\"text-center p-4 rounded-lg\" style={{ background: 'var(--muted)' }}>\n                    <CheckCircle className=\"w-6 h-6 mx-auto mb-2\" style={{ color: getProgressColor(todayLog.progress) }} />\n                    <div className=\"text-2xl font-bold\">{todayLog.progress}%</div>\n                    <div className=\"text-sm text-muted-foreground\">完成进度</div>\n                  </div>\n                  <div className=\"text-center p-4 rounded-lg\" style={{ background: 'var(--muted)' }}>\n                    <AlertCircle className=\"w-6 h-6 mx-auto mb-2\" style={{ color: 'oklch(0.75 0.18 75)' }} />\n                    <div className=\"text-2xl font-bold\">{(todayLog as any).tasks?.length || 0}</div>\n                    <div className=\"text-sm text-muted-foreground\">执行任务</div>\n                  </div>\n                </div>\n\n                <div>\n                  <div className=\"font-medium mb-2\">工作内容</div>\n                  <div className=\"text-sm text-muted-foreground whitespace-pre-wrap\">\n                    {todayLog.workContent}\n                  </div>\n                </div>\n\n                {todayLog.achievements && (\n                  <div>\n                    <div className=\"font-medium mb-2\">完成成果</div>\n                    <div className=\"text-sm text-muted-foreground whitespace-pre-wrap\">\n                      {todayLog.achievements}\n                    </div>\n                  </div>\n                )}\n\n                {todayLog.problems && (\n                  <div className=\"p-3 rounded-lg\" style={{ background: 'oklch(0.95 0.03 25)' }}>\n                    <div className=\"font-medium mb-1 flex items-center gap-2\">\n                      <AlertCircle className=\"w-4 h-4\" style={{ color: 'oklch(0.55 0.22 25)' }} />\n                      遇到的问题\n                    </div>\n                    <div className=\"text-sm whitespace-pre-wrap\">{todayLog.problems}</div>\n                  </div>\n                )}\n              </div>\n            </CardContent>\n          </Card>\n        </FadeIn>\n      )}\n\n      {/* 历史日志 */}\n      <FadeIn>\n        <Card>\n          <CardHeader>\n            <div className=\"flex items-center justify-between\">\n              <CardTitle>历史日志</CardTitle>\n              <div className=\"flex items-center gap-2\">\n                <Button\n                  size=\"icon\"\n                  variant=\"outline\"\n                  onClick={() => {\n                    const date = new Date(currentDate);\n                    date.setDate(date.getDate() - 7);\n                    setCurrentDate(date.toISOString().split('T')[0]);\n                  }}\n                >\n                  <ChevronLeft className=\"w-4 h-4\" />\n                </Button>\n                <span className=\"text-sm text-muted-foreground min-w-[100px] text-center\">\n                  {new Date(currentDate).toLocaleDateString('zh-CN', { month: 'short', year: 'numeric' })}\n                </span>\n                <Button\n                  size=\"icon\"\n                  variant=\"outline\"\n                  onClick={() => {\n                    const date = new Date(currentDate);\n                    date.setDate(date.getDate() + 7);\n                    setCurrentDate(date.toISOString().split('T')[0]);\n                  }}\n                >\n                  <ChevronRight className=\"w-4 h-4\" />\n                </Button>\n              </div>\n            </div>\n          </CardHeader>\n          <CardContent>\n            {loading ? (\n              <div className=\"space-y-3\">\n                {[1, 2, 3].map((i) => (\n                  <Skeleton key={i} className=\"h-20\" />\n                ))}\n              </div>\n            ) : logs.length === 0 ? (\n              <div className=\"text-center py-12\">\n                <Calendar className=\"w-16 h-16 mx-auto text-muted-foreground mb-4\" />\n                <p className=\"text-muted-foreground\">暂无日志记录</p>\n                <Button className=\"mt-4\" onClick={openCreate}>\n                  填写第一份日志\n                </Button>\n              </div>\n            ) : (\n              <div className=\"space-y-3\">\n                {logs.map((log) => (\n                  <div\n                    key={log.id}\n                    className=\"p-4 rounded-lg border\"\n                    style={{ borderColor: 'var(--border)' }}\n                  >\n                    <div className=\"flex items-start justify-between mb-2\">\n                      <div className=\"flex items-center gap-2\">\n                        <div\n                          className=\"w-10 h-10 rounded-full flex items-center justify-center text-white text-sm font-medium\"\n                          style={{ background: 'oklch(0.42 0.19 250)' }}\n                        >\n                          {new Date(log.logDate).getDate()}\n                        </div>\n                        <div>\n                          <div className=\"font-medium text-sm\">\n                            {new Date(log.logDate).toLocaleDateString('zh-CN', { weekday: 'long' })}\n                          </div>\n                          <div className=\"text-xs text-muted-foreground\">\n                            {log.user?.name} · {log.department?.name}\n                          </div>\n                        </div>\n                      </div>\n                      <div className=\"flex items-center gap-3\">\n                        <Badge variant=\"outline\">{log.workHours}h</Badge>\n                        <Badge\n                          style={{\n                            background: getProgressColor(log.progress),\n                            color: 'white',\n                          }}\n                        >\n                          {log.progress}%\n                        </Badge>\n                      </div>\n                    </div>\n                    <div className=\"text-sm text-muted-foreground line-clamp-2\">\n                      {log.workContent}\n                    </div>\n                    <div className=\"flex gap-2 mt-2\">\n                      <Button variant=\"ghost\" size=\"sm\" onClick={() => onEdit(log)}>\n                        <Edit className=\"w-4 h-4\" />\n                      </Button>\n                      <Button variant=\"ghost\" size=\"sm\" onClick={() => onDelete(log.id)}>\n                        <Trash2 className=\"w-4 h-4 text-destructive\" />\n                      </Button>\n                    </div>\n                  </div>\n                ))}\n              </div>\n            )}\n          </CardContent>\n        </Card>\n      </FadeIn>\n\n      {/* 填写/编辑日志对话框 */}\n      <Dialog open={dialogOpen} onOpenChange={onDialogChange}>\n        <DialogContent className=\"max-w-3xl max-h-[90vh] overflow-y-auto\">\n          <DialogHeader>\n            <DialogTitle>\n              {editItem ? '编辑' : '填写'}工作日志\n            </DialogTitle>\n          </DialogHeader>\n          <form onSubmit={handleSubmit} className=\"space-y-4\">\n            <div className=\"grid grid-cols-3 gap-4\">\n              <div className=\"space-y-2\">\n                <Label htmlFor=\"logDate\">日期</Label>\n                <Input\n                  id=\"logDate\"\n                  type=\"date\"\n                  value={form.logDate}\n                  onChange={(e) => setForm({ ...form, logDate: e.target.value })}\n                  required\n                />\n              </div>\n              <div className=\"space-y-2\">\n                <Label htmlFor=\"workHours\">工作时长(小时)</Label>\n                <Input\n                  id=\"workHours\"\n                  type=\"number\"\n                  value={form.workHours}\n                  onChange={(e) => setForm({ ...form, workHours: parseFloat(e.target.value) })}\n                  min=\"0\"\n                  max=\"24\"\n                  step=\"0.5\"\n                />\n              </div>\n              <div className=\"space-y-2\">\n                <Label htmlFor=\"progress\">完成进度(%)</Label>\n                <Input\n                  id=\"progress\"\n                  type=\"number\"\n                  value={form.progress}\n                  onChange={(e) => setForm({ ...form, progress: parseInt(e.target.value) })}\n                  min=\"0\"\n                  max=\"100\"\n                />\n              </div>\n            </div>\n\n            <div className=\"space-y-2\">\n              <Label htmlFor=\"workContent\">今日工作内容 *</Label>\n              <Textarea\n                id=\"workContent\"\n                value={form.workContent}\n                onChange={(e) => setForm({ ...form, workContent: e.target.value })}\n                placeholder=\"详细记录今天完成的工作\"\n                rows={4}\n                required\n              />\n            </div>\n\n            <div className=\"space-y-2\">\n              <Label htmlFor=\"achievements\">完成成果</Label>\n              <Textarea\n                id=\"achievements\"\n                value={form.achievements}\n                onChange={(e) => setForm({ ...form, achievements: e.target.value })}\n                placeholder=\"记录今天的工作成果、交付物\"\n                rows={3}\n              />\n            </div>\n\n            {/* 任务列表 */}\n            <div className=\"space-y-2\">\n              <div className=\"flex items-center justify-between\">\n                <Label>执行任务明细</Label>\n                <Button type=\"button\" size=\"sm\" variant=\"outline\" onClick={addTask}>\n                  <Plus className=\"w-4 h-4 mr-2\" />\n                  添加任务\n                </Button>\n              </div>\n              {form.tasks.map((task, index) => (\n                <div key={index} className=\"p-3 rounded-lg border space-y-2\">\n                  <div className=\"flex items-start gap-2\">\n                    <Input\n                      placeholder=\"任务名称\"\n                      value={task.taskName}\n                      onChange={(e) => updateTask(index, 'taskName', e.target.value)}\n                      className=\"flex-1\"\n                    />\n                    <Input\n                      type=\"number\"\n                      placeholder=\"计划时长\"\n                      value={task.planHours}\n                      onChange={(e) => updateTask(index, 'planHours', parseFloat(e.target.value))}\n                      className=\"w-24\"\n                    />\n                    <Input\n                      type=\"number\"\n                      placeholder=\"实际时长\"\n                      value={task.actualHours}\n                      onChange={(e) => updateTask(index, 'actualHours', parseFloat(e.target.value))}\n                      className=\"w-24\"\n                    />\n                    <Button type=\"button\" size=\"sm\" variant=\"ghost\" onClick={() => removeTask(index)}>\n                      ×\n                    </Button>\n                  </div>\n                  <div className=\"flex gap-2\">\n                    <Input\n                      placeholder=\"任务描述\"\n                      value={task.description}\n                      onChange={(e) => updateTask(index, 'description', e.target.value)}\n                      className=\"flex-1\"\n                    />\n                    <Input\n                      type=\"number\"\n                      placeholder=\"完成度%\"\n                      value={task.completion}\n                      onChange={(e) => updateTask(index, 'completion', parseInt(e.target.value))}\n                      className=\"w-24\"\n                    />\n                  </div>\n                </div>\n              ))}\n              {form.tasks.length === 0 && (\n                <div className=\"text-center py-4 text-sm text-muted-foreground\">\n                  点击\"添加任务\"记录具体执行明细\n                </div>\n              )}\n            </div>\n\n            <div className=\"space-y-2\">\n              <Label htmlFor=\"problems\">遇到的问题</Label>\n              <Textarea\n                id=\"problems\"\n                value={form.problems}\n                onChange={(e) => setForm({ ...form, problems: e.target.value })}\n                placeholder=\"记录工作中遇到的问题和困难\"\n                rows={2}\n              />\n            </div>\n\n            <div className=\"space-y-2\">\n              <Label htmlFor=\"nextDayPlan\">明日计划</Label>\n              <Textarea\n                id=\"nextDayPlan\"\n                value={form.nextDayPlan}\n                onChange={(e) => setForm({ ...form, nextDayPlan: e.target.value })}\n                placeholder=\"计划明天要完成的工作\"\n                rows={2}\n              />\n            </div>\n\n            <DialogFooter>\n              <Button type=\"button\" variant=\"outline\" onClick={() => onDialogChange(false)}>\n                取消\n              </Button>\n              <Button type=\"submit\" disabled={submitting}>\n                {submitting ? '提交中...' : (editItem ? '保存' : '提交')}\n              </Button>\n            </DialogFooter>\n          </form>\n        </DialogContent>\n      </Dialog>\n    </div>\n  );\n}\n","file_path":"/workspace/frontend/src/pages/DailyLog.tsx"},"tool_response":"Successfully overwrote file: /workspace/frontend/src/pages/DailyLog.tsx","client":"CLI","version":"2.71.1","generation_id":"2fc3ddf29a9447859c701b38910c33bb","model":"glm-5.0-turbo","call_id":"call_6286e869eba04107bc469c58"}
