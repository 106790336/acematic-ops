dData();\n\n  // 提交\n  const handleSubmit = async (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!form.title.trim() || !form.startDate || !form.endDate) {\n      alert('请填写必填项');\n      return;\n    }\n    try {\n      setSaving(true);\n      if (editItem) {\n        await apiClient.put(`/strategies/${editItem.id}`, form);\n      } else {\n        await apiClient.post('/strategies', form);\n      }\n      setShowDialog(false);\n      resetForm();\n      loadData();\n    } catch (err: any) {\n      alert(err.response?.data?.error || '操作失败');\n    } finally {\n      setSaving(false);\n    }\n  };\n\n  // 编辑\n  const onEdit = (item: Strategy) => {\n    setEditItem(item);\n    setForm({\n      title: item.title,\n      description: item.description || '',\n      year: item.year,\n      startDate: item.startDate.split('T')[0],\n      endDate: item.endDate.split('T')[0],\n    });\n    setShowDialog(true);\n  };\n\n  // 删除\n  const onDelete = async (id: string) => {\n    if (!confirm('确定删除？')) return;\n    try {\n      await apiClient.delete(`/strategies/${id}`);\n      loadData();\n    } catch (err: any) {\n      alert(err.response?.data?.error || '删除失败');\n    }\n  };\n\n  // 重置\n  const resetForm = () => {\n    setEditItem(null);\n    setForm({\n      title: '',\n      description: '',\n      year: new Date().getFullYear(),\n      startDate: '',\n      endDate: '',\n    });\n  };\n\n  // 打开新建\n  const openCreate = () => {\n    resetForm();\n    setShowDialog(true);\n  };\n\n  // 对话框关闭\n  const onDialogChange = (open: boolean) => {\n    setShowDialog(open);\n    if (!open) resetForm();\n  };\n\n  const statusMap: Record<string, { label: string; class: string }> = {\n    draft: { label: '草稿', class: 'bg-gray-100 text-gray-700' },\n    active: { label: '进行中', class: 'bg-blue-100 text-blue-700' },\n    completed: { label: '已完成', class: 'bg-green-100 text-green-700' },\n  };\n\n  return (\n    <div className=\"space-y-6\">\n      <FadeIn>\n        <div className=\"flex items-center justify-between\">\n          <div>\n            <h1 className=\"font-bold text-2xl\">战略管理</h1>\n            <p className=\"text-muted-foreground text-sm\">管理公司战略目标</p>\n          </div>\n          <Button onClick={openCreate}>\n            <Plus className=\"w-4 h-4 mr-2\" />新建战略\n          </Button>\n        </div>\n      </FadeIn>\n\n      <FadeIn>\n        <Card>\n          <CardContent className=\"pt-6\">\n            {loading ? (\n              <div className=\"space-y-3\">{[1,2,3].map(i => <Skeleton key={i} className=\"h-16\" />)}</div>\n            ) : list.length === 0 ? (\n              <div className=\"text-center py-12 text-muted-foreground\">暂无数据</div>\n            ) : (\n              <Table>\n                <TableHeader>\n                  <TableRow>\n                    <TableHead>名称</TableHead>\n                    <TableHead>年度</TableHead>\n                    <TableHead>状态</TableHead>\n                    <TableHead>进度</TableHead>\n                    <TableHead>操作</TableHead>\n                  </TableRow>\n                </TableHeader>\n                <TableBody>\n                  {list.map(item => (\n                    <TableRow key={item.id}>\n                      <TableCell>\n                        <div className=\"flex items-center gap-2\">\n                          <Target className=\"w-4 h-4 text-blue-500\" />\n                          <span className=\"font-medium\">{item.title}</span>\n                        </div>\n                      </TableCell>\n                      <TableCell>{item.year}</TableCell>\n                      <TableCell>\n                        <Badge className={statusMap[item.status]?.class || ''}>\n                          {statusMap[item.status]?.label || item.status}\n                        </Badge>\n                      </TableCell>\n                      <TableCell>\n                        <div className=\"flex items-center gap-2\">\n                          <Progress value={item.progress} className=\"w-16 h-2\" />\n                          <span className=\"text-sm\">{item.progress}%</span>\n                        </div>\n                      </TableCell>\n                      <TableCell>\n                        <Button variant=\"ghost\" size=\"sm\" onClick={() => onEdit(item)}>\n                          <Edit className=\"w-4 h-4\" />\n                        </Button>\n                        <Button variant=\"ghost\" size=\"sm\" onClick={() => onDelete(item.id)}>\n                          <Trash2 className=\"w-4 h-4 text-destructive\" />\n                        </Button>\n                      </TableCell>\n                    </TableRow>\n                  ))}\n                </TableBody>\n              </Table>\n            )}\n          </CardContent>\n        </Card>\n      </FadeIn>\n\n      {/* 新建/编辑对话框 */}\n      <Dialog open={showDialog} onOpenChange={onDialogChange}>\n        <DialogContent>\n          <DialogHeader>\n            <DialogTitle>{editItem ? '编辑战略' : '新建战略'}</DialogTitle>\n          </DialogHeader>\n          <form onSubmit={handleSubmit} className=\"space-y-4\">\n            <div className=\"space-y-2\">\n              <Label>战略名称 *</Label>\n              <Input\n                value={form.title}\n                onChange={e => setForm({...form, title: e.target.value})}\n                placeholder=\"输入名称\"\n                required\n              />\n            </div>\n            <div className=\"space-y-2\">\n              <Label>描述</Label>\n              <Textarea\n                value={form.description}\n                onChange={e => setForm({...form, description: e.target.value})}\n                rows={2}\n              />\n            </div>\n            <div className=\"grid grid-cols-3 gap-4\">\n              <div className=\"space-y-2\">\n                <Label>年度</Label>\n                <Input\n                  type=\"number\"\n                  value={form.year}\n                  onChange={e => setForm({...form, year: parseInt(e.target.value)})}\n                />\n              </div>\n              <div className=\"space-y-2\">\n                <Label>开始日期 *</Label>\n                <Input\n                  type=\"date\"\n                  value={form.startDate}\n                  onChange={e => setForm({...form, startDate: e.target.value})}\n                  required\n                />\n              </div>\n              <div className=\"space-y-2\">\n                <Label>结束日期 *</Label>\n                <Input\n                  type=\"date\"\n                  value={form.endDate}\n                  onChange={e => setForm({...form, endDate: e.target.value})}\n                  required\n                />\n              </div>\n            </div>\n            <DialogFooter>\n              <Button type=\"button\" variant=\"outline\" onClick={() => setShowDialog(false)}>取消</Button>\n              <Button type=\"submit\" disabled={saving}>\n                {saving ? '提交中...' : (editItem ? '保存' : '创建')}\n              </Button>\n            </DialogFooter>\n          </form>\n        </DialogContent>\n      </Dialog>\n    </div>\n  );\n}\n","file_path":"/workspace/frontend/src/pages/StrategyList.tsx"},"tool_response":"Successfully overwrote file: /workspace/frontend/src/pages/StrategyList.tsx","client":"CLI","version":"2.71.1","generation_id":"b1203ecb8a594bb4901e52f1ff785680","model":"minimax-m2.5","call_id":"call_function_g3iba69qnop3_1"}
