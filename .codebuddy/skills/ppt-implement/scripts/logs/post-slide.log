 }\n    try {\n      setSaving(true);\n      if (editItem) {\n        const { password, ...rest } = form;\n        await apiClient.put(`/users/${editItem.id}`, password ? form : rest);\n      } else {\n        await apiClient.post('/auth/register', form);\n      }\n      setShowDialog(false); resetForm();\n      const res = await apiClient.get('/users?limit=100');\n      if (res.data.success) setList(res.data.data?.items || []);\n    } catch (err: any) { alert(err.response?.data?.error || '操作失败'); }\n    finally { setSaving(false); }\n  };\n\n  const onEdit = (item: UserType) => {\n    setEditItem(item);\n    setForm({ name: item.name, username: item.username, password: '', role: item.role, departmentId: item.departmentId || '', position: item.position || '' });\n    setShowDialog(true);\n  };\n\n  const onDelete = async (id: string) => {\n    if (!confirm('确定删除？')) return;\n    try { await apiClient.delete(`/users/${id}`);\n      const res = await apiClient.get('/users?limit=100');\n      if (res.data.success) setList(res.data.data?.items || []);\n    } catch (err: any) { alert(err.response?.data?.error || '删除失败'); }\n  };\n\n  const resetForm = () => { setEditItem(null); setForm({ name: '', username: '', password: '', role: 'employee', departmentId: '', position: '' }); };\n  const openCreate = () => { resetForm(); setShowDialog(true); };\n  const onDialogChange = (open: boolean) => { setShowDialog(open); if (!open) resetForm(); };\n\n  const roleMap: Record<string, string> = { ceo: 'CEO', executive: '高管', manager: '经理', employee: '员工' };\n\n  return (\n    <div className=\"space-y-6\">\n      <FadeIn>\n        <div className=\"flex items-center justify-between\">\n          <div><h1 className=\"font-bold text-2xl\">人员管理</h1><p className=\"text-muted-foreground text-sm\">员工账号管理</p></div>\n          <Button onClick={openCreate}><Plus className=\"w-4 h-4 mr-2\" />新建员工</Button>\n        </div>\n      </FadeIn>\n      <FadeIn>\n        <Card>\n          <CardContent className=\"pt-6\">\n            {loading ? <div className=\"space-y-3\">{[1,2,3].map(i => <Skeleton key={i} className=\"h-16\" />)}</div>\n            : list.length === 0 ? <div className=\"text-center py-12 text-muted-foreground\">暂无数据</div>\n            : (\n              <Table>\n                <TableHeader><TableRow><TableHead>姓名</TableHead><TableHead>用户名</TableHead><TableHead>角色</TableHead><TableHead>部门</TableHead><TableHead>操作</TableHead></TableRow></TableHeader>\n                <TableBody>\n                  {list.map(item => (\n                    <TableRow key={item.id}>\n                      <TableCell><div className=\"flex items-center gap-2\"><User className=\"w-4 h-4\" /><span className=\"font-medium\">{item.name}</span></div></TableCell>\n                      <TableCell>@{item.username}</TableCell>\n                      <TableCell><Badge variant=\"outline\">{roleMap[item.role] || item.role}</Badge></TableCell>\n                      <TableCell>{item.department?.name || '-'}</TableCell>\n                      <TableCell>\n                        <Button variant=\"ghost\" size=\"sm\" onClick={() => onEdit(item)}><Edit className=\"w-4 h-4\" /></Button>\n                        <Button variant=\"ghost\" size=\"sm\" onClick={() => onDelete(item.id)}><Trash2 className=\"w-4 h-4 text-destructive\" /></Button>\n                      </TableCell>\n                    </TableRow>\n                  ))}\n                </TableBody>\n              </Table>\n            )}\n          </CardContent>\n        </Card>\n      </FadeIn>\n      <Dialog open={showDialog} onOpenChange={onDialogChange}>\n        <DialogContent>\n          <DialogHeader><DialogTitle>{editItem ? '编辑员工' : '新建员工'}</DialogTitle></DialogHeader>\n          <form onSubmit={handleSubmit} className=\"space-y-4\">\n            <div className=\"grid grid-cols-2 gap-4\">\n              <div className=\"space-y-2\"><Label>姓名 *</Label><Input value={form.name} onChange={e => setForm({...form, name: e.target.value})} required /></div>\n              <div className=\"space-y-2\"><Label>用户名 *</Label><Input value={form.username} onChange={e => setForm({...form, username: e.target.value})} required disabled={!!editItem} /></div>\n            </div>\n            <div className=\"space-y-2\"><Label>密码 {editItem && '(留空不修改)'}</Label><Input type=\"password\" value={form.password} onChange={e => setForm({...form, password: e.target.value})} required={!editItem} /></div>\n            <div className=\"grid grid-cols-2 gap-4\">\n              <div className=\"space-y-2\"><Label>角色</Label><Input value={form.role} onChange={e => setForm({...form, role: e.target.value})} /></div>\n              <div className=\"space-y-2\"><Label>职位</Label><Input value={form.position} onChange={e => setForm({...form, position: e.target.value})} /></div>\n            </div>\n            <DialogFooter>\n              <Button type=\"button\" variant=\"outline\" onClick={() => setShowDialog(false)}>取消</Button>\n              <Button type=\"submit\" disabled={saving}>{saving ? '提交中...' : (editItem ? '保存' : '创建')}</Button>\n            </DialogFooter>\n          </form>\n        </DialogContent>\n      </Dialog>\n    </div>\n  );\n}\n","file_path":"/workspace/frontend/src/pages/UserList.tsx"},"tool_response":"Successfully overwrote file: /workspace/frontend/src/pages/UserList.tsx","client":"CLI","version":"2.71.1","generation_id":"ba5ab2cd7e8d46269a801f7375c547fb","model":"glm-5.0","call_id":"019d7b42d32ae3213d8180c40ec2a29d"}
