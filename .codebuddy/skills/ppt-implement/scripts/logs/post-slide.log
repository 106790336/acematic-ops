iClient.put(`/departments/${editItem.id}`, form);\n      } else {\n        await apiClient.post('/departments', form);\n      }\n      setShowDialog(false); resetForm();\n      const res = await apiClient.get('/departments/list');\n      if (res.data.success) setList(res.data.data || []);\n    } catch (err: any) { alert(err.response?.data?.error || '操作失败'); }\n    finally { setSaving(false); }\n  };\n\n  const onEdit = (item: Department) => {\n    setEditItem(item);\n    setForm({ name: item.name, description: item.description || '' });\n    setShowDialog(true);\n  };\n\n  const onDelete = async (id: string) => {\n    if (!confirm('确定删除？')) return;\n    try { await apiClient.delete(`/departments/${id}`);\n      const res = await apiClient.get('/departments/list');\n      if (res.data.success) setList(res.data.data || []);\n    } catch (err: any) { alert(err.response?.data?.error || '删除失败'); }\n  };\n\n  const resetForm = () => { setEditItem(null); setForm({ name: '', description: '' }); };\n  const openCreate = () => { resetForm(); setShowDialog(true); };\n  const onDialogChange = (open: boolean) => { setShowDialog(open); if (!open) resetForm(); };\n\n  return (\n    <div className=\"space-y-6\">\n      <FadeIn>\n        <div className=\"flex items-center justify-between\">\n          <div><h1 className=\"font-bold text-2xl\">部门管理</h1><p className=\"text-muted-foreground text-sm\">组织架构管理</p></div>\n          <Button onClick={openCreate}><Plus className=\"w-4 h-4 mr-2\" />新建部门</Button>\n        </div>\n      </FadeIn>\n      <FadeIn>\n        <Card>\n          <CardContent className=\"pt-6\">\n            {loading ? <div className=\"space-y-3\">{[1,2,3].map(i => <Skeleton key={i} className=\"h-16\" />)}</div>\n            : list.length === 0 ? <div className=\"text-center py-12 text-muted-foreground\">暂无数据</div>\n            : (\n              <Table>\n                <TableHeader><TableRow><TableHead>名称</TableHead><TableHead>描述</TableHead><TableHead>操作</TableHead></TableRow></TableHeader>\n                <TableBody>\n                  {list.map(item => (\n                    <TableRow key={item.id}>\n                      <TableCell><div className=\"flex items-center gap-2\"><Building2 className=\"w-4 h-4 text-blue-500\" /><span className=\"font-medium\">{item.name}</span></div></TableCell>\n                      <TableCell><span className=\"text-muted-foreground\">{item.description || '-'}</span></TableCell>\n                      <TableCell>\n                        <Button variant=\"ghost\" size=\"sm\" onClick={() => onEdit(item)}><Edit className=\"w-4 h-4\" /></Button>\n                        <Button variant=\"ghost\" size=\"sm\" onClick={() => onDelete(item.id)}><Trash2 className=\"w-4 h-4 text-destructive\" /></Button>\n                      </TableCell>\n                    </TableRow>\n                  ))}\n                </TableBody>\n              </Table>\n            )}\n          </CardContent>\n        </Card>\n      </FadeIn>\n      <Dialog open={showDialog} onOpenChange={onDialogChange}>\n        <DialogContent>\n          <DialogHeader><DialogTitle>{editItem ? '编辑部门' : '新建部门'}</DialogTitle></DialogHeader>\n          <form onSubmit={handleSubmit} className=\"space-y-4\">\n            <div className=\"space-y-2\"><Label>部门名称 *</Label><Input value={form.name} onChange={e => setForm({...form, name: e.target.value})} required /></div>\n            <div className=\"space-y-2\"><Label>描述</Label><Textarea value={form.description} onChange={e => setForm({...form, description: e.target.value})} /></div>\n            <DialogFooter>\n              <Button type=\"button\" variant=\"outline\" onClick={() => setShowDialog(false)}>取消</Button>\n              <Button type=\"submit\" disabled={saving}>{saving ? '提交中...' : (editItem ? '保存' : '创建')}</Button>\n            </DialogFooter>\n          </form>\n        </DialogContent>\n      </Dialog>\n    </div>\n  );\n}\n","file_path":"/workspace/frontend/src/pages/DepartmentList.tsx"},"tool_response":"Successfully overwrote file: /workspace/frontend/src/pages/DepartmentList.tsx","client":"CLI","version":"2.71.1","generation_id":"d23a636f3dc14c00a4871991c4e382bc","model":"glm-5.0","call_id":"019d7b424c75bc241f8298b788898038"}
