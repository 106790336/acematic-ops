\n    setLoading(true);\n    try {\n      const response = await apiClient.get<ApiResponse<User>>('/auth/profile');\n      \n      if (response.data.success && response.data.data) {\n        const user = response.data.data;\n        localStorage.setItem(USER_KEY, JSON.stringify(user));\n        setUser(user);\n        return user;\n      }\n      return null;\n    } catch (err) {\n      setError(getErrorMessage(err));\n      return null;\n    } finally {\n      setLoading(false);\n    }\n  }, []);\n\n  const isAuthenticated = !!user;\n\n  return {\n    user,\n    loading,\n    error,\n    login,\n    logout,\n    getProfile,\n    isAuthenticated,\n    setError,\n  };\n}\n","file_path":"/workspace/frontend/src/hooks/use-auth.ts"},"tool_response":"Successfully created and wrote to new file: /workspace/frontend/src/hooks/use-auth.ts","client":"CLI","version":"2.71.1","generation_id":"c9f66c5ceebe4c81857f9d45a54f54cd","model":"glm-5.0","call_id":"019d54742597f57f3d02a809ae4af683"}
