ing(true);\n    try {\n      const response = await apiClient.get<ApiResponse<PaginatedResponse<WeeklyReport>>>('/weekly-reports');\n      if (response.data.success && response.data.data) {\n        setReports(response.data.data.items);\n      }\n    } catch (err) {\n      console.error('Fetch reports error:', err);\n    } finally {\n      setLoading(false);\n    }\n  };\n\n  const fetchDepartments = async () => {\n    try {\n      const response = await apiClient.get<ApiResponse<Department[]>>('/departments/list');\n      if (response.data.success && response.data.data) {\n        setDepartments(response.data.data);\n      }\n    } catch (err) {\n      console.error('Fetch departments error:', err);\n    }\n  };\n\n  const handleSubmit = async (e: React.FormEvent) => {\n    e.preventDefault();\n    try {\n      setSubmitting(true);\n      if (editingReport) {\n        await apiClient.put(`/weekly-reports/${editingReport.id}`, formData);\n      } else {\n        await apiClient.post('/weekly-reports', formData);\n      }\n      setDialogOpen(false);\n      resetForm();\n      fetchReports();\n    } catch (err: any) {\n      alert(err.response?.data?.error || getErrorMessage(err));\n    } finally {\n      setSubmitting(false);\n    }\n  };\n\n  const handleEdit = (report: WeeklyReport) => {\n    setEditingReport(report);\n    setFormData({\n      weekDate: report.weekDate.split('T')[0],\n      departmentId: report.departmentId,\n      completedTasks: report.completedTasks,\n      keyData: report.keyData,\n      nextWeekPlan: report.nextWeekPlan,\n      coordinationNeed: report.coordinationNeed || '',\n      selfEvaluation: report.selfEvaluation,\n    });\n    setDialogOpen(true);\n  };\n\n  const handleDelete = async (id: string) => {\n    if (confirm('确定要删除这条周报吗？')) {\n      try {\n        await apiClient.delete(`/weekly-reports/${id}`);\n        fetchReports();\n      } catch (err: any) {\n        alert(err.response?.data?.error || getErrorMessage(err));\n      }\n    }\n  };\n\n  const resetForm = () => {\n    setFormData({\n      weekDate: '',\n      departmentId: '',\n      completedTasks: '',\n      keyData: '',\n      nextWeekPlan: '',\n      coordinationNeed: '',\n      selfEvaluation: '达成',\n    });\n    setEditingReport(null);\n  };\n\n  const evaluationColors: Record<string, string> = {\n    '超预期': 'success',\n    '达成': 'default',\n    '未达成': 'destructive',\n  };\n\n  return (\n    <div className=\"space-y-6\">\n      <FadeIn>\n        <div className=\"flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4\">\n          <div>\n            <h1 className=\"font-bold\" style={{ fontSize: 'var(--font-size-headline)' }}>\n              周报管理\n            </h1>\n            <p className=\"text-muted-foreground\" style={{ fontSize: 'var(--font-size-label)' }}>\n              各中心每周工作汇报管理\n            </p>\n          </div>\n          <Button onClick={() => { resetForm(); setDialogOpen(true); }}>\n            <Plus className=\"w-4 h-4 mr-2\" />\n            提交周报\n          </Button>\n        </div>\n      </FadeIn>\n\n      <FadeIn>\n        <Card>\n          <CardContent className=\"pt-6\">\n            {loading ? (\n              <div className=\"space-y-4\">\n                {[1, 2, 3].map((i) => (\n                  <Skeleton key={i} className=\"h-32\" />\n                ))}\n              </div>\n            ) : reports.length === 0 ? (\n              <div className=\"text-center py-12\">\n                <FileText className=\"w-16 h-16 mx-auto text-muted-foreground mb-4\" />\n                <p className=\"text-muted-foreground\">暂无周报记录</p>\n                <Button className=\"mt-4\" onClick={() => { resetForm(); setDialogOpen(true); }}>\n                  提交第一份周报\n                </Button>\n              </div>\n            ) : (\n              <div className=\"space-y-4\">\n                {reports.map((report) => (\n                  <div\n                    key={report.id}\n                    className=\"p-4 rounded-lg border\"\n                    style={{ borderColor: 'var(--border)' }}\n                  >\n                    <div className=\"flex items-start justify-between mb-3\">\n                      <div className=\"flex items-center gap-3\">\n                        <div className=\"p-2 rounded-lg\" style={{ background: 'var(--muted)' }}>\n                          <FileText className=\"w-5 h-5\" style={{ color: 'oklch(0.42 0.19 250)' }} />\n                        </div>\n                        <div>\n                          <div className=\"font-medium\">{report.department?.name || '未知部门'}</div>\n                          <div className=\"text-sm text-muted-foreground\">\n                            {new Date(report.weekDate).toLocaleDateString('zh-CN')} 周\n                          </div>\n                        </div>\n                      </div>\n                      <div className=\"flex items-center gap-2\">\n                        <Badge variant={evaluationColors[report.selfEvaluation] as any}>\n                          {report.selfEvaluation}\n                        </Badge>\n                        <Button variant=\"ghost\" size=\"sm\" onClick={() => handleEdit(report)}>\n                          <Edit className=\"w-4 h-4\" />\n                        </Button>\n                        <Button variant=\"ghost\" size=\"sm\" onClick={() => handleDelete(report.id)}>\n                          <Trash2 className=\"w-4 h-4 text-destructive\" />\n                        </Button>\n                      </div>\n                    </div>\n\n                    <div className=\"space-y-3 text-sm\">\n                      <div>\n                        <div className=\"font-medium mb-1\">本周完成：</div>\n                        <div className=\"text-muted-foreground whitespace-pre-wrap\">{report.completedTasks}</div>\n                      </div>\n                      <div>\n                        <div className=\"font-medium mb-1\">关键数据：</div>\n                        <div className=\"text-muted-foreground whitespace-pre-wrap\">{report.keyData}</div>\n                      </div>\n                      <div>\n                        <div className=\"font-medium mb-1\">下周计划：</div>\n                        <div className=\"text-muted-foreground whitespace-pre-wrap\">{report.nextWeekPlan}</div>\n                      </div>\n                      {report.coordinationNeed && (\n                        <div className=\"p-3 rounded-lg\" style={{ background: 'oklch(0.95 0.03 25)' }}>\n                          <div className=\"font-medium mb-1 flex items-center gap-2\">\n                            <AlertCircle className=\"w-4 h-4\" style={{ color: 'oklch(0.55 0.22 25)' }} />\n                            需要协调：\n                          </div>\n                          <div className=\"whitespace-pre-wrap\">{report.coordinationNeed}</div>\n                        </div>\n                      )}\n                    </div>\n\n                    <div className=\"mt-3 pt-3 border-t flex items-center justify-between text-sm text-muted-foreground\">\n                      <div className=\"flex items-center gap-2\">\n                        <User className=\"w-3 h-3\" />\n                        提交人：{report.submitter?.name || '未知'}\n                      </div>\n                      <div className=\"flex items-center gap-1\">\n                        <Calendar className=\"w-3 h-3\" />\n                        {new Date(report.submitTime).toLocaleDateString('zh-CN')}\n                      </div>\n                    </div>\n                  </div>\n                ))}\n              </div>\n            )}\n          </CardContent>\n        </Card>\n      </FadeIn>\n\n      {/* 提交/编辑周报对话框 */}\n      <Dialog open={dialogOpen} onOpenChange={setDialogOpen}>\n        <DialogContent className=\"max-w-2xl max-h-[90vh] overflow-y-auto\">\n          <DialogHeader>\n            <DialogTitle>{editingReport ? '编辑周报' : '提交周报'}</DialogTitle>\n          </DialogHeader>\n          <form onSubmit={handleSubmit} className=\"space-y-4\">\n            <div className=\"grid grid-cols-2 gap-4\">\n              <div className=\"space-y-2\">\n                <Label>周报日期（周一）</Label>\n                <Input\n                  type=\"date\"\n                  value={formData.weekDate}\n                  onChange={(e) => setFormData({ ...formData, weekDate: e.target.value })}\n                  required\n                />\n              </div>\n              <div className=\"space-y-2\">\n                <Label>所属部门</Label>\n                <Select value={formData.departmentId} onValueChange={(v) => setFormData({ ...formData, departmentId: v })}>\n                  <SelectTrigger><SelectValue placeholder=\"选择部门\" /></SelectTrigger>\n                  <SelectContent>\n                    {departments.map((dept) => (\n                      <SelectItem key={dept.id} value={dept.id}>{dept.name}</SelectItem>\n                    ))}\n                  </SelectContent>\n                </Select>\n              </div>\n            </div>\n            <div className=\"space-y-2\">\n              <Label>本周完成事项 *</Label>\n              <Textarea\n                value={formData.completedTasks}\n                onChange={(e) => setFormData({ ...formData, completedTasks: e.target.value })}\n                placeholder=\"对照月度计划填写本周完成的工作\"\n                rows={4}\n                required\n              />\n            </div>\n            <div className=\"space-y-2\">\n              <Label>关键数据 *</Label>\n              <Textarea\n                value={formData.keyData}\n                onChange={(e) => setFormData({ ...formData, keyData: e.target.value })}\n                placeholder=\"格式：指标名:数值（如：销售额:380万，交付率:96%）\"\n                rows={3}\n                required\n              />\n            </div>\n            <div className=\"space-y-2\">\n              <Label>下周重点事项 *</Label>\n              <Textarea\n                value={formData.nextWeekPlan}\n                onChange={(e) => setFormData({ ...formData, nextWeekPlan: e.target.value })}\n                placeholder=\"3-5项下周重点工作\"\n                rows={3}\n                required\n              />\n            </div>\n            <div className=\"space-y-2\">\n              <Label>需要协调问题（可选）</Label>\n              <Textarea\n                value={formData.coordinationNeed}\n                onChange={(e) => setFormData({ ...formData, coordinationNeed: e.target.value })}\n                placeholder=\"具体问题+期望支持\"\n                rows={2}\n              />\n            </div>\n            <div className=\"space-y-2\">\n              <Label>自我评价</Label>\n              <Select value={formData.selfEvaluation} onValueChange={(v) => setFormData({ ...formData, selfEvaluation: v })}>\n                <SelectTrigger><SelectValue /></SelectTrigger>\n                <SelectContent>\n                  <SelectItem value=\"超预期\">超预期</SelectItem>\n                  <SelectItem value=\"达成\">达成</SelectItem>\n                  <SelectItem value=\"未达成\">未达成</SelectItem>\n                </SelectContent>\n              </Select>\n            </div>\n            <DialogFooter>\n              <Button type=\"button\" variant=\"outline\" onClick={() => setDialogOpen(false)}>取消</Button>\n              <Button type=\"submit\" disabled={submitting}>{submitting ? '提交中...' : (editingReport ? '保存' : '提交')}</Button>\n            </DialogFooter>\n          </form>\n        </DialogContent>\n      </Dialog>\n    </div>\n  );\n}\n","file_path":"/workspace/frontend/src/pages/WeeklyReportList.tsx"},"tool_response":"Successfully overwrote file: /workspace/frontend/src/pages/WeeklyReportList.tsx","client":"CLI","version":"2.71.1","generation_id":"032034b915624b5689b31b0d402215cf","model":"glm-5.0-turbo","call_id":"call_a525fc043b68444c85ce1a9a"}
