fault(now())\n  updatedAt        DateTime @updatedAt\n\n  department Department @relation(fields: [departmentId], references: [id])\n  submitter  User       @relation(\"ReportSubmitter\", fields: [submitterId], references: [id])\n}\n\n// 问题清单表\nmodel Issue {\n  id              String   @id @default(cuid())\n  issueNumber     String   @unique // P2026040001\n  source          String   // 周报/会议/其他\n  discoveryDate   DateTime\n  departmentId    String\n  description     String\n  issueType       String   // 质量问题/交付问题/协作问题/其他\n  severity        String   @default(\"中\") // 高/中/低\n  responsibleId   String?\n  planCompleteDate DateTime?\n  actualCompleteDate DateTime?\n  status          String   @default(\"待处理\") // 待处理/处理中/已解决/挂起\n  solution        String?\n  verifyResult    String?\n  createdAt       DateTime @default(now())\n  updatedAt       DateTime @updatedAt\n\n  department Department @relation(fields: [departmentId], references: [id])\n  responsible User?    @relation(\"IssueResponsible\", fields: [responsibleId], references: [id])\n}\n\n// 会议纪要表\nmodel Meeting {\n  id           String   @id @default(cuid())\n  meetingName  String\n  meetingType  String   // 周例会/月度分析会/专题会\n  meetingTime  DateTime\n  location     String\n  hostId       String\n  recorderId   String\n  content      String\n  resolutions  String\n  nextMeetingDate DateTime?\n  createdAt    DateTime @default(now())\n  updatedAt    DateTime @updatedAt\n\n  host     User      @relation(\"MeetingHost\", fields: [hostId], references: [id])\n  recorder User      @relation(\"MeetingRecorder\", fields: [recorderId], references: [id])\n  attendees MeetingAttendee[]\n}\n\n// 会议参会人员关联表\nmodel MeetingAttendee {\n  id        String   @id @default(cuid())\n  meetingId String\n  userId    String\n  createdAt DateTime @default(now())\n\n  meeting Meeting @relation(fields: [meetingId], references: [id])\n  user    User    @relation(fields: [userId], references: [id])\n}\n\n// 月度经营数据表\nmodel MonthlyData {\n  id             String   @id @default(cuid())\n  yearMonth      String   // 2026-04\n  departmentId   String\n  indicatorName  String\n  targetValue    Float\n  actualValue    Float\n  achievement    Float    @default(0) // 达成率\n  lastYearValue  Float?\n  lastMonthValue Float?\n  yearOverYear   Float?   // 同比增长\n  monthOverMonth Float?   // 环比增长\n  deviation      String?  // 偏差原因\n  improvement    String?  // 改进措施\n  createdAt      DateTime @default(now())\n  updatedAt      DateTime @updatedAt\n\n  department Department @relation(fields: [departmentId], references: [id])\n}\n\n// 改进措施表\nmodel ImprovementMeasure {\n  id              String   @id @default(cuid())\n  measureNumber   String   @unique\n  issueId         String?\n  description     String\n  responsibleId   String\n  planCompleteDate DateTime\n  progress        Int      @default(0)\n  effectVerify    String?\n  isEffective     String   @default(\"待验证\") // 有效/部分有效/无效/待验证\n  createdAt       DateTime @default(now())\n  updatedAt       DateTime @updatedAt\n\n  issue       Issue? @relation(fields: [issueId], references: [id])\n  responsible User   @relation(\"MeasureResponsible\", fields: [responsibleId], references: [id])\n}"},"tool_response":"Successfully edited file: /workspace/backend/prisma/schema.prisma","client":"CLI","version":"2.71.1","generation_id":"de91ab3180fa44e6b6f439b6b42c878e","model":"glm-5.0","call_id":"019d708606b8dc4b5bf1ba33b8ae3ba6"}
