[2026-04-09 08:34:53] [DEBUG] [PPT PostToolUse Hook] stdin 数据: {"session_id":"2040121509614309376","transcript_path":"/root/.codebuddy/projects/workspace/2040121509614309376.jsonl","cwd":"/workspace","hook_event_name":"PostToolUse","tool_name":"Write","tool_input":{"content":"import { useState, useEffect } from 'react';\nimport { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';\nimport { Progress } from '@/components/ui/progress';\nimport { Badge } from '@/components/ui/badge';\nimport { api } from '@/lib/api';\nimport { Target, AlertTriangle, TrendingUp, Users, CheckCircle } from 'lucide-react';\n\ninterface AlignmentStats {\n  totalTasks: number;\n  alignedTasks: number;\n  overallRate: number;\n  departmentAlignment: Array<{\n    departmentId: string;\n    total: number;\n    aligned: number;\n    rate: number;\n  }>;\n  warnings: Array<{ departmentId: string; rate: number; level: string }>;\n  reminders: Array<{ departmentId: string; rate: number; level: string }>;\n}\n\nexport function AlignmentStatsCard() {\n  const [stats, setStats] = useState<AlignmentStats | null>(null);\n  const [loading, setLoading] = useState(true);\n\n  useEffect(() => {\n    fetchStats();\n  }, []);\n\n  const fetchStats = async () => {\n    try {\n      const response = await api.get('/tasks-v2/stats/alignment');\n      if (response.data.success) {\n        setStats(response.data.data);\n      }\n    } catch (error) {\n      console.error('Failed to fetch alignment stats:', error);\n    } finally {\n      setLoading(false);\n    }\n  };\n\n  const getRateColor = (rate: number) => {\n    if (rate >= 90) return 'text-green-600';\n    if (rate >= 70) return 'text-yellow-600';\n    return 'text-red-600';\n  };\n\n  const getRateBg = (rate: number) => {\n    if (rate >= 90) return 'bg-green-500';\n    if (rate >= 70) return 'bg-yellow-500';\n    return 'bg-red-500';\n  };\n\n  if (loading) {\n    return (\n      <Card>\n        <CardHeader className=\"pb-2\">\n          <CardTitle className=\"text-base flex items-center gap-2\">\n            <Target className=\"w-4 h-4\" />\n            战略对齐度\n          </CardTitle>\n        </CardHeader>\n        <CardContent>\n          <div className=\"text-muted-foreground text-sm\">加载中...</div>\n        </CardContent>\n      </Card>\n    );\n  }\n\n  if (!stats) {\n    return null;\n  }\n\n  return (\n    <Card>\n      <CardHeader className=\"pb-2\">\n        <CardTitle className=\"text-base flex items-center gap-2\">\n          <Target className=\"w-4 h-4\" />\n          战略对齐度\n        </CardTitle>\n      </CardHeader>\n      <CardContent>\n        {/* 整体对齐度 */}\n        <div className=\"mb-4\">\n          <div className=\"flex items-center justify-between mb-2\">\n            <span className=\"text-sm text-muted-foreground\">公司整体</span>\n            <span className={`text-2xl font-bold ${getRateColor(stats.overallRate)}`}>\n              {stats.overallRate}%\n            </span>\n          </div>\n          <Progress \n            value={stats.overallRate} \n            className=\"h-2\"\n          />\n          <div className=\"flex items-center justify-between mt-1 text-xs text-muted-foreground\">\n            <span>已对齐 {stats.alignedTasks} 项</span>\n            <span>共 {stats.totalTasks} 项任务</span>\n          </div>\n        </div>\n\n        {/* 部门对齐度 */}\n        {stats.departmentAlignment.length > 0 && (\n          <div className=\"space-y-2 mb-4\">\n            <div className=\"text-xs font-medium text-muted-foreground\">部门对齐度</div>\n            {stats.departmentAlignment.slice(0, 4).map((dept) => (\n              <div key={dept.departmentId} className=\"flex items-center justify-between\">\n                <span className=\"text-sm\">\n                  {dept.departmentId === 'unknown' ? '未分配部门' : `部门 ${dept.departmentId.slice(0, 6)}`}\n                </span>\n                <div className=\"flex items-center gap-2\">\n                  <Progress value={dept.rate} className=\"w-16 h-1.5\" />\n                  <span className={`text-xs font-medium ${getRateColor(dept.rate)}`}>\n                    {dept.rate}%\n                  </span>\n                </div>\n              </div>\n            ))}\n          </div>\n        )}\n\n        {/* 预警信息 */}\n        {(stats.warnings.length > 0 || stats.reminders.length > 0) && (\n          <div className=\"space-y-2\">\n            <div className=\"text-xs font-medium text-muted-foreground flex items-center gap-1\">\n              <AlertTriangle className=\"w-3 h-3\" />\n              预警提醒\n            </div>\n            <div className=\"space-y-1\">\n              {stats.warnings.slice(0, 2).map((w, i) => (\n                <div key={i} className=\"flex items-center gap-2 text-xs p-2 rounded bg-red-50 text-red-700\">\n                  <AlertTriangle className=\"w-3 h-3\" />\n                  <span>某部门对齐度仅 {w.rate}%</span>\n                </div>\n              ))}\n              {stats.reminders.slice(0, 2).map((r, i) => (\n                <div key={i} className=\"flex items-center gap-2 text-xs p-2 rounded bg-yellow-50 text-yellow-700\">\n                  <TrendingUp className=\"w-3 h-3\" />\n                  <span>某部门对齐度 {r.rate}%，需改进</span>\n                </div>\n              ))}\n            </div>\n          </div>\n        )}\n\n        {/* 图例 */}\n        <div className=\"flex items-center gap-4 mt-4 pt-3 border-t text-xs text-muted-foreground\">\n          <div className=\"flex items-center gap-1\">\n            <div className=\"w-2 h-2 rounded-full bg-green-500\" />\n            <span>≥90% 正常</span>\n          </div>\n          <div className=\"flex items-center gap-1\">\n            <div className=\"w-2 h-2 rounded-full bg-yellow-500\" />\n            <span>70-90% 提醒</span>\n          </div>\n          <div className=\"flex items-center gap-1\">\n            <div className=\"w-2 h-2 rounded-full bg-red-500\" />\n            <span>&lt;70% 预警</span>\n          </div>\n        </div>\n      </CardContent>\n    </Card>\n  );\n}\n","file_path":"/workspace/frontend/src/components/AlignmentStatsCard.tsx"},"tool_response":"Successfully created and wrote to new file: /workspace/frontend/src/components/AlignmentStatsCard.tsx","client":"CLI","version":"2.71.1","generation_id":"efca8b42b3214fb881eb579549671be1","model":"glm-5.0","call_id":"019d7160d2d877cc5bb58c65bb201a4f"}
