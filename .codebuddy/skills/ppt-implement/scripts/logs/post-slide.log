ment[]\n  department   Department?  @relation(fields: [departmentId], references: [id])\n  owner        User         @relation(\"PlanOwner\", fields: [ownerId], references: [id])\n  strategy     Strategy?    @relation(fields: [strategyId], references: [id])\n  tasks        Task[]\n}","replace_all":false},"tool_response":"Successfully edited file: /workspace/backend/prisma/schema.prisma","client":"CLI","version":"2.71.1","generation_id":"e1a3adbfc4f7406cba5665ff0d0c246c","model":"glm-5.0","call_id":"019d8e9034ddb30c856454fa727fb0d7"}
