    <SelectItem value=\"\">全部</SelectItem>\n                <SelectItem value=\"urgent\">紧急</SelectItem>\n                <SelectItem value=\"high\">高</SelectItem>\n                <SelectItem value=\"medium\">中</SelectItem>\n                <SelectItem value=\"low\">低</SelectItem>\n              </SelectContent>\n            </Select>\n          </div>\n        </CardContent>\n      </Card>\n\n      <Tabs value={activeTab} onValueChange={setActiveTab}>\n        <TabsList>\n          <TabsTrigger value=\"all\">全部任务</TabsTrigger>\n          <TabsTrigger value=\"my\">我的任务</TabsTrigger>\n        </TabsList>\n\n        <TabsContent value={activeTab} className=\"mt-4\">\n          <Card>\n            <CardContent className=\"p-0\">\n              {error && (\n                <div className=\"p-4 text-red-500 bg-red-50\">{error}</div>\n              )}\n              {loading ? (\n                <div className=\"p-8 text-center text-muted-foreground\">加载中...</div>\n              ) : tasks.length === 0 ? (\n                <div className=\"p-8 text-center text-muted-foreground\">暂无任务</div>\n              ) : (\n                <Table>\n                  <TableHeader>\n                    <TableRow>\n                      <TableHead>任务编号</TableHead>\n                      <TableHead>任务名称</TableHead>\n                      <TableHead>来源</TableHead>\n                      <TableHead>负责人</TableHead>\n                      <TableHead>截止日期</TableHead>\n                      <TableHead>优先级</TableHead>\n                      <TableHead>战略对齐</TableHead>\n                      <TableHead>状态</TableHead>\n                      <TableHead>操作</TableHead>\n                    </TableRow>\n                  </TableHeader>\n                  <TableBody>\n                    {tasks.map((task) => (\n                      <TableRow key={task.id} className=\"cursor-pointer hover:bg-muted/50\"\n                        onClick={() => { setSelectedTask(task); setShowDetailDialog(true); }}>\n                        <TableCell className=\"font-mono text-sm\">{task.taskNumber}</TableCell>\n                        <TableCell>\n                          <div>\n                            <div className=\"font-medium\">{task.title}</div>\n                            {task.sourceRef && (\n                              <div className=\"text-xs text-muted-foreground\">{task.sourceRef}</div>\n                            )}\n                          </div>\n                        </TableCell>\n                        <TableCell>\n                          <Badge variant=\"outline\">{sourceTypeLabels[task.sourceType]}</Badge>\n                        </TableCell>\n                        <TableCell>{task.assignee?.name || '未分配'}</TableCell>\n                        <TableCell>\n                          <div className=\"flex items-center gap-1\">\n                            <Clock className=\"w-3 h-3 text-muted-foreground\" />\n                            {new Date(task.dueDate).toLocaleDateString()}\n                          </div>\n                        </TableCell>\n                        <TableCell>\n                          <Badge className={priorityLabels[task.priority]?.color}>\n                            {priorityLabels[task.priority]?.label}\n                          </Badge>\n                        </TableCell>\n                        <TableCell>\n                          {task.strategicAlignment ? (\n                            <div className=\"flex items-center gap-1 text-green-600\">\n                              <Target className=\"w-4 h-4\" />\n                              <span className=\"text-xs\">已对齐</span>\n                            </div>\n                          ) : (\n                            <div className=\"flex items-center gap-1 text-orange-500\">\n                              <AlertTriangle className=\"w-4 h-4\" />\n                              <span className=\"text-xs\">未对齐</span>\n                            </div>\n                          )}\n                        </TableCell>\n                        <TableCell>\n                          <Badge className={statusLabels[task.status]?.color}>\n                            {statusLabels[task.status]?.label}\n                          </Badge>\n                        </TableCell>\n                        <TableCell>\n                          <div className=\"flex items-center gap-2\" onClick={(e) => e.stopPropagation()}>\n                            {task.status === 'pending' && task.sourceType === 'assigned' && (\n                              <Button size=\"sm\" variant=\"outline\" onClick={() => handleConfirmTask(task.id)}>\n                                <CheckCircle className=\"w-4 h-4 mr-1\" />\n                                确认\n                              </Button>\n                            )}\n                            {task.status === 'confirmed' && (\n                              <Button size=\"sm\" variant=\"outline\" onClick={() => handleStartTask(task.id)}>\n                                <Play className=\"w-4 h-4 mr-1\" />\n                                开始\n                              </Button>\n                            )}\n                            {task.status === 'pending' && task.sourceType === 'self_initiated' && (\n                              <>\n                                <Button size=\"sm\" onClick={() => handleApproveTask(task.id, true)}>通过</Button>\n                                <Button size=\"sm\" variant=\"destructive\" onClick={() => handleApproveTask(task.id, false)}>驳回</Button>\n                              </>\n                            )}\n                          </div>\n                        </TableCell>\n                      </TableRow>\n                    ))}\n                  </TableBody>\n                </Table>\n              )}\n            </CardContent>\n          </Card>\n        </TabsContent>\n      </Tabs>\n\n      <Dialog open={showCreateDialog} onOpenChange={setShowCreateDialog}>\n        <DialogContent className=\"max-w-2xl\">\n          <DialogHeader>\n            <DialogTitle>新建任务</DialogTitle>\n          </DialogHeader>\n          <div className=\"grid gap-4 py-4\">\n            <div className=\"grid gap-2\">\n              <Label>任务标题 *</Label>\n              <Input\n                value={newTask.title}\n                onChange={(e) => setNewTask({ ...newTask, title: e.target.value })}\n                placeholder=\"输入任务标题\"\n              />\n            </div>\n            <div className=\"grid gap-2\">\n              <Label>任务描述</Label>\n              <Textarea\n                value={newTask.description}\n                onChange={(e) => setNewTask({ ...newTask, description: e.target.value })}\n                placeholder=\"输入任务描述\"\n              />\n            </div>\n            <div className=\"grid grid-cols-2 gap-4\">\n              <div className=\"grid gap-2\">\n                <Label>来源类型</Label>\n                <Select\n                  value={newTask.sourceType}\n                  onValueChange={(value) => setNewTask({ ...newTask, sourceType: value })}\n                >\n                  <SelectTrigger>\n                    <SelectValue />\n                  </SelectTrigger>\n                  <SelectContent>\n                    <SelectItem value=\"assigned\">上级分配</SelectItem>\n                    <SelectItem value=\"self_initiated\">主动提交</SelectItem>\n                    <SelectItem value=\"plan_decomposition\">计划分解</SelectItem>\n                  </SelectContent>\n                </Select>\n              </div>\n              <div className=\"grid gap-2\">\n                <Label>负责人</Label>\n                <Select\n                  value={newTask.assigneeId}\n                  onValueChange={(value) => setNewTask({ ...newTask, assigneeId: value })}\n                >\n                  <SelectTrigger>\n                    <SelectValue placeholder=\"选择负责人\" />\n                  </SelectTrigger>\n                  <SelectContent>\n                    {users.map((u) => (\n                      <SelectItem key={u.id} value={u.id}>{u.name}</SelectItem>\n                    ))}\n                  </SelectContent>\n                </Select>\n              </div>\n            </div>\n            <div className=\"grid grid-cols-2 gap-4\">\n              <div className=\"grid gap-2\">\n                <Label>截止日期 *</Label>\n                <Input\n                  type=\"date\"\n                  value={newTask.dueDate}\n                  onChange={(e) => setNewTask({ ...newTask, dueDate: e.target.value })}\n                />\n              </div>\n              <div className=\"grid gap-2\">\n                <Label>优先级</Label>\n                <Select\n                  value={newTask.priority}\n                  onValueChange={(value) => setNewTask({ ...newTask, priority: value })}\n                >\n                  <SelectTrigger>\n                    <SelectValue />\n                  </SelectTrigger>\n                  <SelectContent>\n                    <SelectItem value=\"low\">低</SelectItem>\n                    <SelectItem value=\"medium\">中</SelectItem>\n                    <SelectItem value=\"high\">高</SelectItem>\n                    <SelectItem value=\"urgent\">紧急</SelectItem>\n                  </SelectContent>\n                </Select>\n              </div>\n            </div>\n            <div className=\"flex items-center gap-4 pt-2\">\n              <div className=\"flex items-center gap-2\">\n                <input\n                  type=\"checkbox\"\n                  id=\"strategicAlignment\"\n                  checked={newTask.strategicAlignment}\n                  onChange={(e) => setNewTask({ ...newTask, strategicAlignment: e.target.checked })}\n                  className=\"w-4 h-4\"\n                />\n                <Label htmlFor=\"strategicAlignment\" className=\"flex items-center gap-1 cursor-pointer\">\n                  <Target className=\"w-4 h-4\" />\n                  战略对齐\n                </Label>\n              </div>\n              {newTask.strategicAlignment && (\n                <Input\n                  value={newTask.alignmentTarget}\n                  onChange={(e) => setNewTask({ ...newTask, alignmentTarget: e.target.value })}\n                  placeholder=\"对齐目标说明\"\n                  className=\"flex-1\"\n                />\n              )}\n            </div>\n          </div>\n          <DialogFooter>\n            <Button variant=\"outline\" onClick={() => setShowCreateDialog(false)}>取消</Button>\n            <Button onClick={handleCreateTask}>创建任务</Button>\n          </DialogFooter>\n        </DialogContent>\n      </Dialog>\n\n      <Dialog open={showDetailDialog} onOpenChange={setShowDetailDialog}>\n        <DialogContent className=\"max-w-2xl\">\n          <DialogHeader>\n            <DialogTitle>任务详情</DialogTitle>\n          </DialogHeader>\n          {selectedTask && (\n            <div className=\"space-y-4\">\n              <div className=\"flex items-center justify-between\">\n                <div>\n                  <div className=\"text-sm text-muted-foreground\">{selectedTask.taskNumber}</div>\n                  <div className=\"text-xl font-semibold\">{selectedTask.title}</div>\n                </div>\n                <Badge className={statusLabels[selectedTask.status]?.color}>\n                  {statusLabels[selectedTask.status]?.label}\n                </Badge>\n              </div>\n              \n              {selectedTask.description && (\n                <div className=\"p-4 rounded-lg bg-muted/50\">\n                  <div className=\"text-sm text-muted-foreground mb-1\">任务描述</div>\n                  <div>{selectedTask.description}</div>\n                </div>\n              )}\n\n              <div className=\"grid grid-cols-2 gap-4\">\n                <div className=\"p-4 rounded-lg border\">\n                  