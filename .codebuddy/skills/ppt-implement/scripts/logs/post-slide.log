[2026-04-09 08:29:45] [DEBUG] [PPT PostToolUse Hook] stdin 数据: {"session_id":"2040121509614309376","transcript_path":"/root/.codebuddy/projects/workspace/2040121509614309376.jsonl","cwd":"/workspace","hook_event_name":"PostToolUse","tool_name":"Write","tool_input":{"content":"// Prisma Schema for CEO Management System\n// PostgreSQL database with TypeScript ORM\n\ngenerator client {\n  provider = \"prisma-client-js\"\n}\n\ndatasource db {\n  provider = \"postgresql\"\n  url      = env(\"DATABASE_URL\")\n}\n\n// 用户表\nmodel User {\n  id          String   @id @default(cuid())\n  username    String   @unique\n  password    String\n  name        String\n  role        String   @default(\"employee\") // ceo, executive, manager, employee\n  departmentId String?\n  position    String?\n  avatar      String?\n  email       String?  @unique\n  phone       String?\n  isActive    Boolean  @default(true)\n  lastLoginAt DateTime?\n  createdAt   DateTime @default(now())\n  updatedAt   DateTime @updatedAt\n\n  department         Department?           @relation(fields: [departmentId], references: [id])\n  plans              Plan[]                @relation(\"PlanOwner\")\n  tasks              Task[]                @relation(\"TaskAssignee\")\n  assignedTasks      Task[]                @relation(\"TaskAssigner\")\n  approvedTasks      Task[]                @relation(\"TaskApprover\")\n  assessments        Assessment[]          @relation(\"AssessmentUser\")\n  assessedBy         Assessment[]          @relation(\"AssessmentAssessor\")\n  createdStrategies  Strategy[]            @relation(\"StrategyCreator\")\n  submittedReports   WeeklyReport[]        @relation(\"ReportSubmitter\")\n  responsibleIssues  Issue[]               @relation(\"IssueResponsible\")\n  hostedMeetings     Meeting[]             @relation(\"MeetingHost\")\n  recordedMeetings   Meeting[]             @relation(\"MeetingRecorder\")\n  meetingAttendees   MeetingAttendee[]\n  responsibleMeasures ImprovementMeasure[] @relation(\"MeasureResponsible\")\n  submittedMonthlyPlans MonthlyPlan[]      @relation(\"PlanSubmitter\")\n  submittedWeeklyPlans WeeklyPlan[]        @relation(\"WeeklyPlanSubmitter\")\n  dailyLogs          DailyLog[]            @relation(\"UserDailyLogs\")\n  achievements       Achievement[]         @relation(\"UserAchievements\")\n  ownerAnnualGoals   AnnualGoal[]          @relation(\"AnnualGoalOwner\")\n  ownerQuarterlyPlans QuarterlyPlan[]      @relation(\"QuarterlyPlanOwner\")\n  ownerMonthlyPlans  NewMonthlyPlan[]      @relation(\"NewMonthlyPlanOwner\")\n  ownerWeeklyPlans   NewWeeklyPlan[]       @relation(\"NewWeeklyPlanOwner\")\n}\n\n// 部门表\nmodel Department {\n  id          String   @id @default(cuid())\n  name        String\n  parentId    String?\n  managerId   String?\n  description String?\n  memberCount Int      @default(0)\n  createdAt   DateTime @default(now())\n  updatedAt   DateTime @updatedAt\n\n  parent           Department?       @relation(\"DepartmentTree\", fields: [parentId], references: [id])\n  children         Department[]      @relation(\"DepartmentTree\")\n  members          User[]\n  plans            Plan[]\n  weeklyReports    WeeklyReport[]\n  issues           Issue[]\n  monthlyData      MonthlyData[]\n  annualGoals      AnnualGoal[]\n  monthlyPlans     MonthlyPlan[]\n  weeklyPlans      WeeklyPlan[]\n  dailyLogs        DailyLog[]\n  achievements     Achievement[]\n  quarterlyPlans   QuarterlyPlan[]\n  newMonthlyPlans  NewMonthlyPlan[]\n  newWeeklyPlans   NewWeeklyPlan[]\n}\n\n// 战略目标表\nmodel Strategy {\n  id          String   @id @default(cuid())\n  title       String\n  description String?\n  year        Int\n  status      String   @default(\"draft\") // draft, active, completed, archived\n  progress    Int      @default(0)\n  startDate   DateTime\n  endDate     DateTime\n  createdById String\n  createdAt   DateTime @default(now())\n  updatedAt   DateTime @updatedAt\n\n  createdBy User?  @relation(\"StrategyCreator\", fields: [createdById], references: [id])\n  plans     Plan[]\n}\n\n// 工作计划表\nmodel Plan {\n  id           String   @id @default(cuid())\n  title        String\n  description  String?\n  type         String   @default(\"department\") // company, department, personal\n  strategyId   String?\n  departmentId String?\n  ownerId      String\n  status       String   @default(\"pending\") // pending, in_progress, completed, cancelled\n  progress     Int      @default(0)\n  priority     String   @default(\"medium\") // high, medium, low\n  startDate    DateTime\n  endDate      DateTime\n  createdAt    DateTime @default(now())\n  updatedAt    DateTime @updatedAt\n\n  strategy   Strategy?    @relation(fields: [strategyId], references: [id])\n  department Department?  @relation(fields: [departmentId], references: [id])\n  owner      User         @relation(\"PlanOwner\", fields: [ownerId], references: [id])\n  tasks      Task[]\n  assessments Assessment[]\n}\n\n// 任务表 - 支持任务来源与战略对齐\nmodel Task {\n  id                  String   @id @default(cuid())\n  taskNumber          String   @unique // T-20260409-001\n  title               String\n  description         String?\n  \n  // 任务来源\n  sourceType          String   // assigned(上级分配) / self_initiated(主动提交) / plan_decomposition(计划分解)\n  sourceId            String?  // 关联的上级任务/计划ID\n  sourceRef           String?  // 来源引用说明\n  \n  // 分配关系\n  assigneeId          String?\n  assignerId          String?  // 分配人ID\n  approverId          String?  // 审批人ID（主动申请时）\n  parentTaskId        String?  // 父任务ID\n  planId              String?  // 关联计划ID\n  goalId              String?  // 关联年度目标ID\n  quarterlyPlanId     String?  // 关联季度计划ID\n  monthlyPlanId       String?  // 关联月度计划ID\n  weeklyPlanId        String?  // 关联周计划ID\n  \n  // 战略对齐\n  strategicAlignment  Boolean  @default(false)  // 是否对齐战略\n  alignmentTarget     String?  // 对齐目标说明\n  alignmentScore      Float?   @default(0)      // 对齐度得分\n  \n  // 任务属性\n  dueDate             DateTime\n  priority            String   @default(\"medium\") // low, medium, high, urgent\n  status              String   @default(\"pending\") // pending(待确认) / confirmed(已确认) / in_progress(进行中) / completed(已完成) / verified(已验收) / rejected(已驳回)\n  progress            Int      @default(0)\n  \n  // 确认与审批\n  confirmedAt         DateTime? // 确认时间\n  confirmedById       String?  // 确认人ID\n  approvedAt          DateTime? // 审批时间\n  approvalComment     String?  // 审批意见\n  \n  // 完成信息\n  completedAt         DateTime?\n  completedById       String?\n  verifyResult        String?  // 验收结果\n  verifiedAt          DateTime?\n  verifiedById        String?\n  \n  createdAt           DateTime @default(now())\n  updatedAt           DateTime @updatedAt\n\n  assignee    User?    @relation(\"TaskAssignee\", fields: [assigneeId], references: [id])\n  assigner    User?    @relation(\"TaskAssigner\", fields: [assignerId], references: [id])\n  approver    User?    @relation(\"TaskApprover\", fields: [approverId], references: [id])\n  plan        Plan?    @relation(fields: [planId], references: [id])\n  parentTask  Task?    @relation(\"TaskTree\", fields: [parentTaskId], references: [id])\n  subTasks    Task[]   @relation(\"TaskTree\")\n  sources     TaskSource[]\n  executions  TaskExecutionRecord[]\n}\n\n// 任务来源关联表\nmodel TaskSource {\n  id              String   @id @default(cuid())\n  taskId          String\n  sourceType      String   // assigned/self_initiated/plan_decomposition\n  sourceId        String?  // 来源ID\n  sourcePlanId    String?  // 关联计划ID\n  sourceGoalId    String?  // 关联目标ID\n  createdAt       DateTime @default(now())\n\n  task Task @relation(fields: [taskId], references: [id])\n}\n\n// 任务执行记录\nmodel TaskExecutionRecord {\n  id              String   @id @default(cuid())\n  taskId          String\n  executionDate   DateTime\n  workContent     String\n  hoursSpent      Float    @default(0)\n  progress        Int      @default(0)\n  result          String?\n  problems        String?\n  createdAt       DateTime @default(now())\n  updatedAt       DateTime @updatedAt\n\n  task Task @relation(fields: [taskId], references: [id])\n}\n\n// 考核记录表\nmodel Assessment {\n  id         String   @id @default(cuid())\n  planId     String?\n  userId     String\n  assessorId String\n  score      Int\n  comment    String?\n  type       String   @default(\"monthly\") // monthly, quarterly, annual\n  period     String\n  createdAt  DateTime @default(now())\n  updatedAt  DateTime @updatedAt\n\n  plan     Plan?  @relation(fields: [planId], references: [id])\n  user     User   @relation(\"AssessmentUser\", fields: [userId], references: [id])\n  assessor User   @relation(\"AssessmentAssessor\", fields: [assessorId], references: [id])\n}\n\n// 周报表\nmodel WeeklyReport {\n  id               String   @id @default(cuid())\n  weekDate         DateTime // 周一日期\n  departmentId     String\n  submitterId      String\n  completedTasks   String   // 本周完成事项\n  keyData          String   // 关键数据\n  nextWeekPlan     String   // 下周重点事项\n  coordinationNeed String?  // 需要协调问题\n  selfEvaluation   String   @default(\"达成\") // 超预期/达成/未达成\n  submitTime       DateTime @default(now())\n  createdAt        DateTime @default(now())\n  updatedAt        DateTime @updatedAt\n\n  department Department @relation(fields: [departmentId], references: [id])\n  submitter  User       @relation(\"ReportSubmitter\", fields: [submitterId], references: [id])\n}\n\n// 问题清单表\nmodel Issue {\n  id              String   @id @default(cuid())\n  issueNumber     String   @unique // P2026040001\n  source          String   // 周报/会议/其他\n  discoveryDate   DateTime\n  departmentId    String\n  description     String\n  issueType       String   // 质量问题/交付问题/协作问题/其他\n  severity        String   @default(\"中\") // 高/中/低\n  responsibleId   String?\n  planCompleteDate DateTime?\n  actualCompleteDate DateTime?\n  status          String   @default(\"待处理\") // 待处理/处理中/已解决/挂起\n  solution        String?\n  verifyResult    String?\n  createdAt       DateTime @default