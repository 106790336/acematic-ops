.role === 'ceo' || user?.role === 'executive';\n  };\n\n  // 检查是否是CEO\n  const isCEO = (): boolean => {\n    return user?.role === 'ceo';\n  };\n\n  return {\n    hasPermission,\n    isAdmin,\n    isCEO,\n    user,\n  };\n}\n","file_path":"/workspace/frontend/src/hooks/use-permission.ts"},"tool_response":"Successfully created and wrote to new file: /workspace/frontend/src/hooks/use-permission.ts","client":"CLI","version":"2.71.1","generation_id":"36ebc94704f348daa92e645f77f80fe7","model":"glm-5.0","call_id":"019d8d43eb412055ca5b8cc6b9a09da2"}
