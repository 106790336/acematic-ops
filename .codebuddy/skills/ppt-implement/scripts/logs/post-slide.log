[2026-04-14 19:27:59] [DEBUG] [PPT PostToolUse Hook] stdin 数据: {"session_id":"2040121509614309376","transcript_path":"/root/.codebuddy/projects/workspace/2040121509614309376.jsonl","cwd":"/workspace","hook_event_name":"PostToolUse","tool_name":"Write","tool_input":{"content":"import { useAuth } from './use-auth';\n\nexport function usePermission() {\n  const { user } = useAuth();\n\n  // 检查是否有权限\n  const hasPermission = (permission: string): boolean => {\n    // CEO 有所有权限\n    if (user?.role === 'ceo') return true;\n    \n    // 高管有大部分权限\n    if (user?.role === 'executive') {\n      const executiveBlocked = ['settings:edit', 'role:manage'];\n      return !executiveBlocked.includes(permission);\n    }\n    \n    // 经理有限权限\n    if (user?.role === 'manager') {\n      const managerAllowed = [\n        'user:view', 'dept:view', 'strategy:view', 'plan:view', 'task:view',\n        'plan:create', 'plan:edit', 'task:create', 'task:edit',\n      ];\n      return managerAllowed.includes(permission);\n    }\n    \n    // 员工基本权限\n    const employeeAllowed = ['task:view', 'task:create', 'task:edit'];\n    return employeeAllowed.includes(permission);\n  };\n\n  // 检查是否是管理员\n  const isAdmin = (): boolean => {\n    return user?.role === 'ceo' || user?.role === 'executive';\n  };\n\n  // 检查是否是CEO\n  const isCEO = (): boolean => {\n    return user?.role === 'ceo';\n  };\n\n  // 检查是否可以编辑内容（创建者或管理员）\n  const canEditContent = (creatorId: string): boolean => {\n    // CEO可以编辑所有内容\n    if (user?.role === 'ceo') return true;\n    // 创建者可以编辑自己的内容\n    if (user?.id === creatorId) return true;\n    // 高管可以编辑大部分内容（除了系统设置）\n    if (user?.role === 'executive') return true;\n    return false;\n  };\n\n  // 检查是否可以删除内容\n  const canDeleteContent = (creatorId: string): boolean => {\n    // 只有CEO可以删除他人内容\n    if (user?.role === 'ceo') return true;\n    // 创建者可以删除自己的内容\n    if (user?.id === creatorId) return true;\n    return false;\n  };\n\n  return {\n    hasPermission,\n    isAdmin,\n    isCEO,\n    canEditContent,\n    canDeleteContent,\n    user,\n  };\n}\n","file_path":"/workspace/frontend/src/hooks/use-permission.ts"},"tool_response":"Successfully overwrote file: /workspace/frontend/src/hooks/use-permission.ts","client":"CLI","version":"2.71.1","generation_id":"baada1fb66e346f1a1261710711cbec1","model":"glm-5.0","call_id":"019d8d76d6d17a06f109e6a9ddb887a8"}
