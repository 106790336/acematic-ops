[2026-04-12 02:51:21] [DEBUG] [PPT PostToolUse Hook] stdin 数据: {"session_id":"2040121509614309376","transcript_path":"/root/.codebuddy/projects/workspace/2040121509614309376.jsonl","cwd":"/workspace","hook_event_name":"PostToolUse","tool_name":"Write","tool_input":{"content":"import { useState, useEffect } from 'react';\nimport { Card, CardContent } from '@/components/ui/card';\nimport { Button } from '@/components/ui/button';\nimport { Input } from '@/components/ui/input';\nimport { Badge } from '@/components/ui/badge';\nimport { Progress } from '@/components/ui/progress';\nimport { Skeleton } from '@/components/ui/skeleton';\nimport {\n  Table, TableBody, TableCell, TableHead, TableHeader, TableRow,\n} from '@/components/ui/table';\nimport {\n  Dialog, DialogContent, DialogHeader, DialogTitle, DialogFooter,\n} from '@/components/ui/dialog';\nimport { Label } from '@/components/ui/label';\nimport { Textarea } from '@/components/ui/textarea';\nimport { FadeIn } from '@/components/MotionPrimitives';\nimport { Plus, Edit, Trash2, Target, Eye } from 'lucide-react';\nimport { apiClient } from '@/lib/api-client';\nimport type { Strategy } from '@/types';\n\ninterface SimplePlan { id: string; title: string; status: string; progress: number; }\n\nexport default function StrategyList() {\n  const [list, setList] = useState<Strategy[]>([]);\n  const [loading, setLoading] = useState(true);\n  const [showDialog, setShowDialog] = useState(false);\n  const [showDetail, setShowDetail] = useState<Strategy | null>(null);\n  const [editItem, setEditItem] = useState<Strategy | null>(null);\n  const [saving, setSaving] = useState(false);\n  const [relatedPlans, setRelatedPlans] = useState<SimplePlan[]>([]);\n  const [form, setForm] = useState({\n    title: '',\n    description: '',\n    year: new Date().getFullYear(),\n    startDate: '',\n    endDate: '',\n    status: 'draft',\n    progress: 0,\n  });\n\n  useEffect(() => {\n    loadData();\n  }, []);\n\n  const loadData = async () => {\n    try {\n      setLoading(true);\n      const res = await apiClient.get('/strategies?limit=100');\n      if (res.data.success) setList(res.data.data?.items || []);\n    } catch (e) { console.error(e); }\n    finally { setLoading(false); }\n  };\n\n  const loadRelatedPlans = async (strategyId: string) => {\n    try {\n      const res = await apiClient.get(`/strategies/${strategyId}`);\n      if (res.data.success && res.data.data.plans) {\n        setRelatedPlans(res.data.data.plans);\n      }\n    } catch (e) { console.error(e); }\n  };\n\n  const handleSubmit = async (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!form.title.trim() || !form.startDate || !form.endDate) {\n      alert('请填写必填项'); return;\n    }\n    try {\n      setSaving(true);\n      if (editItem) {\n        await apiClient.put(`/strategies/${editItem.id}`, form);\n      } else {\n        await apiClient.post('/strategies', form);\n      }\n      setShowDialog(false); resetForm();\n      const res = await apiClient.get('/strategies?limit=100');\n      if (res.data.success) setList(res.data.data?.items || []);\n    } catch (err: any) { alert(err.response?.data?.error || '操作失败'); }\n    finally { setSaving(false); }\n  };\n\n  const onEdit = (item: Strategy) => {\n    setEditItem(item);\n    setForm({\n      title: item.title, description: item.description || '',\n      year: item.year,\n      startDate: item.startDate.split('T')[0], endDate: item.endDate.split('T')[0],\n      status: item.status, progress: item.progress,\n    });\n    setShowDialog(true);\n  };\n\n  const onDelete = async (id: string) => {\n    if (!confirm('确定删除？有关联计划的战略无法删除。')) return;\n    try {\n      const res = await apiClient.delete(`/strategies/${id}`);\n      if (res.data.success) {\n        const r2 = await apiClient.get('/strategies?limit=100');\n        if (r2.data.success) setList(r2.data.data?.items || []);\n      } else { alert(res.data.error || '删除失败'); }\n    } catch (err: any) { alert(err.response?.data?.error || '删除失败'); }\n  };\n\n  const onViewDetail = (item: Strategy) => {\n    setShowDetail(item);\n    loadRelatedPlans(item.id);\n  };\n\n  const resetForm = () => {\n    setEditItem(null);\n    setForm({ title: '', description: '', year: new Date().getFullYear(), startDate: '', endDate: '', status: 'draft', progress: 0 });\n  };\n\n  const openCreate = () => { resetForm(); setShowDialog(true); };\n  const onDialogChange = (open: boolean) => { setShowDialog(open); if (!open) resetForm(); };\n\n  const statusMap: Record<string, { label: string; class: string }> = {\n    draft: { label: '草稿', class: 'bg-gray-100 text-gray-700' },\n    active: { label: '进行中', class: 'bg-blue-100 text-blue-700' },\n    completed: { label: '已完成', class: 'bg-green-100 text-green-700' },\n  };\n\n  return (\n    <div className=\"space-y-6\">\n      <FadeIn>\n        <div className=\"flex items-center justify-between\">\n          <div>\n            <h1 className=\"font-bold text-2xl\">战略管理</h1>\n            <p className=\"text-muted-foreground text-sm\">管理公司战略目标，关联部门计划</p>\n          </div>\n          <Button onClick={openCreate}><Plus className=\"w-4 h-4 mr-2\" />新建战略</Button>\n        </div>\n      </FadeIn>\n\n      <FadeIn>\n        <Card>\n          <CardContent className=\"pt-6\">\n            {loading ? <div className=\"space-y-3\">{[1,2,3].map(i => <Skeleton key={i} className=\"h-16\" />)}</div>\n            : list.length === 0 ? <div className=\"text-center py-12 text-muted-foreground\">暂无战略数据，请新建战略</div>\n            : (\n              <Table>\n                <TableHeader>\n                  <TableRow>\n                    <TableHead>名称</TableHead>\n                    <TableHead>年度</TableHead>\n                    <TableHead>状态</TableHead>\n                    <TableHead>进度</TableHead>\n                    <TableHead>关联计划</TableHead>\n                    <TableHead>操作</TableHead>\n                  </TableRow>\n                </TableHeader>\n                <TableBody>\n                  {list.map(item => (\n                    <TableRow key={item.id}>\n                      <TableCell>\n                        <div className=\"flex items-center gap-2\">\n                          <Target className=\"w-4 h-4 text-blue-500\" />\n                          <span className=\"font-medium\">{item.title}</span>\n                        </div>\n                      </TableCell>\n                      <TableCell>{item.year}</TableCell>\n                      <TableCell><Badge className={statusMap[item.status]?.class || ''}>{statusMap[item.status]?.label || item.status}</Badge></TableCell>\n                      <TableCell>\n                        <div className=\"flex items-center gap-2\"><Progress value={item.progress} className=\"w-16 h-2\" /><span className=\"text-sm\">{item.progress}%</span></div>\n                      </TableCell>\n                      <TableCell><Badge variant=\"outline\">{item.planCount || 0} 个</Badge></TableCell>\n                      <TableCell>\n                        <Button variant=\"ghost\" size=\"sm\" onClick={() => onViewDetail(item)}><Eye className=\"w-4 h-4\" /></Button>\n                        <Button variant=\"ghost\" size=\"sm\" onClick={() => onEdit(item)}><Edit className=\"w-4 h-4\" /></Button>\n                        <Button variant=\"ghost\" size=\"sm\" onClick={() => onDelete(item.id)}><Trash2 className=\"w-4 h-4 text-destructive\" /></Button>\n                      </TableCell>\n                    </TableRow>\n                  ))}\n                </TableBody>\n              </Table>\n            )}\n          </CardContent>\n        </Card>\n      </FadeIn>\n\n      {/* 新建/编辑对话框 */}\n      <Dialog open={showDialog} onOpenChange={onDialogChange}>\n        <DialogContent>\n          <DialogHeader><DialogTitle>{editItem ? '编辑战略' : '新建战略'}</DialogTitle></DialogHeader>\n          <form onSubmit={handleSubmit} className=\"space-y-4\">\n            <div className=\"space-y-2\"><Label>战略名称 *</Label><Input value={form.title} onChange={e => setForm({...form, title: e.target.value})} placeholder=\"例：2026年度营收突破5000万\" required /></div>\n            <div className=\"space-y-2\"><Label>描述</Label><Textarea value={form.description} onChange={e => setForm({...form, description: e.target.value})} rows={2} placeholder=\"战略目标详细说明\" /></div>\n            <div className=\"grid grid-cols-2 gap-4\">\n              <div className=\"space-y-2\"><Label>年度 *</Label><Input type=\"number\" value={form.year} onChange={e => setForm({...form, year: parseInt(e.target.value) || 2026})} /></div>\n              {editItem && (\n                <div className=\"space-y-2\"><Label>状态</Label>\n                  <select value={form.status} onChange={e => setForm({...form, status: e.target.value})} className=\"flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm\">\n                    <option value=\"draft\">草稿</option><option value=\"active\">进行中</option><option value=\"completed\">已完成</option>\n                  </select>\n                </div>\n              )}\n              <div className=\"space-y-2\"><Label>开始日期 *</Label><Input type=\"date\" value={form.startDate} onChange={e => setForm({...form, startDate: e.target.value})} required /></div>\n              <div className=\"space-y-2\"><Label>结束日期 *</Label><Input type=\"date\" value={form.endDate} onChange={e => setForm({...form, endDate: e.target.value})} required /></div>\n            </div>\n            {editItem && (\n              <div className=\"space-y-2\"><Label>当前进度</Label><Input type=\"number\" min={0} max={100} value={form.progress} onChange={e => setForm({...form, progress: parseInt(e.target.value) || 0})} /></div>\n            )}\n            <DialogFooter>\n              <Button type=\"button\" variant=\"outline\" onClick={() => setShowDialog(false)}>取消</Button>\n              <Button type=\"submit\" disabled={saving}>{saving ? '提交中...' : (editItem ? '保存' : '创建')}</Button>\n            </DialogFooter>\n          </form>\n        </DialogContent>\n      </Dialog>\n\n      {/* 详情对话框 - 查看关联计划 */}\n      <Dialog open={!!showDetail} onOpenChange={() => setShowDetail(null)}>\n        <DialogContent className=\"max-w-2xl\">\n          <DialogHeader><DialogTitle>{showDetail?.title}</DialogTitle></DialogHeader>\n          <div className=\"space-y-4\">\n            <div className=\"grid grid-cols-3 gap-4 text-sm\">\n              <div><span className=\"text-muted-foreground\">年度：</span>{showDetail?.year}</div>\n              <div><span className=\"text-muted-foreground\">状态：</span><Badge className={statusMap[showDetail?.status || '']?.class || ''}>{statusMap[showDetail?.status || '']?.label || showDetail?.status}</Badge></div>\n              <div><span className=\"text-muted-foreground\">进度：</span>{showDetail?.progress}%</div>\n            </div>\n            {showDetail?.description && <p className=\"text-sm text-muted-foreground\">{showDetail.description}</p>}\n            <div>\n              <h3 className=\"font-medium mb-2\">关联计划 ({relatedPlans.length})</h3>\n              {relatedPlans.length === 0 ? (\n                <p className=\"text-sm text-muted-foreground text-center py-4\">暂无关联计划。请在计划管理中创建计划时关联此战略。</p>\n              ) : (\n                <div className=\"space-y-2\">\n                  {relatedPlans.map(p => (\n                    <div key={p.id} className=\"flex items-center justify-between p-3 rounded-lg border\">\n                      <span className=\"font-medium text-sm\">{p.title}</span>\n                      <div className=\"flex items-center gap-2\">\n                        <Progress value={p.progress} className=\"w-16 h-1.5\" />\n                        <span className=\"text-xs text-muted-foreground\">{p.progress}%</span>\n                      </div>\n                    </div>\n                  ))}\n                </div>\n              )}\n            </div>\n          </div>\n        </DialogContent>\n      </Dialog>\n    </div>\n  );\n}\n","file_path":"/workspace/frontend/src/pages/StrategyList.tsx"},"tool_response":"Successfully overwrote file: /workspace/frontend/src/pages/StrategyList.tsx","client":"CLI","version":"2.71.1","generation_id":"62556fb610094d5baa6e0865796d8338","model":"glm-5.0-turbo","call_id":"call_8fc54d7d33f1436bae19a229"}
