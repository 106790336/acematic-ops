nt={\n                <ProtectedRoute>\n                  <Layout />\n                </ProtectedRoute>\n              }\n            >\n              <Route index element={<Navigate to=\"/dashboard\" replace />} />\n              <Route \n                path=\"dashboard\" \n                element={\n                  <PageTransition transition=\"slide-fade\">\n                    <Dashboard />\n                  </PageTransition>\n                } \n              />\n              <Route \n                path=\"strategy\" \n                element={\n                  <PageTransition transition=\"slide-fade\">\n                    <StrategyList />\n                  </PageTransition>\n                } \n              />\n              <Route \n                path=\"plan\" \n                element={\n                  <PageTransition transition=\"slide-fade\">\n                    <PlanList />\n                  </PageTransition>\n                } \n              />\n              <Route \n                path=\"department\" \n                element={\n                  <PageTransition transition=\"slide-fade\">\n                    <DepartmentList />\n                  </PageTransition>\n                } \n              />\n              <Route \n                path=\"assessment\" \n                element={\n                  <PageTransition transition=\"slide-fade\">\n                    <AssessmentList />\n                  </PageTransition>\n                } \n              />\n            </Route>\n            \n            {/* 404 */}\n            <Route \n              path=\"*\" \n              element={\n                <PageTransition transition=\"fade\">\n                  <NotFound />\n                </PageTransition>\n              } \n            />\n          </AnimatedRoutes>\n        </BrowserRouter>\n      </TooltipProvider>\n    </QueryClientProvider>\n  );\n}\n\nexport default App;\n","file_path":"/workspace/frontend/src/App.tsx"},"