ent>\n        </Card>\n      </Stagger>\n\n      {/* 图表区域 */}\n      <div className=\"grid gap-6 lg:grid-cols-2\">\n        {/* 战略进度 */}\n        <FadeIn>\n          <Card>\n            <CardHeader>\n              <CardTitle className=\"flex items-center gap-2\">\n                <Target className=\"w-5 h-5\" style={{ color: 'oklch(0.42 0.19 250)' }} />\n                战略目标进度\n              </CardTitle>\n            </CardHeader>\n            <CardContent>\n              <div className=\"space-y-4\">\n                {strategyProgress.map((strategy) => (\n                  <div key={strategy.id} className=\"space-y-2\">\n                    <div className=\"flex items-center justify-between text-sm\">\n                      <span className=\"font-medium\">{strategy.title}</span>\n                      <span className=\"text-muted-foreground\">{strategy.progress}%</span>\n                    </div>\n                    <Progress value={strategy.progress} className=\"h-2\" />\n                  </div>\n                ))}\n                {strategyProgress.length === 0 && (\n                  <div className=\"text-center py-8 text-muted-foreground\">\n                    暂无战略目标\n                  </div>\n                )}\n              </div>\n            </CardContent>\n          </Card>\n        </FadeIn>\n\n        {/* 计划状态分布 */}\n        <FadeIn>\n          <Card>\n            <CardHeader>\n              <CardTitle className=\"flex items-center gap-2\">\n                <ClipboardList className=\"w-5 h-5\" style={{ color: 'oklch(0.75 0.18 75)' }} />\n                计划状态分布\n              </CardTitle>\n            </CardHeader>\n            <CardContent>\n              <div className=\"h-64\">\n                <ResponsiveContainer width=\"100%\" height=\"100%\">\n                  <PieChart>\n                    <Pie\n                      data={planStatusData}\n                      cx=\"50%\"\n                      cy=\"50%\"\n                      innerRadius