[2026-04-13 09:23:25] [DEBUG] [PPT PostToolUse Hook] stdin 数据: {"session_id":"2040121509614309376","transcript_path":"/root/.codebuddy/projects/workspace/2040121509614309376.jsonl","cwd":"/workspace","hook_event_name":"PostToolUse","tool_name":"Write","tool_input":{"content":"import { useState, useEffect, useRef } from 'react';\nimport { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';\nimport { Button } from '@/components/ui/button';\nimport { Input } from '@/components/ui/input';\nimport { Badge } from '@/components/ui/badge';\nimport { Skeleton } from '@/components/ui/skeleton';\nimport { Label } from '@/components/ui/label';\nimport { FadeIn } from '@/components/MotionPrimitives';\nimport { Shield, Palette, Check, X, Upload, Trash2, ImageIcon } from 'lucide-react';\nimport { apiClient, getErrorMessage } from '@/lib/api-client';\n\ninterface Permission { id: string; code: string; name: string; module: string; }\ninterface BrandConfig { \n  systemName: string; shortName: string; logoUrl?: string; faviconUrl?: string; primaryColor: string; secondaryColor: string;\n  companyName?: string; welcomeText?: string; \n}\n\nconst roles = [\n  { key: 'ceo', label: 'CEO', color: 'bg-purple-100 text-purple-700' },\n  { key: 'executive', label: '高管', color: 'bg-blue-100 text-blue-700' },\n  { key: 'manager', label: '经理', color: 'bg-green-100 text-green-700' },\n  { key: 'employee', label: '员工', color: 'bg-gray-100 text-gray-700' },\n];\n\nconst modules = [\n  { key: 'dashboard', label: '数据看板' },\n  { key: 'strategy', label: '战略管理' },\n  { key: 'plan', label: '计划管理' },\n  { key: 'task', label: '任务管理' },\n  { key: 'execution', label: '执行日志' },\n  { key: 'assessment', label: '绩效考核' },\n  { key: 'report', label: '报告管理' },\n  { key: 'issue', label: '问题管理' },\n  { key: 'org', label: '组织人员' },\n  { key: 'settings', label: '系统设置' },\n];\n\nconst defaultPermissions: { code: string; name: string; module: string }[] = [\n  { code: 'dashboard:view', name: '查看看板', module: 'dashboard' },\n  { code: 'strategy:view', name: '查看战略', module: 'strategy' },\n  { code: 'strategy:edit', name: '编辑战略', module: 'strategy' },\n  { code: 'plan:view', name: '查看计划', module: 'plan' },\n  { code: 'plan:edit', name: '编辑计划', module: 'plan' },\n  { code: 'task:view', name: '查看任务', module: 'task' },\n  { code: 'task:edit', name: '编辑任务', module: 'task' },\n  { code: 'execution:view', name: '查看日志', module: 'execution' },\n  { code: 'execution:edit', name: '填写日志', module: 'execution' },\n  { code: 'assessment:view', name: '查看考核', module: 'assessment' },\n  { code: 'assessment:edit', name: '评分/计算', module: 'assessment' },\n  { code: 'report:view', name: '查看报告', module: 'report' },\n  { code: 'report:edit', name: '编辑报告', module: 'report' },\n  { code: 'issue:view', name: '查看问题', module: 'issue' },\n  { code: 'issue:edit', name: '编辑问题', module: 'issue' },\n  { code: 'org:view', name: '查看组织', module: 'org' },\n  { code: 'org:edit', name: '编辑组织', module: 'org' },\n  { code: 'settings:view', name: '查看设置', module: 'settings' },\n  { code: 'settings:edit', name: '编辑设置', module: 'settings' },\n];\n\nfunction ImageUploadField({ label, value, onChange, hint }: { label: string; value?: string; onChange: (url: string) => void; hint: string }) {\n  const inputRef = useRef<HTMLInputElement>(null);\n  const [uploading, setUploading] = useState(false);\n\n  const handleUpload = async (e: React.ChangeEvent<HTMLInputElement>) => {\n    const file = e.target.files?.[0];\n    if (!file) return;\n    if (file.size > 2 * 1024 * 1024) { alert('文件大小不能超过 2MB'); return; }\n    setUploading(true);\n    try {\n      const form = new FormData();\n      form.append('file', file);\n      const endpoint = label.includes('Favicon') ? '/settings/upload/favicon' : '/settings/upload/logo';\n      const res = await apiClient.post(endpoint, form, { headers: { 'Content-Type': 'multipart/form-data' } });\n      if (res.data.success) onChange(res.data.data.url);\n    } catch (err: any) { alert(err.response?.data?.error || '上传失败'); }\n    finally { setUploading(false); }\n  };\n\n  return (\n    <div className=\"space-y-2\">\n      <Label>{label}</Label>\n      <div className=\"flex items-center gap-3\">\n        {value ? (\n          <div className=\"relative group\">\n            <img src={value} alt={label} className=\"w-16 h-16 object-contain border rounded-lg bg-white p-1\" />\n            <button onClick={() => onChange('')} className=\"absolute -top-1.5 -right-1.5 w-5 h-5 bg-destructive text-white rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transition\">\n              <X className=\"w-3 h-3\" />\n            </button>\n          </div>\n        ) : (\n          <div className=\"w-16 h-16 border-2 border-dashed rounded-lg flex flex-col items-center justify-center text-muted-foreground\">\n            <ImageIcon className=\"w-6 h-6\" />\n          </div>\n        )}\n        <div className=\"flex-1 space-y-1\">\n          <Button variant=\"outline\" size=\"sm\" onClick={() => inputRef.current?.click()} disabled={uploading}>\n            <Upload className=\"w-4 h-4 mr-1\" />{uploading ? '上传中...' : '上传图片'}\n          </Button>\n          <p className=\"text-xs text-muted-foreground\">{hint}</p>\n        </div>\n        <input ref={inputRef} type=\"file\" accept=\"image/png,image/jpeg,image/svg+xml,image/x-icon,image/webp\" onChange={handleUpload} className=\"hidden\" />\n      </div>\n    </div>\n  );\n}\n\nexport default function SettingsPage() {\n  const [activeTab, setActiveTab] = useState<'permission' | 'brand'>('permission');\n  const [permissions, setPermissions] = useState<Permission[]>([]);\n  const [rolePerms, setRolePerms] = useState<Record<string, string[]>>({});\n  const [selectedRole, setSelectedRole] = useState('ceo');\n  const [brand, setBrand] = useState<BrandConfig>({ systemName: '', shortName: '', primaryColor: '#7c3aed', secondaryColor: '#3b82f6' });\n  const [loading, setLoading] = useState(true);