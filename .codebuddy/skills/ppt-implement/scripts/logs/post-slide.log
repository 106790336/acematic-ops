[2026-04-12 02:52:15] [DEBUG] [PPT PostToolUse Hook] stdin 数据: {"session_id":"2040121509614309376","transcript_path":"/root/.codebuddy/projects/workspace/2040121509614309376.jsonl","cwd":"/workspace","hook_event_name":"PostToolUse","tool_name":"Write","tool_input":{"content":"import { useState, useEffect } from 'react';\nimport { Card, CardContent } from '@/components/ui/card';\nimport { Button } from '@/components/ui/button';\nimport { Input } from '@/components/ui/input';\nimport { Badge } from '@/components/ui/badge';\nimport { Progress } from '@/components/ui/progress';\nimport { Skeleton } from '@/components/ui/skeleton';\nimport {\n  Table, TableBody, TableCell, TableHead, TableHeader, TableRow,\n} from '@/components/ui/table';\nimport {\n  Dialog, DialogContent, DialogHeader, DialogTitle, DialogFooter,\n} from '@/components/ui/dialog';\nimport { Label } from '@/components/ui/label';\nimport { Textarea } from '@/components/ui/textarea';\nimport { FadeIn } from '@/components/MotionPrimitives';\nimport { Plus, Edit, Trash2, User, Clock, Eye, Link2, CheckCircle } from 'lucide-react';\nimport { apiClient } from '@/lib/api-client';\nimport type { Task } from '@/types';\n\ninterface SimpleUser { id: string; name: string; position?: string; }\ninterface SimplePlan { id: string; title: string; strategy?: { title: string }; }\ninterface SimpleStrategy { id: string; title: string; }\ninterface ProgressLog { id: string; progress: number; description: string; createdAt: string; user?: { name: string }; }\n\nexport default function TaskManagement() {\n  const [list, setList] = useState<Task[]>([]);\n  const [loading, setLoading] = useState(true);\n  const [showDialog, setShowDialog] = useState(false);\n  const [showDetail, setShowDetail] = useState<any>(null);\n  const [showProgress, setShowProgress] = useState<Task | null>(null);\n  const [editItem, setEditItem] = useState<Task | null>(null);\n  const [saving, setSaving] = useState(false);\n  const [users, setUsers] = useState<SimpleUser[]>([]);\n  const [plans, setPlans] = useState<SimplePlan[]>([]);\n  const [strategies, setStrategies] = useState<SimpleStrategy[]>([]);\n  const [progressLogs, setProgressLogs] = useState<ProgressLog[]>([]);\n  const [form, setForm] = useState({\n    title: '', description: '', assigneeId: '', dueDate: '',\n    priority: 'medium', sourceType: 'assigned', planId: '',\n    strategicAlignment: false, alignmentTarget: '',\n  });\n  const [progressForm, setProgressForm] = useState({ progress: 0, result: '' });\n\n  useEffect(() => { loadData(); loadOptions(); }, []);\n\n  const loadData = async () => {\n    try {\n      setLoading(true);\n      const res = await apiClient.get('/tasks-v2?limit=100');\n      if (res.data.success) setList(res.data.data?.items || []);\n    } catch (e) { console.error(e); }\n    finally { setLoading(false); }\n  };\n\n  const loadOptions = async () => {\n    try {\n      const [uRes, pRes, sRes] = await Promise.all([\n        apiClient.get('/users?limit=100'),\n        apiClient.get('/plans?limit=100'),\n        apiClient.get('/strategies?limit=100'),\n      ]);\n      if (uRes.data.success) setUsers(uRes.data.data?.items || []);\n      if (pRes.data.success) setPlans(pRes.data.data?.items || []);\n      if (sRes.data.success) setStrategies(sRes.data.data?.items || []);\n    } catch (e) { console.error(e); }\n  };\n\n  const handleSubmit = async (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!form.title.trim() || !form.dueDate) { alert('请填写任务名称和截止日期'); return; }\n    try {\n      setSaving(true);\n      const body: any = {\n        ...form,\n        assigneeId: form.assigneeId || null,\n        planId: form.planId || null,\n      };\n      if (editItem) {\n        await apiClient.put(`/tasks-v2/${editItem.id}`, body);\n      } else {\n        await apiClient.post('/tasks-v2', body);\n      }\n      setShowDialog(false); resetForm();\n      const res = await apiClient.get('/tasks-v2?limit=100');\n      if (res.data.success) setList(res.data.data?.items || []);\n    } catch (err: any) { alert(err.response?.data?.error || '操作失败'); }\n    finally { setSaving(false); }\n  };\n\n  const onEdit = (item: Task) => {\n    setEditItem(item);\n    setForm({\n      title: item.title, description: item.description || '',\n      assigneeId: item.assignee?.id || '', dueDate: item.dueDate.split('T')[0],\n      priority: item.priority,\n      sourceType: (item as any).sourceType || 'assigned',\n      planId: (item as any).planId || '',\n      strategicAlignment: (item as any).strategicAlignment || false,\n      alignmentTarget: (item as any).alignmentTarget || '',\n    });\n    setShowDialog(true);\n  };\n\n  const onDelete = async (id: string) => {\n    if (!confirm('确定删除此任务？')) return;\n    try {\n      await apiClient.delete(`/tasks-v2/${id}`);\n      const res = await apiClient.get('/tasks-v2?limit=100');\n      if (res.data.success) setList(res.data.data?.items || []);\n    } catch (err: any) { alert(err.response?.data?.error || '删除失败'); }\n  };\n\n  const onViewDetail = async (item: any) => {\n    try {\n      const res = await apiClient.get(`/tasks-v2/${item.id}`);\n      if (res.data.success) setShowDetail(res.data.data);\n    } catch (e) { console.error(e); }\n  };\n\n  const openProgress = (item: Task) => {\n    setShowProgress(item);\n    setProgressForm({ progress: item.progress || 0, result: '' });\n  };\n\n  const submitProgress = async (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!showProgress) return;\n    try {\n      await apiClient.put(`/tasks-v2/${showProgress.id}/progress`, {\n        progress: progressForm.progress, result: progressForm.result,\n      });\n      setShowProgress(null);\n      const res = await apiClient.get('/tasks-v2?limit=100');\n      if (res.data.success) setList(res.data.data?.items || []);\n    } catch (err: any) { alert(err.response?.data?.error || '操作失败'); }\n  };\n\n  const confirmTask = async (id: string) => {\n    try {\n      await apiClient.post(`/tasks-v2/${id}/confirm`);\n      const res = await apiClient.get('/tasks-v2?limit=100');\n      if (res.data.success) setList(res.data.data?.items || []);\n    } catch (err: any) { alert(err.response?.data?.error || '操作失败'); }\n  };\n\n  const resetForm = () => {\n    setEditItem(null);\n    setForm({ title: '', description: '', assigneeId: '', dueDate: '', priority: 'medium', sourceType: 'assigned', planId: '', strategicAlignment: false, alignmentTarget: '' });\n  };\n\n  const openCreate = () => { resetForm(); setShowDialog(true); };\n  const onDialogChange = (open: boolean) => { setShowDialog(open); if (!open) resetForm(); };\n\n  const priorityMap: Record<string, { label: string; class: string }> = {\n    low: { label: '低', class: 'bg-gray-100 text-gray-700' },\n    medium: { label: '中', class: 'bg-blue-100 text-blue-700' },\n    high: { label: '高', class: 'bg-orange-100 text-orange-700' },\n    urgent: { label: '紧急', class: 'bg-red-100 text-red-700' },\n  };\n  const statusMap: Record<string, { label: string; class: string }> = {\n    pending: { label: '待确认', class: 'bg-yellow-100 text-yellow-700' },\n    confirmed: { label: '已确认', class: 'bg-blue-100 text-blue-700' },\n    in_progress: { label: '进行中', class: 'bg-cyan-100 text-cyan-700' },\n    completed: { label: '已完成', class: 'bg-green-100 text-green-700' },\n    verified: { label: '已验收', class: 'bg-green-200 text-green-800' },\n  };\n  const sourceMap: Record<string, string> = { assigned: '上级分配', self_initiated: '主动申请', plan_decomposition: '计划分解' };\n  const planName = (id: string) => plans.find(p => p.id === id)?.title || '-';\n  const userName = (id: string) => users.find(u => u.id === id)?.name || '-';\n\n  return (\n    <div className=\"space-y-6\">\n      <FadeIn>\n        <div className=\"flex items-center justify-between\">\n          <div>\n            <h1 className=\"font-bold text-2xl\">任务管理</h1>\n            <p className=\"text-muted-foreground text-sm\">创建任务时关联计划和战略，实现战略对齐</p>\n          </div>\n          <Button onClick={openCreate}><Plus className=\"w-4 h-4 mr-2\" />新建任务</Button>\n        </div>\n      </FadeIn>\n\n      <FadeIn>\n        <Card>\n          <CardContent className=\"pt-6\">\n            {loading ? <div className=\"space-y-3\">{[1,2,3].map(i => <Skeleton key={i} className=\"h-16\" />)}</div>\n            : list.length === 0 ? <div className=\"text-center py-12 text-muted-foreground\">暂无任务，请新建任务</div>\n            : (\n              <Table>\n                <TableHeader>\n                  <TableRow>\n                    <TableHead>名称</TableHead>\n                    <TableHead>来源</TableHead>\n                    <TableHead>执行人</TableHead>\n                    <TableHead>关联计划</TableHead>\n                    <TableHead>截止日期</TableHead>\n                    <TableHead>优先级</TableHead>\n                    <TableHead>状态</TableHead>\n                    <TableHead>进度</TableHead>\n                    <TableHead>操作</TableHead>\n                  </TableRow>\n                </TableHeader>\n                <TableBody>\n                  {list.map(item => {\n                    const t = item as any;\n                    return (\n                      <TableRow key={item.id}>\n                        <TableCell><span className=\"font-medium\">{item.title}</span></TableCell>\n                        <TableCell><Badge variant=\"outline\">{sourceMap[t.sourceType] || t.sourceType || '-'}</Badge></TableCell>\n                        <TableCell><div className=\"flex items-center gap-1\"><User className=\"w-3 h-3\" />{item.assignee?.name || '-'}</div></TableCell>\n                        <TableCell><span className=\"text-sm\">{t.plan ? t.plan.title : <span className=\"text-muted-foreground\">未关联</span>}</span></TableCell>\n                        <TableCell><div className=\"flex items-center gap-1\"><Clock className=\"w-3 h-3\" />{item.dueDate?.split('T')[0] || '-'}</div></TableCell>\n                        <TableCell><Badge className={priorityMap[item.priority]?.class || ''}>{priorityMap[item.priority]?.label}</Badge></TableCell>\n                        <TableCell><Badge className={statusMap[item.status]?.class || ''}>{statusMap[item.status]?.label || item.status}</Badge></TableCell>\n                        <TableCell>\n                          <div className=\"flex items-center gap-1\"><Progress value={item.progress || 0} className=\"w-12 h-1.5\" /><span className=\"text-xs\">{item.progress || 0}%</span></div>\n                        </TableCell>\n                        <TableCell>\n                          {item.status === 'pending' && <Button variant=\"ghost\" size=\"sm\" onClick={() => confirmTask(item.id)}><CheckCircle className=\"w-4 h-4 text-green-500\" /></Button>}\n                          {(item.status === 'confirmed' || item.status === 'in_progress') && <Button variant=\"ghost\" size=\"sm\" onClick={() => openProgress(item)}><Edit className=\"w-4 h-4\" /></Button>}\n                          <Button variant=\"ghost\" size=\"sm\" onClick={() => onViewDetail(item)}><Eye className=\"w-4 h-4\" /></Button>\n                          <Button variant=\"ghost\" size=\"sm\" onClick={() => onEdit(item)}><Edit className=\"w-4 h-4\" /></Button>\n                          <Button variant=\"ghost\" size=\"sm\" onClick={() => onDelete(item.id)}><Trash2 className=\"w-4 h-4 text-destructive\" /></Button>\n                        </TableCell>\n                      </TableRow>\n                    );\n                  })}\n                </TableBody>\n              </Table>\n            )}\n          </CardContent>\n        </Card>\n      </FadeIn>\n\n      {/* 新建/编辑对话框 */}\n      <Dialog open={showDialog} onOpenChange={onDialogChange}>\n        <DialogContent className=\"max-w-lg\">\n          <DialogHeader><DialogTitle>{editItem ? '编辑任务' : '下达新任务'}</DialogTitle></DialogHeader>\n          <form onSubmit={handleSubmit} className=\"space-y-4\">\n            <div className=\"space-y-2\"><Label>任务名称 *</Label><Input value={form.title} onChange={e => setForm({...form, title: e.target.value})} placeholder=\"例：完成XX客户方案设计\" required /></div>\n            <div className=\"space-y-2\"><Label>任务描述</Label><Textarea value={form.description} onChange={e => setForm({...form, description: e.target.value})} rows={2} /></div>\n            <div className=\"grid grid-cols-2 gap-4\">\n              <div className=\"space-y-2\">\n                <Label>执行人</Label>\n                <select value={form.assigneeId} onChange={e => setForm({...form, assigneeId: e.target.value})} className=\"flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm\">\n                  <option value=\"\">-- 选择执行人 --</option>\n                  {users.map(u => <option key={u.id} value={u.id}>{u.name} ({u.position || '员工'})</option>)}\n                </select>\n              </div>\n              <div className=\"space-y-2\">\n                <Label>截止日期 *</Label>\n                <Input type=\"date\" value={form.dueDate} onChange={e => setForm({...form, dueDate: e.target.value})} required />\n              </div>\n              <div className=\"space-y-2\">\n                <Label>优先级</Label>\n                <select value={form.priority} onChange={e => setForm({...form, priority: e.target.value})} className=\"flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm\">\n                  <option value=\"low\">低</option><option value=\"medium\">中</option><option value=\"high\">高</option><option value=\"urgent\">紧急</option>\n                </select>\n              </div>\n              <div className=\"space-y-2\">\n                <Label>任务来源</Label>\n                <select value={form.sourceType} onChange={e => setForm({...form, sourceType: e.target.value})} className=\"flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm\">\n                  <option value=\"assigned\">上级分配</option><option value=\"self_initiated\">主动申请</option><option value=\"plan_decomposition\">计划分解</option>\n                </select>\n              </div>\n            </div>\n\n            {/* 关联设置 */}\n            <div className=\"border rounded-lg p-4 space-y-4 bg-muted/30\">\n              <h4 className=\"font-medium text-sm flex items-center gap-2\"><Link2 className=\"w-4 h-4\" />关联设置（战略对齐）</h4>\n              <div className=\"grid grid-cols-2 gap-4\">\n                <div className=\"space-y-2\">\n                  <Label>关联计划</Label>\n                  <select value={form.planId} onChange={e => {\n                    const planId = e.target.value;\n                    const plan = plans.find(p => p.id === planId);\n                    setForm({\n                      ...form, planId,\n                      strategicAlignment: !!planId,\n                      alignmentTarget: plan?.strategy?.title || '',\n                    });\n                  }} className=\"flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm\">\n                    <option value=\"\">-- 不关联 --</option>\n                    {plans.map(p => <option key={p.id} value={p.id}>{p.title}{p.strategy ? ` (${p.strategy.title})` : ''}</option>)}\n                  </select>\n                </div>\n                <div className=\"space-y-2\">\n                  <Label>对齐目标</Label>\n                  <Input value={form.alignmentTarget} onChange={e => setForm({...form, alignmentTarget: e.target.value})} placeholder=\"选择计划后自动填充\" disabled={!!form.planId} />\n                </div>\n              </div>\n              <div className=\"flex items-center gap-2\">\n                <input type=\"checkbox\" checked={form.strategicAlignment} onChange={e => setForm({...form, strategicAlignment: e.target.checked})} />\n                <span className=\"text-sm\">已对齐战略</span>\n                {form.strategicAlignment && <Badge className=\"bg-green-100 text-green-700\">已对齐</Badge>}\n              </div>\n            </div>\n\n            <DialogFooter>\n              <Button type=\"button\" variant=\"outline\" onClick={() => setShowDialog(false)}>取消</Button>\n              <Button type=\"submit\" disabled={saving}>{saving ? '提交中...' : (editItem ? '保存' : '下达任务')}</Button>\n            </DialogFooter>\n          </form>\n        </DialogContent>\n      </Dialog>\n\n      {/* 更新进度对话框 */}\n      <Dialog open={!!showProgress} onOpenChange={() => setShowProgress(null)}>\n        <DialogContent>\n          <DialogHeader><DialogTitle>更新任务进度</DialogTitle></DialogHeader>\n          <div className=\"space-y-2 mb-4\">\n            <p className=\"font-medium\">{showProgress?.title}</p>\n            <p className=\"text-sm text-muted-foreground\">当前进度：{showProgress?.progress || 0}%</p>\n          </div>\n          <form onSubmit={submitProgress} className=\"space-y-4\">\n            <div className=\"space-y-2\"><Label>新进度 (%)</Label><Input type=\"number\" min={0} max={100} value={progressForm.progress} onChange={e => setProgressForm({...progressForm, progress: parseInt(e.target.value) || 0})} /></div>\n            <div className=\"space-y-2\"><Label>执行描述 *</Label><Textarea value={progressForm.result} onChange={e => setProgressForm({...progressForm, result: e.target.value})} rows={3} placeholder=\"描述本次完成的工作内容、遇到的问题、需要的支持\" required /></div>\n            <DialogFooter>\n              <Button type=\"button\" variant=\"outline\" onClick={() => setShowProgress(null)}>取消</Button>\n              <Button type=\"submit\">更新进度</Button>\n            </DialogFooter>\n          </form>\n        </DialogContent>\n      </Dialog>\n\n      {/* 任务详情对话框 */}\n      <Dialog open={!!showDetail} onOpenChange={() => setShowDetail(null)}>\n        <DialogContent className=\"max-w-2xl max-h-[80vh] overflow-y-auto\">\n          <DialogHeader><DialogTitle>{showDetail?.title}</DialogTitle></DialogHeader>\n          <div className=\"space-y-4\">\n            <div className=\"grid grid-cols-2 gap-3 text-sm\">\n              <div><span className=\"text-muted-foreground\">来源：</span>{sourceMap[showDetail?.sourceType] || showDetail?.sourceType}</div>\n              <div><span className=\"text-muted-foreground\">优先级：</span>{priorityMap[showDetail?.priority]?.label}</div>\n              <div><span className=\"text-muted-foreground\">分配人：</span>{showDetail?.assigner?.name || '-'}</div>\n              <div><span className=\"text-muted-foreground\">执行人：</span>{showDetail?.assignee?.name || '-'}</div>\n              <div><span className=\"text-muted-foreground\">截止日期：</span>{showDetail?.dueDate?.split('T')[0]}</div>\n              <div><span className=\"text-muted-foreground\">状态：</span><Badge className={statusMap[showDetail?.status]?.class || ''}>{statusMap[showDetail?.status]?.label || showDetail?.status}</Badge></div>\n            </div>\n            {showDetail?.strategicAlignment && (\n              <div className=\"flex items-center gap-2 text-sm p-2 rounded bg-green-50 text-green-700\">\n                <Link2 className=\"w-4 h-4\" /> 已对齐战略：{showDetail.alignmentTarget || '已关联计划'}\n              </div>\n            )}\n            <div className=\"space-y-2\">\n              <Label>当前进度</Label>\n              <div className=\"flex items-center gap-2\"><Progress value={showDetail?.progress || 0} className=\"flex-1 h-2\" /><span className=\"text-sm\">{showDetail?.progress || 0}%</span></div>\n            </div>\n            {showDetail?.executions && showDetail.executions.length > 0 && (\n              <div>\n                <Label>执行记录</Label>\n                <div className=\"space-y-2 mt-2\">\n                  {showDetail.executions.map((log: any) => (\n                    <div key={log.id} className=\"p-3 rounded-lg border text-sm\">\n                      <div className=\"flex items-center justify-between mb-1\">\n                        <span className=\"font-medium\">进度 {log.progress}%</span>\n                        <span className=\"text-muted-foreground\">{log.executionDate?.split('T')[0]}</sp