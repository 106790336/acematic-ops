[2026-04-14 20:00:32] [DEBUG] [PPT PostToolUse Hook] stdin 数据: {"session_id":"2040121509614309376","transcript_path":"/root/.codebuddy/projects/workspace/2040121509614309376.jsonl","cwd":"/workspace","hook_event_name":"PostToolUse","tool_name":"Edit","tool_input":{"file_path":"/workspace/backend/src/modules/users.ts","new_string":"// 更新用户\nrouter.put('/:id', async (req: Request, res: Response) => {\n  try {\n    const { id } = req.params;\n    const updateData = { ...req.body };\n\n    // 如果更新用户名，检查是否已存在\n    if (updateData.username) {\n      const existingUser = await prisma.user.findFirst({\n        where: {\n          username: updateData.username,\n          NOT: { id },\n        },\n      });\n      if (existingUser) {\n        return res.status(400).json({\n          success: false,\n          error: '用户名已存在',\n        });\n      }\n    }\n\n    // 如果更新密码，需要加密\n    if (updateData.password) {\n      updateData.password = await bcrypt.hash(updateData.password, 10);\n    }\n\n    const user = await prisma.user.update({\n      where: { id },\n      data: updateData,\n    });\n\n    const { password, ...userWithoutPassword } = user;\n    \n    res.json({\n      success: true,\n      data: userWithoutPassword,\n    });\n  } catch (error) {\n    console.error('Update user error:', error);\n    res.status(500).json({\n      success: false,\n      error: '更新用户失败',\n    });\n  }\n});","old_string":"// 更新用户\nrouter.put('/:id', async (req: Request, res: Response) => {\n  try {\n    const { id } = req.params;\n    const updateData = { ...req.body };\n\n    // 如果更新密码，需要加密\n    if (updateData.password) {\n      updateData.password = await bcrypt.hash(updateData.password, 10);\n    }\n\n    const user = await prisma.user.update({\n      where: { id },\n      data: updateData,\n    });\n\n    const { password, ...userWithoutPassword } = user;\n    \n    res.json({\n      success: true,\n      data: userWithoutPassword,\n    });\n  } catch (error) {\n    console.error('Update user error:', error);\n    res.status(500).json({\n      success: false,\n      error: '更新用户失败',\n    });\n  }\n});","replace_all":false},"tool_response":"Successfully edited file: /workspace/backend/src/modules/users.ts","client":"CLI","version":"2.71.1","generation_id":"c512c24fb9dc4868a26c387eb809ce1b","model":"glm-5.0","call_id":"019d8d94a8eef367c00af7cc5924f211"}
