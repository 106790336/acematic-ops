t-gray-700' },\n  medium: { label: '中', color: 'bg-blue-100 text-blue-700' },\n  high: { label: '高', color: 'bg-orange-100 text-orange-700' },\n  urgent: { label: '紧急', color: 'bg-red-100 text-red-700' },\n};\n\nconst statusLabels: Record<string, { label: string; color: string }> = {\n  pending: { label: '待确认', color: 'bg-yellow-100 text-yellow-700' },\n  confirmed: { label: '已确认', color: 'bg-blue-100 text-blue-700' },\n  in_progress: { label: '进行中', color: 'bg-cyan-100 text-cyan-700' },\n  completed: { label: '已完成', color: 'bg-green-100 text-green-700' },\n  verified: { label: '已验收', color: 'bg-emerald-100 text-emerald-700' },\n  rejected: { label: '已驳回', color: 'bg-red-100 text-red-700' },\n};\n\nexport default function TaskManagement() {\n  const [tasks, setTasks] = useState<Task[]>([]);\n  const [loading, setLoading] = useState(true);\n  const [error, setError] = useState<string | null>(null);\n  const [activeTab, setActiveTab] = useState('all');\n  const [sourceTypeFilter, setSourceTypeFilter] = useState('');\n  const [statusFilter, setStatusFilter] = useState('');\n  const [priorityFilter, setPriorityFilter] = useState('');\n  const [search, setSearch] = useState('');\n  const [showCreateDialog, setShowCreateDialog] = useState(false);\n  const [showDetailDialog, setShowDetailDialog] = useState(false);\n  const [selectedTask, setSelectedTask] = useState<Task | null>(null);\n  const [newTask, setNewTask] = useState({\n    title: '',\n    description: '',\n    sourceType: 'assigned',\n    assigneeId: '',\n    dueDate: '',\n    priority: 'medium',\n    strategicAlignment: false,\n    alignmentTarget: '',\n  });\n  const [users, setUsers] = useState<any[]>([]);\n\n  const fetchTasks = useCallback(async () => {\n    try {\n      setLoading(true);\n      setError(null);\n      const params = new URLSearchParams();\n      if (sourceTypeFilter) params.append('sourceType', sourceTypeFilter);\n      if (statusFilter) params.append('status', statusFilter);\n      if (priorityFilter) params.append('priority', priorityFilter);\n      \n      const endpoint = activeTab === 'my' ? '/tasks-v2/my' : '/tasks-v2';\n      const response = await api.get(endpoint, { params: Object.fromEntries(params) });\n      \n      if (response.data.success) {\n        const items = response.data.data.items || response.data.data;\n        if (search) {\n          setTasks(items.filter((t: Task) => t.title.toLowerCase().includes(search.toLowerCase())));\n        } else {\n          setTasks(items);\n        }\n      }\n    } catch (err: any) {\n      console.error('Failed to fetch tasks:', err);\n      setError(err.message || '获取任务失败');\n    } finally {\n      setLoading(false);\n    }\n  }, [activeTab, sourceTypeFilter, statusFilter, priorityFilter, search]);\n\n  const fetchUsers = useCallback(async () => {\n    try {\n      const response = await api.get('/users');\n      if (response.data.success) {\n        setUsers(response.data.data.items || response.data.data);\n      }\n    } catch (err) {\n      console.error('Failed to fetch users:', err);\n    }\n  }, []);\n\n  useEffect(() => {\n    fetchTasks();\n  }, [fetchTasks]);\n\n  useEffect(() => {\n    fetchUsers();\n  }, [fetchUsers]);\n\n  const handleCreateTask = async () => {\n    try {\n      if (!newTask.title || !newTask.dueDate) {\n        alert('请填写任务标题和截止日期');\n        return;\n      }\n      const response = await api.post('/tasks-v2', {\n        title: newTask.title,\n        description: newTask.description,\n        sourceType: newTask.sourceType,\n        assigneeId: newTask.assigneeId || undefined,\n        dueDate: newTask.dueDate,\n        priority: newTask.priority,\n        strategicAlignment: newTask.strategicAlignment,\n        alignmentTarget: newTask.strategicAlignment ? newTask.alignmentTarget : undefined,\n      });\n      \n      if (response.data.success) {\n        setShowCreateDialog(false);\n        fetchTasks();\n        resetNewTask();\n      } else {\n        alert(response.data.error || '创建失败');\n      }\n    } catch (err: any) {\n      console.error('Failed to create task:', err);\n      alert(err.response?.data?.error || '创建任务失败');\n    }\n  };\n\n  const handleConfirmTask = async (taskId: string) => {\n    try {\n      const response = await api.post(`/tasks-v2/${taskId}/confirm`);\n      if (response.data.success) {\n        fetchTasks();\n      }\n    } catch (err: any) {\n      alert(err.response?.data?.error || '确认任务失败');\n    }\n  };\n\n  const handleStartTask = async (taskId: string) => {\n    try {\n      const response = await api.post(`/tasks-v2/${taskId}/start`);\n      if (response.data.success) {\n        fetchTasks();\n      }\n    } catch (err: any) {\n      alert(err.response?.data?.error || '开始任务失败');\n    }\n  };\n\n  const handleApproveTask = async (taskId: string, approved: boolean, comment?: string) => {\n    try {\n      const response = await api.post(`/tasks-v2/${taskId}/approve`, {\n        approved,\n        comment,\n      });\n      if (response.data.success) {\n        fetchTasks();\n      }\n    } catch (err: any) {\n      alert(err.response?.data?.error || '审批任务失败');\n    }\n  };\n\n  const resetNewTask = () => {\n    setNewTask({\n      title: '',\n      description: '',\n      sourceType: 'assigned',\n      assigneeId: '',\n      dueDate: '',\n      priority: 'medium',\n      strategicAlignment: false,\n      alignmentTarget: '',\n    });\n  };\n\n  return (\n    <div className=\"space-y-6\">\n      <div className=\"flex items-center justify-between\">\n        <div>\n          <h1 className=\"text-2xl font-semibold\">任务管理</h1>\n          <p className=\"text-sm mt-1 text-muted-foreground\">任务来源追溯 · 战略对齐管理</p>\n        </div>\n        <Button onClick={() => setShowCreateDialog(true)}>\n          <Plus className=\"w-4 h-4 mr-2\" />\n          新建任务\n        </Button>\n      </div>\n\n      <Card>\n        <CardContent className=\"pt-4\">\n          <div className=\"flex flex-wrap gap-4\">\n       