iv className=\"grid gap-2\">\n                <Label>负责人</Label>\n                <Select\n                  value={newTask.assigneeId}\n                  onValueChange={(value) => setNewTask({ ...newTask, assigneeId: value })}\n                >\n                  <SelectTrigger>\n                    <SelectValue placeholder=\"选择负责人\" />\n                  </SelectTrigger>\n                  <SelectContent>\n                    {users.map((u) => (\n                      <SelectItem key={u.id} value={u.id}>{u.name}</SelectItem>\n                    ))}\n                  </SelectContent>\n                </Select>\n              </div>\n            </div>\n            <div className=\"grid grid-cols-2 gap-4\">\n              <div className=\"grid gap-2\">\n                <Label>截止日期</Label>\n                <Input\n                  type=\"date\"\n                  value={newTask.dueDate}\n                  onChange={(e) => setNewTask({ ...newTask, dueDate: e.target.value })}\n                />\n              </div>\n              <div className=\"grid gap-2\">\n                <Label>优先级</Label>\n                <Select\n                  value={newTask.priority}\n                  onValueChange={(value: any) => setNewTask({ ...newTask, priority: value })}\n                >\n                  <SelectTrigger>\n                    <SelectValue />\n                  </SelectTrigger>\n                  <SelectContent>\n                    <SelectItem value=\"low\">低</SelectItem>\n                    <SelectItem value=\"medium\">中</SelectItem>\n                    <SelectItem value=\"high\">高</SelectItem>\n                    <SelectItem value=\"urgent\">紧急</SelectItem>\n                  </SelectContent>\n                </Select>\n              </div>\n            </div>\n            <div className=\"flex items-center gap-4 pt-2\">\n              <div className=\"flex items-center gap-2\">\n                <input\n                  type=\"checkbox\"\n                  id=\"strategicAlignment\"\n                  checked={newTask.strategicAlignment}\n                  onChange={(e) => setNewTask({ ...newTask, strategicAlignment: e.target.checked })}\n                  className=\"w-4 h-4\"\n                />\n                <Label htmlFor=\"strategicAlignment\" className=\"flex items-center gap-1 cursor-pointer\">\n                  <Target className=\"w-4 h-4\" />\n                  战略对齐\n                </Label>\n              </div>\n              {newTask.strategicAlignment && (\n                <Input\n                  value={newTask.alignmentTarget}\n                  onChange={(e) => setNewTask({ ...newTask, alignmentTarget: e.target.value })}\n                  placeholder=\"对齐目标说明\"\n                  className=\"flex-1\"\n                />\n              )}\n            </div>\n          </div>\n          <DialogFooter>\n            <Button variant=\"outline\" onClick={() => setShowCreateDialog(false)}>取消</Button>\n            <Button onClick={handleCreateTask} style={{ background: 'oklch(0.75 0.18 75)', color: 'oklch(0.18 0.02 250)' }}>\n              创建任务\n            </Button>\n          </DialogFooter>\n        </DialogContent>\n      </Dialog>\n\n      {/* 任务详情对话框 */}\n      <Dialog open={showDetailDialog} onOpenChange={setShowDetailDialog}>\n        <DialogContent className=\"max-w-2xl\">\n          <DialogHeader>\n            <DialogTitle>任务详情</DialogTitle>\n          </DialogHeader>\n          {selectedTask && (\n            <div className=\"space-y-4\">\n              <div className=\"flex items-center justify-between\">\n                <div>\n                  <div className=\"text-sm text-muted-foreground\">{selectedTask.taskNumber}</div>\n                  <div className=\"text-xl font-semibold\">{selectedTask.title}</div>\n                </div>\n                <Badge className={statusLabels[selectedTask.status]?.color}>\n                  {statusLabels[selectedTask.status]?.label}\n               