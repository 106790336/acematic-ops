lse);\n  const [formData, setFormData] = useState({\n    title: '',\n    description: '',\n    type: 'department' as 'company' | 'department' | 'personal',\n    strategyId: '',\n    departmentId: '',\n    startDate: '',\n    endDate: '',\n    priority: 'medium' as 'high' | 'medium' | 'low',\n  });\n\n  const { plans, loading, error, createPlan, updatePlan, deletePlan } = usePlans({\n    search,\n    status: statusFilter !== 'all' ? statusFilter : undefined,\n    type: typeFilter !== 'all' ? typeFilter : undefined,\n    strategyId: strategyFilter !== 'all' ? strategyFilter : undefined,\n  });\n\n  const { strategies } = useStrategies();\n  const { departments } = useDepartments();\n\n  const handleSubmit = async (e: React.FormEvent) => {\n    e.preventDefault();\n    try {\n      setSubmitting(true);\n      if (editingPlan) {\n        await updatePlan(editingPlan.id, formData);\n      } else {\n        await createPlan(formData);\n      }\n      setDialogOpen(false);\n      resetForm();\n    } catch (err: any) {\n      alert(err.message);\n    } finally {\n      setSubmitting(false);\n    }\n  };\n\n  const handleEdit = (plan: Plan) => {\n    setEditingPlan(plan);\n    setFormData({\n      title: plan.title,\n      description: plan.description || '',\n      type: plan.type,\n      strategyId: plan.strategyId || '',\n      departmentId: plan.departmentId || '',\n      startDate: plan.startDate.split('T')[0],\n      endDate: plan.endDate.split('T')[0],\n      priority: plan.priority,\n    });\n    setDialogOpen(true);\n  };\n\n  const handleDelete = async (id: string) => {\n    if (confirm('确定要删除这个计划吗？')) {\n      try {\n        await deletePlan(id);\n      } catch (err: any) {\n        alert(err.message);\n      }\n    }\n  };\n\n  const resetForm = () => {\n    setFormData({\n      title: '',\n      description: '',\n      type: 'department',\n      strategyId: '',\n      departmentId: '',\n      startDate: '',\n      endDate: '',\n      priority: 'medium',\n    });\n    setEditingPlan(null);\n  };\n\n  const statusStyles: Record<string, string> = {\n    pending: 'bg-gray-100 text-gray-700',\n    in_progress: '',\n    completed: 'bg-green-100 text-green-700',\n    cancelled: 'bg-gray-100 text-gray-500',\n  };\n\n  const statusLabels: Record<string, string> = {\n    pending: '待开始',\n    in_progress: '进行中',\n    completed: '已完成',\n    cancelled: '已取消',\n  };\n\n  const priorityStyles: Record<string, string> = {\n    high: 'bg-red-100 text-red-700',\n    medium: 'bg-blue-100 text-blue-700',\n    low: 'bg-gray-100 text-gray-700',\n  };\n\n  const priorityLabels: Record<string, string> = {\n    high: '高',\n    medium: '中',\n    low: '低',\n  };\n\n  const typeLabels: Record<string, string> = {\n    company: '公司级',\n    department: '部门级',\n    personal: '个人',\n  };\n\n  if (error) {\n    return (\n      <div className=\"flex items-center justify-center h-64\">\n        <div className=\"text-center\">\n          <AlertCircle className=\"w-12 h-12 mx-auto text-destructive mb-4\" />\n          <p className=\"text-destructive\">{error}</p>\n        </div>\n      </div>\n    );\n  }\n\n  return (\n    <div className=\"space-y-6\">\n      <FadeIn>\n        <div className=\"flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4\">\n          <div>\n            <h1 className=\"font-bold\" style={{ fontSize: 'var(--font-size-headline)' }}>\n              计划管理\n            </h1>\n            <p className=\"text-muted-foreground\" style={{ fontSize: 'var(--font-size-label)' }}>\n              管理部门和个人的工作计划，关联战略目标\n            </p>\n          </div>\n          <Button onClick={() => { resetForm(); setDialogOpen(true); }}>\n            <Plus className=\"w-4 h-4 mr-2\" />\n            新建计划\n          </Button>\n        </div>\n      </FadeIn>\n\n      <FadeIn>\n        <Card>\n          <CardHeader>\n            <div className=\"flex flex-col sm:flex-row gap-4\">\n              <div className=\"relative flex-1\">\n                <Search className=\"absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-muted-foreground\" />\n                <Input\n                  placeholder=\"搜索计划...\"\n                  value={search}\n                  onChange={(e) => setSearch(e.target.value)}\n                  className=\"pl-10\"\n                />\n              </div>\n              <Select value={strategyFilter} onValueChange={setStrategyFilter}>\n                <SelectTrigger className=\"w-[160px]\">\n                  <SelectValue placeholder=\"关联战略\" />\n                </SelectTrigger>\n                <SelectContent>\n                  <SelectItem value=\"all\">全部战略</SelectItem>\n                  {strategies.map((s) => (\n                    <SelectItem key={s.id} value={s.id}>{s.title}</SelectItem>\n                  ))}\n                </SelectContent>\n              </Select>\n              <Select value={typeFilter} onValueChange={setTypeFilter}>\n                <SelectTrigger className=\"w-[120px]\">\n                  <SelectValue placeholder=\"类型\" />\n                </SelectTrigger>\n                <SelectContent>\n                  <SelectItem value=\"all\">全部类型</SelectItem>\n                  <SelectItem value=\"company\">公司级</SelectItem>\n                  <SelectItem value=\"department\">部门级</SelectItem>\n                  <SelectItem value=\"personal\">个人</SelectItem>\n                </SelectContent>\n              </Select>\n              <Select value={statusFilter} onValueChange={setStatusFilter}>\n                <SelectTrigger className=\"w-[120px]\">\n                  <SelectValue placeholder=\"状态\" />\n                </SelectTrigger>\n                <SelectContent>\n                  <SelectItem value=\"all\">全部状态</SelectItem>\n                  <SelectItem value=\"in_progress\">进行中</SelectItem>\n                  <SelectItem value=\"completed\">已完成</SelectItem>\n                  <SelectItem value=\"pending\">待开始</SelectItem>\n                </SelectContent>\n              </Select>\n            </div>\n          </CardHeader>\n          <CardContent>\n            {loading ? (\n              <div className=\"space-y-4\">\n                {[1, 2, 3].map((i) => (\n                  <Skeleton key={i} className=\"h-16\" />\n                ))}\n              </div>\n            ) : (\n              <div className=\"overflow-x-auto\">\n                <Table>\n                  <TableHeader>\n                    <TableRow>\n                      <TableHead>计划名称</TableHead>\n                      <TableHead>类型</TableHead>\n                      <TableHead>关联战略</TableHead>\n                      <TableHead>部门</TableHead>\n                      <TableHead>状态</TableHead>\n                      <TableHead>进度</TableHead>\n                      <TableHead>优先级</TableHead>\n                      <TableHead className=\"text-right\">操作</TableHead>\n                    </TableRow>\n                  </TableHeader>\n                  <TableBody>\n                    {plans.map((plan) => (\n                      <TableRow key={plan.id}>\n                        <TableCell>\n                          <div className=\"flex items-center gap-3\">\n                            <div className=\"p-2 rounded-lg\" style={{ background: 'var(--muted)' }}>\n                              <ClipboardList className=\"w-4 h-4\" style={{ color: 'oklch(0.75 0.18 75)' }} />\n                            </div>\n                            <div>\n                              <div className=\"font-medium\">{plan.title}</div>\n                              <div className=\"text-xs text-muted-foreground\">\n                                负责人: {plan.owner?.name || '-'}\n                              </div>\n                            </div>\n                          </div>\n                        </TableCell>\n                        <TableCell>\n                          <Badge variant=\"outline\">{typeLabels[plan.type]}</Badge>\n                        </TableCell>\n                        <TableCell>\n                          {plan.strategy ? (\n                            <div className=\"flex items-center gap-1 text-sm\">\n                              <Link className=\"w-3 h-3 text-green-600\" />\n                              <span className=\"text-green-600 font-medium\">{plan.strategy.title}</span>\n                            </div>\n                          ) : (\n                            <span className=\"text-muted-foreground text-sm\">未关联</span>\n                          )}\n                        </TableCell>\n                        <TableCell>{plan.department?.name || '-'}</TableCell>\n                        <TableCell>\n                          <Badge className={statusStyles[plan.status]}>\n                            {statusLabels[plan.status]}\n                          </Badge>\n                        </TableCell>\n                        <TableCell>\n                          <div className=\"flex items-center gap-2\">\n                            <Progress value={plan.progress} className=\"w-20 h-2\" />\n                            <span className=\"text-sm\">{plan.progress}%</span>\n                          </div>\n                        </TableCell>\n                        <TableCell>\n                          <Badge className={priorityStyles[plan.priority]}>\n                            {priorityLabels[plan.priority]}\n                          </Badge>\n                        </TableCell>\n                        <TableCell className=\"text-right\">\n                          <Button variant=\"ghost\" size=\"sm\" onClick={() => handleEdit(plan)}>\n                            <Edit className=\"w-4 h-4\" />\n                          </Button>\n                          <Button variant=\"ghost\" size=\"sm\" onClick={() => handleDelete(plan.id)}>\n                            <Trash2 className=\"w-4 h-4 text-destructive\" />\n                          </Button>\n                        </TableCell>\n                      </TableRow>\n                    ))}\n                    {plans.length === 0 && (\n                      <TableRow>\n                        <TableCell colSpan={8} className=\"text-center py-8 text-muted-foreground\">\n                          暂无数据\n                        </TableCell>\n                      </TableRow>\n                    )}\n                  </TableBody>\n                </Table>\n              </div>\n            )}\n          </CardContent>\n        </Card>\n      </FadeIn>\n\n      {/* 新建/编辑对话框 */}\n      <Dialog open={dialogOpen} onOpenChange={setDialogOpen}>\n        <DialogContent>\n          <DialogHeader>\n            <DialogTitle>{editingPlan ? '编辑计划' : '新建计划'}</DialogTitle>\n          </DialogHeader>\n          <form onSubmit={handleSubmit} className=\"space-y-4\">\n            <div className=\"space-y-2\">\n              <Label htmlFor=\"title\">计划名称 *</Label>\n              <Input\n                id=\"title\"\n                value={formData.title}\n                onChange={(e) => setFormData({ ...formData, title: e.target.value })}\n                required\n              />\n            </div>\n            <div className=\"space-y-2\">\n              <Label htmlFor=\"description\">计划描述</Label>\n              <Textarea\n                id=\"description\"\n                value={formData.description}\n                onChange={(e) => setFormData({ ...formData, description: e.target.value })}\n                rows={3}\n              />\n            </div>\n            <div className=\"grid grid-cols-2 gap-4\">\n              <div className=\"space-y-2\">\n                <Label htmlFor=\"strategy\">关联战略</Label>\n                <Select value={formData.strategyId} onValueChange={(v) => setFormData({ ...formData, strategyId: v })}>\n                  <SelectTrigger>\n                    <SelectValue placeholder=\"选择战略（可选）\" />\n                  </SelectTrigger>\n                  <SelectContent>\n                    <SelectItem value=\"\">不关联</SelectItem>\n                    {strategies.map((s) => (\n                      <SelectItem key={s.id} value={s.id}>\n                        <div className=\"flex items-center gap-1\">\n                          <Target className=\"w-3 h-3\" />\n                          {s.title}\n                        </div>\n                      </SelectItem>\n                    ))}\n                  </SelectContent>\n                </Select>\n              </div>\n              <div className=\"space-y-2\">\n                <Label htmlFor=\"type\">计划类型</Label>\n                <Select value={formData.type} onValueChange={(v) => setFormData({ ...formData, type: v as any })}>\n                  <SelectTrigger>\n                    <SelectValue />\n                  </SelectTrigger>\n                  <SelectContent>\n                    <SelectItem value=\"company\">公司级</SelectItem>\n                    <SelectItem value=\"department\">部门级</SelectItem>\n                    <SelectItem value=\"personal\">个人</SelectItem>\n                  </SelectContent>\n                </Select>\n              </div>\n            </div>\n            <div className=\"grid grid-cols-2 gap-4\">\n              <div className=\"space-y-2\">\n                <Label htmlFor=\"department\">所属部门</Label>\n                <Select value={formData.departmentId} onValueChange={(v) => setFormData({ ...formData, departmentId: v })}>\n                  <SelectTrigger>\n                    <SelectValue placeholder=\"选择部门\" />\n                  </SelectTrigger>\n                  <SelectContent>\n                    <SelectItem value=\"\">不指定</SelectItem>\n                    {departments.map((dept) => (\n                      <SelectItem key={dept.id} value={dept.id}>\n                        {dept.name}\n                      </SelectItem>\n                    ))}\n                  </SelectContent>\n                </Select>\n              </div>\n              <div className=\"space-y-2\">\n                <Label htmlFor=\"priority\">优先级</Label>\n                <Select value={formData.priority} onValueChange={(v) => setFormData({ ...formData, priority: v as any })}>\n                  <SelectTrigger>\n                    <SelectValue />\n                  </SelectTrigger>\n                  <SelectContent>\n                    <SelectItem value=\"high\">高</SelectItem>\n                    <SelectItem value=\"medium\">中</SelectItem>\n                    <SelectItem value=\"low\">低</SelectItem>\n                  </SelectContent>\n                </Select>\n              </div>\n            </div>\n            <div className=\"grid grid-cols-2 gap-4\">\n              <div className=\"space-y-2\">\n                <Label htmlFor=\"startDate\">开始日期 *</Label>\n                <Input\n                  id=\"startDate\"\n                  type=\"date\"\n                  value={formData.startDate}\n                  onChange={(e) => setFormData({ ...formData, startDate: e.target.value })}\n                  required\n                />\n              </div>\n              <div className=\"space-y-2\">\n                <Label htmlFor=\"endDate\">结束日期 *</Label>\n                <Input\n                  id=\"endDate\"\n                  type=\"date\"\n                  value={formData.endDate}\n                  onChange={(e) => setFormData({ ...formData, endDate: e.target.value })}\n                  required\n                />\n              </div>\n            </div>\n            <DialogFooter>\n              <Button type=\"button\" variant=\"outline\" onClick={() => setDialogOpen(false)}>\n                取消\n              </Button>\n              <Button type=\"submit\" disabled={submitting}>\n                {submitting ? '提交中...' : (editingPlan ? '保存' : '创建')}\n              </Button>\n            </DialogFooter>\n          </form>\n        </DialogContent>\n      </Dialog>\n    </div>\n  );\n}\n"},"tool_response":"