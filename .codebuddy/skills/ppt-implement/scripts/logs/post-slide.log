[2026-04-11 06:33:38] [DEBUG] [PPT PostToolUse Hook] stdin 数据: {"session_id":"2040121509614309376","transcript_path":"/root/.codebuddy/projects/workspace/2040121509614309376.jsonl","cwd":"/workspace","hook_event_name":"PostToolUse","tool_name":"Write","tool_input":{"content":"import { useState, useEffect } from 'react';\nimport { Card, CardContent } from '@/components/ui/card';\nimport { Button } from '@/components/ui/button';\nimport { Input } from '@/components/ui/input';\nimport { Badge } from '@/components/ui/badge';\nimport { Progress } from '@/components/ui/progress';\nimport { Skeleton } from '@/components/ui/skeleton';\nimport {\n  Table, TableBody, TableCell, TableHead, TableHeader, TableRow,\n} from '@/components/ui/table';\nimport {\n  Dialog, DialogContent, DialogHeader, DialogTitle, DialogFooter,\n} from '@/components/ui/dialog';\nimport { Label } from '@/components/ui/label';\nimport { Textarea } from '@/components/ui/textarea';\nimport { FadeIn } from '@/components/MotionPrimitives';\nimport { Plus, Edit, Trash2, Target } from 'lucide-react';\nimport { apiClient } from '@/lib/api-client';\nimport type { Strategy } from '@/types';\n\nexport default function StrategyList() {\n  const [list, setList] = useState<Strategy[]>([]);\n  const [loading, setLoading] = useState(true);\n  const [showDialog, setShowDialog] = useState(false);\n  const [editItem, setEditItem] = useState<Strategy | null>(null);\n  const [saving, setSaving] = useState(false);\n  const [form, setForm] = useState({\n    title: '',\n    description: '',\n    year: new Date().getFullYear(),\n    startDate: '',\n    endDate: '',\n  });\n\n  // 加载数据 - 使用useEffect避免无限循环\n  useEffect(() => {\n    const loadData = async () => {\n      try {\n        setLoading(true);\n        const res = await apiClient.get('/strategies?limit=100');\n        if (res.data.success) {\n          setList(res.data.data?.items || []);\n        }\n      } catch (e) {\n        console.error(e);\n      } finally {\n        setLoading(false);\n      }\n    };\n    loadData();\n  }, []);\n\n  // 提交\n  const handleSubmit = async (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!form.title.trim() || !form.startDate || !form.endDate) {\n      alert('请填写必填项');\n      return;\n    }\n    try {\n      setSaving(true);\n      if (editItem) {\n        await apiClient.put(`/strategies/${editItem.id}`, form);\n      } else {\n        await apiClient.post('/strategies', form);\n      }\n      setShowDialog(false);\n      resetForm();\n      // 重新加载数据\n      const res = await apiClient.get('/strategies?limit=100');\n      if (res.data.success) setList(res.data.data?.items || []);\n    } catch (err: any) {\n      alert(err.response?.data?.error || '操作失败');\n    } finally {\n      setSaving(false);\n    }\n  };\n\n  // 编辑\n  const onEdit = (item: Strategy) => {\n    setEditItem(item);\n    setForm({\n      title: item.title,\n      description: item.description || '',\n      year: item.year,\n      startDate: item.startDate.split('T')[0],\n      endDate: item.endDate.split('T')[0],\n    });\n    setShowDialog(true);\n  };\n\n  // 删除\n  const onDelete = async (id: string) => {\n    if (!confirm('确定删除？')) return;\n    try {\n      await apiClient.delete(`/strategies/${id}`);\n      const res = await apiClient.get('/strategies?limit=100');\n      if (res.data.success) setList(res.data.data?.items || []);\n    } catch (err: any) {\n      alert(err.response?.data?.error || '删除失败');\n    }\n  };\n\n  // 重置\n  const resetForm = () => {\n    setEditItem(null);\n    setForm({\n      title: '',\n      description: '',\n      year: new Date().getFullYear(),\n      startDate: '',\n      endDate: '',\n    });\n  };\n\n  // 打开新建\n  const openCreate = () => {\n    resetForm();\n    setShowDialog(true);\n  };\n\n  // 对话框关闭\n  const onDialogChange = (open: boolean) => {\n    setShowDialog(open);\n    if (!open) resetForm();\n  };\n\n  const statusMap: Record<string, { label: string; class: string }> = {\n    draft: { label: '草稿', class: 'bg-gray-100 text-gray-700' },\n    active: { label: '进行中', class: 'bg-blue-100 text-blue-700' },\n    completed: { label: '已完成', class: 'bg-green-100 text-green-700' },\n  };\n\n  return (\n    <div className=\"space-y-6\">\n      <FadeIn>\n        <div className=\"flex items-center justify-between\">\n          <div>\n            <h1 className=\"font-bold text-2xl\">战略管理</h1>\n            <p className=\"text-muted-foreground text-sm\">管理公司战略目标</p>\n          </div>\n          <Button onClick={openCreate}>\n            <Plus className=\"w-4 h-4 mr-2\" />新建战略\n          </Button>\n        </div>\n      </FadeIn>\n\n      <FadeIn>\n        <Card>\n          <CardContent className=\"pt-6\">\n            {loading ? (\n              <div className=\"space-y-3\">{[1,2,3].map(i => <Skeleton key={i} className=\"h-16\" />)}</div>\n            ) : list.length === 0 ? (\n              <div className=\"text-center py-12 text-muted-foreground\">暂无数据</div>\n            ) : (\n              <Table>\n                <TableHeader>\n                  <TableRow>\n                    <TableHead>名称</TableHead>\n                    <TableHead>年度</TableHead>\n                    <TableHead>状态</TableHead>\n                    <TableHead>进度</TableHead>\n                    <TableHead>操作</TableHead>\n                  </TableRow>\n                </TableHeader>\n                <TableBody>\n                  {list.map(item => (\n                    <TableRow key={item.id}>\n                      <TableCell>\n                        <div className=\"flex items-center gap-2\">\n                          <Target className=\"w-4 h-4 text-blue-500\" />\n                          <span className=\"font-medium\">{item.title}</span>\n                        </div>\n                      </TableCell>\n                      <TableCell>{item.year}</TableCell>\n                      <TableCell>\n                        <Badge className={statusMap[item.status]?.class || ''}>\n                          {statusMap[item.status]?.label || item.status}\n                        </Badge>\n                      </TableCell>\n                      <TableCell>\n                        <div className=\"flex items-center gap-2\">\n                          <Progress value={item.progress} className=\"w-16 h-2\" />\n                          <span className=\"text-sm\">{item.progress}%</span>\n                        </div>\n                      </TableCell>\n                      <TableCell>\n                        <Button variant=\"ghost\" size=\"sm\" onClick={() => onEdit(item)}>\n                          <Edit className=\"w-4 h-4\" />\n                        </Button>\n                        <Button variant=\"ghost\" size=\"sm\" onClick={() => onDelete(item.id)}>\n                          <Trash2 className=\"w-4 h-4 text-destructive\" />\n                        </Button>\n                      </TableCell>\n                    </TableRow>\n                  ))}\n                </TableBody>\n              </Table>\n            )}\n          </CardContent>\n        </Card>\n      </FadeIn>\n\n      {/* 新建/编辑对话框 */}\n      <Dialog open={showDialog} onOpenChange={onDialogChange}>\n        <DialogContent>\n          <DialogHeader>\n            <DialogTitle>{editItem ? '编辑战略' : '新建战略'}</DialogTitle>\n          </DialogHeader>\n          <form onSubmit={handleSubmit} className=\"space-y-4\">\n            <div className=\"space-y-2\">\n              <Label>战略名称 *</Label>\n              <Input\n                value={form.title}\n                onChange={e => setForm({...form, title: e.target.value})}\n                placeholder=\"输入名称\"\n                required\n              />\n            </div>\n            <div className=\"space-y-2\">\n              <Label>描述</Label>\n              <Textarea\n                value={form.description}\n                onChange={e => setForm({...form, description: e.target.value})}\n                rows={2}\n              />\n            </div>\n            <div className=\"grid grid-cols-3 gap-4\">\n              <div className=\"space-y-2\">\n                <Label>年度</Label>\n                <Input\n                  type=\"number\"\n                  value={form.year}\n                  onChange={e => setForm({...form, year: parseInt(e.target.value) || 2026})}\n                />\n              </div>\n              <div className=\"space-y-2\">\n                <Label>开始日期 *</Label>\n                <Input\n                  type=\"date\"\n                  value={form.startDate}\n                  onChange={e => setForm({...form, startDate: e.target.value})}\n                  required\n                />\n              </div>\n              <div className=\"space-y-2\">\n                <Label>结束日期 *</Label>\n                <Input\n                  type=\"date\"\n                  value={form.endDate}\n                  onChange={e => setForm({...form, endDate: e.target.value})}\n                  required\n                />\n              </div>\n            </div>\n            <DialogFooter>\n              <Button type=\"button\" variant=\"outline\" onClick={() => setShowDialog(false)}>取消</Button>\n              <Button type=\"submit\" disabled={saving}>\n                {saving ? '提交中...' : (editItem ? '保存' : '创建')}\n              </Button>\n            </DialogFooter>\n          </form>\n        </DialogContent>\n      </Dialog>\n    </div>\n  );\n}\n","file_path":"/workspace/frontend/src/pages/StrategyList.tsx"},"tool_response":"Successfully overwrote file: /workspace/frontend/src/pages/StrategyList.tsx","client":"CLI","version":"2.71.1","generation_id":"f04c3d952d204116884db8912a8b2909","model":"glm-5.0","call_id":"019d7b3e5ab53a2d2b79c3f79c754e07"}
