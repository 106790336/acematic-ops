eAuth();\n\n  // 检查是否有权限\n  const hasPermission = (permission: string): boolean => {\n    // CEO 有所有权限\n    if (user?.role === 'ceo') return true;\n    \n    // 高管有大部分权限\n    if (user?.role === 'executive') {\n      const executiveBlocked = ['settings:edit', 'role:manage'];\n      return !executiveBlocked.includes(permission);\n    }\n    \n    // 经理有限权限\n    if (user?.role === 'manager') {\n      const managerAllowed = [\n        'user:view', 'dept:view', 'strategy:view', 'plan:view', 'task:view',\n        'plan:create', 'plan:edit', 'task:create', 'task:edit',\n      ];\n      return managerAllowed.includes(permission);\n    }\n    \n    // 员工基本权限\n    const employeeAllowed = ['task:view', 'task:create', 'task:edit'];\n    return employeeAllowed.includes(permission);\n  };","replace_all":false},"tool_response":"Successfully edited file: /workspace/frontend/src/hooks/use-permission.ts","client":"CLI","version":"2.71.1","generation_id":"2e86f9f10128441cbd26626e66295737","model":"glm-5.0","call_id":"019d8d7adfc1dd01c16547f7c2a3816d"}
