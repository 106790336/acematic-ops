"text-muted-foreground\">-</span>\n                          )}\n                        </TableCell>\n                        <TableCell>\n                          <Badge variant=\"secondary\" className=\"gap-1\">\n                            <Users className=\"w-3 h-3\" />\n                            {dept.memberCount}\n                          </Badge>\n                        </TableCell>\n                        <TableCell className=\"text-right\">\n                          <Button variant=\"ghost\" size=\"sm\" onClick={() => handleEdit(dept)}>\n                            <Edit className=\"w-4 h-4\" />\n                          </Button>\n                          <Button variant=\"ghost\" size=\"sm\" onClick={() => handleDelete(dept.id)}>\n                            <Trash2 className=\"w-4 h-4 text-destructive\" />\n                          </Button>\n                        </TableCell>\n                      </TableRow>\n                    ))}\n                    {departments.length === 0 && (\n                      <TableRow>\n                        <TableCell colSpan={5} className=\"text-center py-8 text-muted-foreground\">\n                          暂无数据\n                        </TableCell>\n                      </TableRow>\n                    )}\n                  </TableBody>\n                </Table>\n              </div>\n            )}\n          </CardContent>\n        </Card>\n      </FadeIn>\n\n      {/* 新建/编辑对话框 */}\n      <Dialog open={dialogOpen} onOpenChange={setDialogOpen}>\n        <DialogContent>\n          <DialogHeader>\n            <DialogTitle>{editingDept ? '编辑部门' : '新建部门'}</DialogTitle>\n          </DialogHeader>\n          <form onSubmit={handleSubmit} className=\"space-y-4\">\n            <div className=\"space-y-2\">\n              <Label htmlFor=\"name\">部门名称</Label>\n              <Input\n                id=\"name\"\n                value={formData.name}\n                onChange={(e) => setFormData({ ...formData, n