een-600\"><Target className=\"w-4 h-4\" /><span className=\"text-xs\">已对齐</span></div>\n                              : <div className=\"flex items-center gap-1 text-orange-500\"><AlertTriangle className=\"w-4 h-4\" /><span className=\"text-xs\">未对齐</span></div>}\n                          </TableCell>\n                          <TableCell><Badge className={statusConfig[task.status]?.className}>{statusConfig[task.status]?.label}</Badge></TableCell>\n                          <TableCell>\n                            <div className=\"flex items-center gap-1 text-sm\">\n                              <div className=\"w-12 h-1.5 rounded-full bg-gray-200\">\n                                <div className=\"h-full rounded-full bg-blue-500\" style={{ width: `${task.progress}%` }} />\n                              </div>\n                              <span className=\"text-xs\">{task.progress}%</span>\n                            </div>\n                          </TableCell>\n                          <TableCell>\n                            <div className=\"flex items-center gap-1\">\n                              {/* 建派人权限：编辑、删除 */}\n                              {canEdit(task) && (\n                                <>\n                                  <Button variant=\"ghost\" size=\"sm\" onClick={() => openEditDialog(task)} title=\"编辑任务\">\n                                    <Edit className=\"w-4 h-4\" />\n                                  </Button>\n                                  <Button variant=\"ghost\" size=\"sm\" onClick={() => handleDelete(task)} title=\"删除任务\">\n                                    <Trash2 className=\"w-4 h-4 text-destructive\" />\n                                  </Button>\n                                </>\n                              )}\n                              {/* 指派对象权限：填写成果 */}\n                              {canEditResult(task) && (\n                                <Button variant=\"ghost\" size=\"sm\" onClick={() => openResultDialog(task)} title=\"填写执行成果\">\n                                  <FileCheck className=\"w-4 h-4 text-green-600\" />\n                                </Button>\n                              )}\n                              {/* 状态流转 */}\n                              {task.status === 'pending' && task.sourceType === 'assigned' && (\n                                <Button size=\"sm\" variant=\"outline\" onClick={() => handleConfirm(task.id)}>\n                                  <CheckCircle className=\"w-3.5 h-3.5 mr-1\" />确认\n                                </Button>\n                              )}\n                              {task.status === 'confirmed' && (\n                                <Button size=\"sm\" variant=\"outline\" onClick={() => handleStart(task.id)}>\n                                  <Play className=\"w-3.5 h-3.5 mr-1\" />开始\n                                </Button>\n                              )}\n                              {task.status === 'pending' && task.sourceType === 'self_initiated' && (\n                                <>\n                                  <Button size=\"sm\" onClick={() => handleApprove(task.id, true)}>通过</Button>\n                                  <Button size=\"sm\" variant=\"destructive\" onClick={() => handleApprove(task.id, false)}>驳回</Button>\n                                </>\n                              )}\n                            </div>\n                          </TableCell>\n                        </TableRow>\n                      ))}\n                    </TableBody>\n                  </Table>\n                </div>\n              )}\n            </CardContent>\n          </Card>\n        </TabsContent>\n      </Tabs>\n\n      {/* 新建/编辑/填写成果对话框 */}\n      <Dialog open={showDialog} onOpenChange={setShowDialog}>\n        <DialogContent className=\"max-w-2xl\">\n          <DialogHeader>\n            <DialogTitle>{dialogTitle}</DialogTitle>\n          </DialogHeader>\n\n          {dialogMode === 'result' ? (\n            /* ---- 填写执行成果 ---- */\n            <div className=\"grid gap-4 py-4\">\n              <div className=\"p-3 rounded-lg bg-muted/50 text-sm\">\n                <div className=\"font-medium mb-1\">任务：{editingTask?.title}</div>\n                <div className=\"text-muted-foreground\">截止日期：{editingTask ? formatDate(editingTask.dueDate) : ''}</div>\n              </div>\n              <div className=\"grid gap-2\">\n                <Label>当前进度 ({resultData.progress}%)</Label>\n                <Input\n                  type=\"range\" min=\"0\" max=\"100\" value={resultData.progress}\n                  onChange={(e) => setResultData({ ...resultData, progress: parseInt(e.target.value) })}\n                  className=\"w-full\"\n                />\n              </div>\n              <div className=\"grid gap-2\">\n                <Label>执行成果</Label>\n                <Textarea\n                  placeholder=\"描述今日完成的成果、遇到的问题...\"\n                  value={resultData.result}\n                  onChange={(e) => setResultData({ ...resultData, result: e.target.value })}\n                  rows={4}\n                />\n              </div>\n            </div>\n          ) : (\n            /* ---- 新建/编辑 ---- */\n            <div className=\"grid gap-4 py-4\">\n              <div className=\"grid gap-2\">\n                <Label>任务标题 *</Label>\n                <Input value={formData.title} onChange={(e) => setFormData({ ...formData, title: e.target.value })} placeholder=\"输入任务标题\" />\n              </div>\n              <div className=\"grid gap-2\">\n                <Label>任务描述</Label>\n                <Textarea value={formData.description} onChange={(e) => setFormData({ ...formData, description: e.target.value })} placeholder=\"输入任务描述\" rows={3} />\n              </div>\n              <div className=\"space-y-2\">\n                <Label className=\"flex items-center gap-2\"><Link className=\"w-4 h-4\" />关联计划（战略落地）</Label>\n                <Select value={formData.planId} onValueChange={(v) => setFormData({ ...formData, planId: v })}>\n                  <SelectTrigger><SelectValue placeholder=\"选择关联计划（可选）\" /></SelectTrigger>\n                  <SelectContent>\n                    <SelectItem value=\"\">不关联计划</SelectItem>\n                    {plans.map((p) => (\n                      <SelectItem key={p.id} value={p.id}>\n                        <div className=\"flex items-center gap-2\">\n                          {p.strategy && <span className=\"text-purple-600 text-xs\">[{p.strategy.title}]</span>}\n                          <span>{p.title}</span>\n                        </div>\n                      </SelectItem>\n                    ))}\n                  </SelectContent>\n                </Select>\n                {selectedPlan && (\n                  <div className=\"p-3 rounded-lg bg-muted/50 text-sm\">\n                    <div className=\"flex items-center gap-1 text-muted-foreground mb-1\">关联链路：</div>\n                    <div className=\"flex items-center gap-1 flex-wrap\">\n                      {selectedPlan.strategy && (\n                        <>\n                          <Badge variant=\"outline\" className=\"text-purple-600 border-purple-200\"><Target className=\"w-3 h-3 mr-1\" />{selectedPlan.strategy.title}</Badge>\n                          <ChevronRight className=\"w-4 h-4 text-muted-foreground\" />\n                        </>\n                      )}\n                      <Badge variant=\"outline\" className=\"text-blue-600 border-blue-200\"><Link className=\"w-3 h-3 mr-1\" />{selectedPlan.title}</Badge>\n                      <ChevronRight className=\"w-4 h-4 text-muted-foreground\" />\n                      <Badge variant=\"outline\" className=\"text-green-600 border-green-200\">本任务</Badge>\n                    </div>\n                  </div>\n                )}\n              </div>\n              <div className=\"grid grid-cols-2 gap-4\">\n                <div className