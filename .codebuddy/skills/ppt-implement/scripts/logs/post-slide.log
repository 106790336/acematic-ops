[2026-04-09 04:53:57] [DEBUG] [PPT PostToolUse Hook] stdin 数据: {"session_id":"2040121509614309376","transcript_path":"/root/.codebuddy/projects/workspace/2040121509614309376.jsonl","cwd":"/workspace","hook_event_name":"PostToolUse","tool_name":"Edit","tool_input":{"file_path":"/workspace/backend/prisma/schema.prisma","new_string":"// 改进措施表\nmodel ImprovementMeasure {\n  id              String   @id @default(cuid())\n  measureNumber   String   @unique\n  issueId         String?\n  description     String\n  responsibleId   String\n  planCompleteDate DateTime\n  progress        Int      @default(0)\n  effectVerify    String?\n  isEffective     String   @default(\"待验证\") // 有效/部分有效/无效/待验证\n  createdAt       DateTime @default(now())\n  updatedAt       DateTime @updatedAt\n\n  issue       Issue? @relation(fields: [issueId], references: [id])\n  responsible User   @relation(\"MeasureResponsible\", fields: [responsibleId], references: [id])\n}\n\n// ===== 执行管理体系 =====\n\n// 年度经营目标\nmodel AnnualGoal {\n  id             String   @id @default(cuid())\n  year           Int\n  departmentId   String\n  indicatorName  String\n  indicatorType  String   // 财务类/客户类/流程类/学习成长类\n  targetValue    Float\n  weight         Float    // 权重百分比\n  q1Target       Float?   // 一季度目标\n  q2Target       Float?   // 二季度目标\n  q3Target       Float?   // 三季度目标\n  q4Target       Float?   // 四季度目标\n  actualValue    Float?\n  achievement    Float?   @default(0)\n  status         String   @default(\"草稿\") // 草稿/已签订/执行中/已完成\n  createdAt      DateTime @default(now())\n  updatedAt      DateTime @updatedAt\n\n  department    Department     @relation(fields: [departmentId], references: [id])\n  monthlyPlans  MonthlyPlan[]\n}\n\n// 月度经营计划\nmodel MonthlyPlan {\n  id             String   @id @default(cuid())\n  yearMonth      String   // 2026-04\n  departmentId   String\n  submitterId    String\n  annualGoalId   String?\n  planItems      String   // JSON格式的计划项列表\n  totalBudget    Float?\n  reviewStatus   String   @default(\"待提交\") // 待提交/待审核/已通过/需修改\n  reviewComment  String?\n  reviewedBy     String?\n  reviewedAt     DateTime?\n  submitTime     DateTime @default(now())\n  createdAt      DateTime @default(now())\n  updatedAt      DateTime @updatedAt\n\n  department   Department   @relation(fields: [departmentId], references: [id])\n  submitter    User         @relation(\"PlanSubmitter\", fields: [submitterId], references: [id])\n  annualGoal   AnnualGoal?  @relation(fields: [annualGoalId], references: [id])\n  weeklyPlans  WeeklyPlan[]\n}\n\n// 周计划\nmodel WeeklyPlan {\n  id             String   @id @default(cuid())\n  weekDate       DateTime // 周一日期\n  monthlyPlanId  String\n  departmentId   String\n  submitterId    String\n  planItems      String   // JSON格式的周计划项\n  completedItems String?  // JSON格式的完成情况\n  progress       Int      @default(0)\n  submitTime     DateTime @default(now())\n  createdAt      DateTime @default(now())\n  updatedAt      DateTime @updatedAt\n\n  monthlyPlan MonthlyPlan @relation(fields: [monthlyPlanId], references: [id])\n  department  Department  @relation(fields: [departmentId], references: [id])\n  submitter   User        @relation(\"WeeklyPlanSubmitter\", fields: [submitterId], references: [id])\n  dailyLogs   DailyLog[]\n}\n\n// 每日日志\nmodel DailyLog {\n  id             String   @id @default(cuid())\n  logDate        DateTime\n  weeklyPlanId   String\n  userId         String\n  departmentId   String\n  workContent    String   // 今日工作内容\n  achievements   String?  // 完成成果\n  workHours      Float    @default(8)\n  progress       Int      @default(0) // 日进度百分比\n  problems       String?  // 遇到的问题\n  nextDayPlan    String?  // 明日计划\n  submitTime     DateTime @default(now())\n  createdAt      DateTime @default(now())\n  updatedAt      DateTime @updatedAt\n\n  weeklyPlan WeeklyPlan @relation(fields: [weeklyPlanId], references: [id])\n  user       User       @relation(fields: [userId], references: [id])\n  department Department @relation(fields: [departmentId], references: [id])\n  tasks      TaskExecution[]\n}\n\n// 任务执行记录\nmodel TaskExecution {\n  id             String   @id @default(cuid())\n  dailyLogId     String\n  taskName       String\n  description    String?\n  planHours      Float?\n  actualHours    Float?\n  status         String   @default(\"进行中\") // 未开始/进行中/已完成/延期\n  completion     Int      @default(0) // 完成度百分比\n  result         String?  // 执行结果\n  createdAt      DateTime @default(now())\n  updatedAt      DateTime @updatedAt\n\n  dailyLog DailyLog @relation(fields: [dailyLogId], references: [id])\n}\n\n// 成果记录\nmodel Achievement {\n  id             String   @id @default(cuid())\n  achievementNumber String @unique // A2026040001\n  title          String\n  description    String\n  departmentId   String\n  userId         String\n  achievementDate DateTime\n  achievementType String  // 个人成果/团队成果\n  relatedPlanId  String?  // 关联的计划ID\n  relatedTaskId  String?  // 关联的任务ID\n  files          String?  // JSON格式的附件列表\n  status         String   @default(\"待审核\") // 待审核/已通过/需改进\n  reviewedBy     String?\n  reviewedAt     DateTime?\n  reviewComment  String?\n  createdAt      DateTime @default(now())\n  updatedAt      DateTime @updatedAt\n\n  department Department @relation(fields: [departmentId], references: [id])\n  user       User       @relation(fields: [userId], references: [id])\n}","old_string":"// 改进措施表\nmodel ImprovementMeasure {\n  id              String   @id @default(cuid())\n  measureNumber   String   @unique\n  issueId         String?\n  description     String\n  responsibleId   String\n  planCompleteDate DateTime\n  progress        Int      @default(0)\n  effectVerify    String?\n  isEffective     String   @default(\"待验证\") // 有效/部分有效/无效/待验证\n  createdAt       DateTime @default(now())\n  updatedAt       DateTime @updatedAt\n\n  issue       Issue? @relation(fields: [issueId], references: [id])\n  responsible User   @relation(\"MeasureResponsible\", fields: [responsibleId], references: [id])\n}"},"tool_response":"Successfully edited file: /workspace/backend/prisma/schema.prisma","client":"CLI","version":"2.71.1","generation_id":"1abc62f689ab427b83533cea2dcf23eb","model":"glm-5.0","call_id":"019d70969389be2d676415a907031245"}
